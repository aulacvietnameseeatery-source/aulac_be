title Dish Module - Persistence Layer

package "Repositories" as Repositories {
    interface IDishRepository {
        +FindByIdAsync(long, CancellationToken): Task<Dish?>
        +GetDishByIdAsync(long, CancellationToken): Task<Dish?>
        +FindByIdForActionAsync(long, CancellationToken): Task<Dish?>
        +FindTagByDishIdAsync(long, CancellationToken): Task<List<DishTag>>
        +UpdateStatusAsync(long, DishStatusCode, CancellationToken): Task<DishStatusDto>
        +GetDishesAsync(GetDishesRequest, CancellationToken): Task<(IEnumerable<Dish>, int)>
        +GetDishesForCustomerAsync(GetDishesRequest, CancellationToken): Task<(IEnumerable<Dish>, int)>
        +GetAllCategoriesAsync(CancellationToken): Task<List<string>>
        +GetDishStatusesAsync(CancellationToken): Task<List<DishStatusDto>>
        +CreateDishAsync(Dish, CancellationToken): Task<long>
        +UpdateDishAsync(Dish, CancellationToken): Task
        +GetAllDishCategoriesAsync(): Task<List<DishCategorySimpleDto>>
        +GetPosDishesAsync(bool): Task<List<DishPosResponseDto>>
    }

    class DishRepository {
        -_context: AuLacDbContext
        -_logger: ILogger<DishRepository>
        +FindByIdAsync(long, CancellationToken): Task<Dish?>
        +GetDishByIdAsync(long, CancellationToken): Task<Dish?>
        +FindByIdForActionAsync(long, CancellationToken): Task<Dish?>
        +FindTagByDishIdAsync(long, CancellationToken): Task<List<DishTag>>
        +UpdateStatusAsync(long, DishStatusCode, CancellationToken): Task<DishStatusDto>
        +GetDishesAsync(GetDishesRequest, CancellationToken): Task<(IEnumerable<Dish>, int)>
        +GetDishesForCustomerAsync(GetDishesRequest, CancellationToken): Task<(IEnumerable<Dish>, int)>
        +GetAllCategoriesAsync(CancellationToken): Task<List<string>>
        +GetDishStatusesAsync(CancellationToken): Task<List<DishStatusDto>>
        +CreateDishAsync(Dish, CancellationToken): Task<long>
        +UpdateDishAsync(Dish, CancellationToken): Task
        +GetAllDishCategoriesAsync(): Task<List<DishCategorySimpleDto>>
        +GetPosDishesAsync(bool): Task<List<DishPosResponseDto>>
    }
}

package "Data Context" as Context {
    class AuLacDbContext {
        +Dishes: DbSet<Dish>
        +DishCategories: DbSet<DishCategory>
        +DishMedia: DbSet<DishMedia>
        +Recipes: DbSet<Recipe>
        +DishTags: DbSet<DishTag>
        +LookupValues: DbSet<LookupValue>
        +Media: DbSet<Media>
        +Ingredients: DbSet<Ingredient>
    }
}

package "Queries" as Queries {
    class GetDishesRequest {
        +PageIndex: int
        +PageSize: int
        +SearchTerm: string?
        +CategoryId: int?
        +Status: DishStatusCode?
        +Locale: string
        +SortBy: string?
        +SortDirection: string?
    }
}

' Relationships
DishRepository ..|> IDishRepository : implements
DishRepository --> AuLacDbContext : uses
DishRepository --> GetDishesRequest : uses

AuLacDbContext --> Dish : contains
AuLacDbContext --> DishCategory : contains
AuLacDbContext --> DishMedia : contains
AuLacDbContext --> Recipe : contains
AuLacDbContext --> DishTag : contains

@enduml