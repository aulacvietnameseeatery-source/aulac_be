title Dish Module - Application Layer

package "Services" as Services {
    interface IDishService {
        +GetDishByIdAsync(long, string?, CancellationToken): Task<DishDetailDto?>
        +GetDishesForAdminAsync(GetDishesRequest, CancellationToken): Task<(IEnumerable<DishManagementDto>, int)>
        +GetDishesForCustomerAsync(GetDishesRequest, CancellationToken): Task<(IEnumerable<DishDisplayDto>, int)>
        +GetAllCategoriesAsync(CancellationToken): Task<List<string>>
        +GetDishStatusesAsync(CancellationToken): Task<List<DishStatusDto>>
        +UpdateDishStatusAsync(long, DishStatusCode, CancellationToken): Task<DishStatusDto>
        +CreateDishAsync(CreateDishRequest, IReadOnlyList<MediaFileInput>, IReadOnlyList<MediaFileInput>, MediaFileInput?, CancellationToken): Task<long>
        +GetDishByIdAsync(long, CancellationToken): Task<DishDetailForActionsDto>
        +UpdateDishAsync(UpdateDishRequest, IReadOnlyList<MediaFileInput>, IReadOnlyList<MediaFileInput>, MediaFileInput?, IReadOnlyList<long>, CancellationToken): Task
        +GetAllDishCategoriesAsync(): Task<List<DishCategorySimpleDto>>
        +GetPosDishesAsync(bool): Task<List<DishPosResponseDto>>
    }

    class DishService {
        -_dishRepository: IDishRepository
        -_lookupService: ILookupService
        -_fileStorage: IFileStorageService
        -_logger: ILogger<DishService>
        +GetDishByIdAsync(long, string?, CancellationToken): Task<DishDetailDto?>
        +GetDishesForAdminAsync(GetDishesRequest, CancellationToken): Task<(IEnumerable<DishManagementDto>, int)>
        +GetDishesForCustomerAsync(GetDishesRequest, CancellationToken): Task<(IEnumerable<DishDisplayDto>, int)>
        +GetAllCategoriesAsync(CancellationToken): Task<List<string>>
        +GetDishStatusesAsync(CancellationToken): Task<List<DishStatusDto>>
        +UpdateDishStatusAsync(long, DishStatusCode, CancellationToken): Task<DishStatusDto>
        +CreateDishAsync(CreateDishRequest, IReadOnlyList<MediaFileInput>, IReadOnlyList<MediaFileInput>, MediaFileInput?, CancellationToken): Task<long>
        +GetDishByIdAsync(long, CancellationToken): Task<DishDetailForActionsDto>
        +UpdateDishAsync(UpdateDishRequest, IReadOnlyList<MediaFileInput>, IReadOnlyList<MediaFileInput>, MediaFileInput?, IReadOnlyList<long>, CancellationToken): Task
        +GetAllDishCategoriesAsync(): Task<List<DishCategorySimpleDto>>
        +GetPosDishesAsync(bool): Task<List<DishPosResponseDto>>
    }
}

package "DTOs" as DTOs {
    class CreateDishRequest {
        +CategoryId: int
        +DishName: string
        +Price: decimal
        +Description: string?
        +ShortDescription: string?
        +Slogan: string?
        +Calories: int?
        +PrepTimeMinutes: int?
        +CookTimeMinutes: int?
        +IsOnline: bool
        +Recipes: List<CreateRecipeRequest>
        +Tags: List<int>
    }

    class UpdateDishRequest {
        +DishId: long
        +CategoryId: int
        +DishName: string
        +Price: decimal
        +Description: string?
        +ShortDescription: string?
        +Slogan: string?
        +Calories: int?
        +PrepTimeMinutes: int?
        +CookTimeMinutes: int?
        +IsOnline: bool
        +Recipes: List<UpdateRecipeRequest>
        +Tags: List<int>
    }

    class CreateRecipeRequest {
        +IngredientId: int
        +Quantity: decimal
        +Unit: string
        +Note: string?
    }

    class UpdateRecipeRequest {
        +RecipeId: long?
        +IngredientId: int
        +Quantity: decimal
        +Unit: string
        +Note: string?
    }

    class MediaFileInput {
        +FileName: string
        +ContentType: string
        +Content: Stream
    }
}

package "Mappers" as Mappers {
    class DishMapper {
        +ToDetailDto(Dish, List<DishTag>, IFileStorageService): DishDetailForActionsDto
        +ToManagementDto(Dish): DishManagementDto
        +ToDisplayDto(Dish, string): DishDisplayDto
        +ToPosResponseDto(Dish): DishPosResponseDto
    }
}

' Relationships
DishService ..|> IDishService : implements
DishService --> IDishRepository : uses
DishService --> ILookupService : uses
DishService --> IFileStorageService : uses
DishService --> DishMapper : uses

DishService --> CreateDishRequest : uses
DishService --> UpdateDishRequest : uses
DishService --> MediaFileInput : uses

DishMapper --> DishDetailForActionsDto : creates
DishMapper --> DishManagementDto : creates
DishMapper --> DishDisplayDto : creates
DishMapper --> DishPosResponseDto : creates

@enduml