title 2.9.2.7 Update Dish Status

actor "Admin User" as Admin
participant "DishController" as Controller
participant "IDishService" as IService
participant "DishService" as Service
participant "IDishRepository" as IRepo
participant "DishRepository" as Repo
participant "AuLacDbContext" as Context

autonumber

Admin -> Controller: PATCH /api/dish/{id}/status\n{"status": "OUT_OF_STOCK"}
activate Controller

Controller -> IService: UpdateDishStatusAsync(id, request.Status, cancellationToken)
activate IService

IService -> Service: UpdateDishStatusAsync(id, newStatus, cancellationToken)
activate Service

Service -> IRepo: UpdateStatusAsync(id, newStatus, cancellationToken)
activate IRepo

IRepo -> Repo: UpdateStatusAsync(id, newStatus, cancellationToken)
activate Repo

Repo -> Context: Find dish by ID
activate Context

Context --> Repo: Return dish entity
deactivate Context

alt dish not found
    Repo --> IRepo: Return null
    IRepo --> Service: Return null
    Service --> Service: Throw exception or return error
else dish found
    Repo -> Context: Update dish status and UpdatedAt
    activate Context
    Context --> Repo: Save changes
    deactivate Context

    Repo -> Context: Query updated dish with status info
    activate Context
    Context --> Repo: Return DishStatusDto
    deactivate Context

    Repo --> IRepo: Return DishStatusDto
    deactivate Repo

    IRepo --> Service: Return DishStatusDto
    deactivate IRepo

    Service --> IService: Return DishStatusDto
    deactivate Service

    IService --> Controller: Return DishStatusDto
    deactivate IService

    Controller -> Controller: Create ApiResponse<DishStatusDto>
    Controller -> Controller: Log status update

    Controller --> Admin: Return 200 OK with updated status
end

deactivate Controller

@enduml