title 2.9.2.4 View Dish Detail (Public)

actor "Customer" as Customer
participant "DishController" as Controller
participant "IDishService" as IService
participant "DishService" as Service
participant "IDishRepository" as IRepo
participant "DishRepository" as Repo
participant "AuLacDbContext" as Context
participant "IFileStorageService" as FileStorage

autonumber

Customer -> Controller: GET /api/dish/{id}?lang=en
activate Controller

Controller -> IService: GetDishByIdAsync(id, lang, cancellationToken)
activate IService

IService -> Service: GetDishByIdAsync(id, langCode, cancellationToken)
activate Service

Service -> IRepo: GetDishByIdAsync(id, cancellationToken)
activate IRepo

IRepo -> Repo: GetDishByIdAsync(id, cancellationToken)
activate Repo

Repo -> Context: Query Dish with includes\n(Category, DishMedia, Recipes.Ingredient)
activate Context

Context --> Repo: Return dish entity or null
deactivate Context

Repo --> IRepo: Return dish
deactivate Repo

IRepo --> Service: Return dish
deactivate IRepo

alt dish == null
    Service --> Service: Return null
    Service --> IService: Return null
    IService --> Controller: Return null
    Controller -> Controller: Create ApiResponse<object> with 404
    Controller --> Customer: Return 404 Not Found
else dish found
    Service -> Service: Extract language code (default "en")
    Service -> Service: Build DishDetailDto with translations
    Service -> FileStorage: ShouldShowMedia("landing_page.show_dish_image")
    activate FileStorage
    FileStorage --> Service: Return boolean
    deactivate FileStorage

    alt show images
        Service -> Service: Get image URLs from DishMedia\n(Filter non-video, resolve public URLs)
        Service -> FileStorage: GetPublicUrl() for each image
        activate FileStorage
        FileStorage --> Service: Return public URLs
        deactivate FileStorage
    end

    Service -> FileStorage: ShouldShowMedia("landing_page.show_dish_video")
    activate FileStorage
    FileStorage --> Service: Return boolean
    deactivate FileStorage

    alt show video
        Service -> Service: Get video URL from DishMedia\n(Filter video, resolve public URL)
        Service -> FileStorage: GetPublicUrl() for video
        activate FileStorage
        FileStorage --> Service: Return public URL
        deactivate FileStorage
    end

    Service -> Service: Build RecipeItemDto list with translations
    Service --> IService: Return DishDetailDto
    deactivate Service

    IService --> Controller: Return DishDetailDto
    deactivate IService

    Controller -> Controller: Create ApiResponse<DishDetailDto>

    Controller --> Customer: Return 200 OK with dish details
end

deactivate Controller

@enduml