title 2.9.2.3 View Dish Detail (Admin)

actor "Admin User" as Admin
participant "DishController" as Controller
participant "IDishService" as IService
participant "DishService" as Service
participant "IDishRepository" as IRepo
participant "DishRepository" as Repo
participant "AuLacDbContext" as Context
participant "DishMapper" as Mapper
participant "IFileStorageService" as FileStorage

autonumber

Admin -> Controller: GET /api/dish/detail/{id}
activate Controller

Controller -> IService: GetDishByIdAsync(id, cancellationToken)
activate IService

IService -> Service: GetDishByIdAsync(id, cancellationToken)
activate Service

Service -> IRepo: FindByIdForActionAsync(id, cancellationToken)
activate IRepo

IRepo -> Repo: FindByIdForActionAsync(id, cancellationToken)
activate Repo

Repo -> Context: Query Dish with includes\n(Category, DishMedia, Recipes.Ingredient, DishTags.Tag)
activate Context

Context --> Repo: Return dish entity or null
deactivate Context

alt dish == null
    Repo --> IRepo: Return null
    IRepo --> Service: Return null
    Service --> Service: Throw KeyNotFoundException
else dish found
    Repo --> IRepo: Return dish
    deactivate Repo

    IRepo --> Service: Return dish
    deactivate IRepo

    Service -> IRepo: FindTagByDishIdAsync(id, cancellationToken)
    activate IRepo

    IRepo -> Repo: FindTagByDishIdAsync(id, cancellationToken)
    activate Repo

    Repo -> Context: Query DishTags for dish
    activate Context

    Context --> Repo: Return dishTags list
    deactivate Context

    Repo --> IRepo: Return dishTags
    deactivate Repo

    IRepo --> Service: Return dishTags
    deactivate IRepo

    Service -> Mapper: ToDetailDto(dish, dishTags, _fileStorage)
    activate Mapper

    Mapper -> FileStorage: Get public URLs for media files
    activate FileStorage

    FileStorage --> Mapper: Return public URLs
    deactivate FileStorage

    Mapper --> Service: Return DishDetailForActionsDto
    deactivate Mapper
end

Service --> IService: Return DishDetailForActionsDto
deactivate Service

IService --> Controller: Return DishDetailForActionsDto
deactivate IService

Controller -> Controller: Create ApiResponse<DishDetailForActionsDto>

Controller --> Admin: Return 200 OK with dish details
deactivate Controller

@enduml