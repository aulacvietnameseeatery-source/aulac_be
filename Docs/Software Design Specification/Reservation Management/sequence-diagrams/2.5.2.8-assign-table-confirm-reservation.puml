@startuml
title 2.5.2.8 Assign Table & Confirm Reservation

skinparam maxMessageSize 250
skinparam sequence {
    ParticipantBackgroundColor #ffffff
    ActorBackgroundColor #ffffff
}

autonumber

actor ":Staff" as U
participant ":ReservationDetailPage" as Client
participant ":ReservationController" as Ctrl
participant ":AdminReservationService" as Svc
participant ":IUnitOfWork" as UoW
participant ":IReservationRepository" as ResRepo
participant ":ITableRepository" as TableRepo
participant ":Database" as DB

activate U

U ->> Client : Click "Approve" on a PENDING reservation
activate Client

Client ->> Ctrl : PATCH /api/reservations/{id}/assign-and-confirm\n(AssignTableRequest)
activate Ctrl

Ctrl ->> Svc : AssignTableAndConfirmAsync(reservationId, tableIds, ct)
activate Svc

Svc ->> ResRepo : GetByIdWithFullDetailsAsync(reservationId, ct)
activate ResRepo
ResRepo ->> DB : Query reservation with tables, status, and source
activate DB
DB -->> ResRepo : Return reservation entity
deactivate DB
ResRepo -->> Svc : Reservation
deactivate ResRepo

alt#White Reservation not found
    Svc -->> Ctrl : throw KeyNotFoundException
    Ctrl -->> Client : 404 Not Found
    Client -->> U : Display "Reservation not found"
else#White Reservation found but has no tables assigned
    Svc -->> Ctrl : throw InvalidOperationException
    Ctrl -->> Client : 400 Bad Request
    Client -->> U : Display "No tables assigned, please edit first"
else#White Reservation valid with tables

    Svc ->> UoW : BeginTransactionAsync(ct)
    activate UoW
    UoW -->> Svc : Transaction started
    deactivate UoW

    Svc ->> Svc : Set reservation status to CONFIRMED

    Svc ->> Svc : Calculate time until 2 hours before reservation

    alt#White Less than 2 hours until reservation
        loop#White For each assigned table
            Svc ->> TableRepo : UpdateStatusAsync(tableId, RESERVED, ct)
            activate TableRepo
            TableRepo ->> DB : Update table status to RESERVED
            activate DB
            DB -->> TableRepo : Updated
            deactivate DB
            TableRepo -->> Svc : void
            deactivate TableRepo

            Svc ->> Svc : Notify real-time table status changed to RESERVED
        end
    else#White More than 2 hours until reservation
        Svc ->> Svc : Schedule Hangfire table lock job (lock 2h before reserved time)
    end

    Svc ->> UoW : SaveChangesAsync(ct)
    activate UoW
    UoW -->> Svc : Changes saved
    deactivate UoW

    Svc ->> Svc : Schedule Hangfire no-show check job (15 min after reserved time)

    Svc ->> UoW : CommitAsync(ct)
    activate UoW
    UoW -->> Svc : Transaction committed
    deactivate UoW

    Svc ->> Svc : Notify real-time reservation status changed to CONFIRMED
    Svc ->> Svc : Publish RESERVATION_STATUS_CHANGED notification

    Svc -->> Ctrl : void (success)
    deactivate Svc

    Ctrl -->> Client : 200 OK
    deactivate Ctrl

    Client -->> U : Display "Reservation confirmed successfully"
end

deactivate Client
deactivate U

@enduml
