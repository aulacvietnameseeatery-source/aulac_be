@startuml
title Reservation Management Module - Domain Layer Class Diagram

package "Domain Layer" {

    enum ReservationStatusCode <<enum>> {
        PENDING
        CONFIRMED
        CHECKED_IN
        CANCELLED
        NO_SHOW
        COMPLETED
    }

    enum ReservationSourceCode <<enum>> {
        PHONE
        WALK_IN
        ONLINE
    }

    enum TableStatusCode <<enum>> {
        AVAILABLE
        OCCUPIED
        RESERVED
        LOCKED
    }

    enum TableZoneCode <<enum>> {
        INDOOR
        OUTDOOR
        ROOFTOP
    }

    class Reservation <<Entity>> {
        +ReservationId : long
        +CustomerId : long?
        +CustomerName : string
        +Phone : string
        +Email : string?
        +PartySize : int
        +ReservedTime : DateTime
        +CreatedAt : DateTime?
        +SourceLvId : uint
        +Notes : string?
        +ReservationStatusLvId : uint
        +Customer : Customer?
        +ReservationStatusLv : LookupValue
        +SourceLv : LookupValue
        +Tables : ICollection<RestaurantTable>
    }

    class RestaurantTable <<Entity>> {
        +TableId : long
        +TableCode : string
        +Capacity : int
        +TableQrImg : long?
        +TableStatusLvId : uint
        +TableTypeLvId : uint
        +ZoneLvId : uint
        +IsOnline : bool?
        +QrToken : string?
        +CreatedAt : DateTime
        +UpdatedAt : DateTime
        +IsDeleted : bool
        +TableStatusLv : LookupValue
        +TableTypeLv : LookupValue
        +ZoneLv : LookupValue
        +Reservations : ICollection<Reservation>
    }
}

package "Cross-Module Entities" <<Rectangle>> {

    class Customer <<Entity>> {
        +CustomerId : long
        +FullName : string
        +Phone : string
        +Email : string?
    }

    class LookupValue <<Entity>> {
        +ValueId : uint
        +TypeId : ushort
        +ValueCode : string
        +ValueName : string
        +SortOrder : short
        +IsActive : bool?
    }
}

' ── Relationships ──

Reservation "0..*" --> "0..1" Customer : placed by customer
Reservation "0..*" --> "1" LookupValue : references status via ReservationStatusLvId
Reservation "0..*" --> "1" LookupValue : references source via SourceLvId
Reservation "0..*" o-- "0..*" RestaurantTable : assigned tables (many-to-many)

RestaurantTable "0..*" --> "1" LookupValue : references status via TableStatusLvId
RestaurantTable "0..*" --> "1" LookupValue : references type via TableTypeLvId
RestaurantTable "0..*" --> "1" LookupValue : references zone via ZoneLvId

@enduml
