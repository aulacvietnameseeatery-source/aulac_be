package "Persistence Layer" {

interface IReservationRepository <<interface>> {
+ CreateAsync(reservation: Reservation, ct: CancellationToken): Task<Reservation>
+ GetByIdAsync(reservationId: long, ct: CancellationToken): Task<Reservation?>
+ GetTableReservationsForTimeAsync(tableId: long, reservedTime: DateTime, durationMinutes: int, cancelledStatusId: uint, noShowStatusId: uint, completedStatusId: uint, ct: CancellationToken): Task<List<Reservation>>
+ GetReservationsAsync(request: GetReservationsRequest, ct: CancellationToken): Task<(List<ReservationManagementDto>, int)>
+ GetReservationStatusesAsync(ct: CancellationToken): Task<List<LookupValue>>
+ GetByIdWithTablesAsync(id: long, ct: CancellationToken): Task<Reservation?>
+ UpdateAsync(reservation: Reservation, ct: CancellationToken): Task
+ GetByIdWithFullDetailsAsync(reservationId: long, ct: CancellationToken): Task<Reservation?>
+ DeleteAsync(reservation: Reservation, ct: CancellationToken): Task
}

class ReservationRepository <<Repository>> {
- _context: RestaurantMgmtContext
+ CreateAsync(reservation: Reservation, ct: CancellationToken): Task<Reservation>
+ GetByIdAsync(reservationId: long, ct: CancellationToken): Task<Reservation?>
+ GetTableReservationsForTimeAsync(tableId: long, reservedTime: DateTime, durationMinutes: int, cancelledStatusId: uint, noShowStatusId: uint, completedStatusId: uint, ct: CancellationToken): Task<List<Reservation>>
+ GetReservationsAsync(request: GetReservationsRequest, ct: CancellationToken): Task<(List<ReservationManagementDto>, int)>
+ GetReservationStatusesAsync(ct: CancellationToken): Task<List<LookupValue>>
+ GetByIdWithTablesAsync(id: long, ct: CancellationToken): Task<Reservation?>
+ UpdateAsync(reservation: Reservation, ct: CancellationToken): Task
+ GetByIdWithFullDetailsAsync(reservationId: long, ct: CancellationToken): Task<Reservation?>
+ DeleteAsync(reservation: Reservation, ct: CancellationToken): Task
}

}

package "Domain Layer" {

class Reservation <<Entity>> {
+ ReservationId: long
+ CustomerId: long?
+ CustomerName: string
+ Phone: string
+ Email: string?
+ PartySize: int
+ ReservedTime: DateTime
+ CreatedAt: DateTime?
+ SourceLvId: uint
+ Notes: string?
+ ReservationStatusLvId: uint
}

class RestaurantTable <<Entity>> {
+ TableId: long
+ TableCode: string
+ Capacity: int
+ TableQrImg: long?
+ TableStatusLvId: uint
+ TableTypeLvId: uint
+ ZoneLvId: uint
+ IsOnline: bool?
+ QrToken: string?
+ CreatedAt: DateTime
+ UpdatedAt: DateTime
+ UpdatedByStaffId: long?
+ IsDeleted: bool
}

class Customer <<Entity>> {
+ CustomerId: long
+ Name: string
+ Phone: string
+ Email: string?
+ CreatedAt: DateTime
+ UpdatedAt: DateTime
+ IsDeleted: bool
}

class LookupValue <<Entity>> {
+ ValueId: uint
+ TypeId: long
+ ValueName: string
+ ValueCode: string
+ IsActive: bool
+ CreatedAt: DateTime
+ UpdatedAt: DateTime
+ IsDeleted: bool
}

}

' Relationships

ReservationController --> IAdminReservationService : uses for admin reservation management
PublicReservationController --> IPublicReservationService : uses for public reservation operations
ManualReservationController --> IAdminReservationService : uses for manual reservation creation

IPublicReservationService ..|> PublicReservationService : implements
IAdminReservationService ..|> AdminReservationService : implements

PublicReservationService --> IReservationRepository : depends on for reservation data access
AdminReservationService --> IReservationRepository : depends on for reservation data access

IReservationRepository ..|> ReservationRepository : implements

ReservationRepository --> Reservation : creates and manages reservation entities

Reservation *-- RestaurantTable : has assigned tables (many-to-many)
Reservation --> Customer : belongs to customer (optional)
Reservation --> LookupValue : has reservation status
Reservation --> LookupValue : has reservation source

@enduml