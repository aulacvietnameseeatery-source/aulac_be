@startuml
skinparam sequence {
    ParticipantBackgroundColor #ffffff
    ActorBackgroundColor #ffffff
}

autonumber

actor ":User" as U
participant ":ReservationController" as Ctrl
participant ":IAdminReservationService" as Svc
participant ":AdminReservationService" as SvcImpl
participant ":IReservationRepository" as Repo
participant ":ReservationRepository" as RepoImpl
participant ":ITableRepository" as TableRepo
participant ":TableRepository" as TableRepoImpl
participant ":IUnitOfWork" as UoW
database ":Database" as DB

U ->> Ctrl : PATCH /api/reservations/{id}/assign-and-confirm (AssignTableRequest)
activate U
Ctrl ->> Svc : AssignTableAndConfirmAsync(id, tableIds, ct)
activate Ctrl
Svc ->> SvcImpl : AssignTableAndConfirmAsync(id, tableIds, ct)
activate Svc
SvcImpl ->> Repo : GetByIdAsync(id, ct)
activate SvcImpl
Repo ->> RepoImpl : GetByIdAsync(id, ct)
activate Repo
RepoImpl ->> DB : SELECT reservation WHERE id = {id}
activate DB
DB -->> RepoImpl : Reservation entity
deactivate DB
RepoImpl -->> Repo : Reservation entity
deactivate Repo
Repo -->> SvcImpl : Reservation entity
deactivate SvcImpl

alt#White reservation found
    SvcImpl ->> TableRepo : GetTablesByIdsAsync(tableIds, ct)
    activate SvcImpl
    TableRepo ->> TableRepoImpl : GetTablesByIdsAsync(tableIds, ct)
    activate TableRepo
    TableRepoImpl ->> DB : SELECT tables WHERE id IN {tableIds}
    activate DB
    DB -->> TableRepoImpl : List of tables
    deactivate DB
    TableRepoImpl -->> TableRepo : List of tables
    deactivate TableRepo
    TableRepo -->> SvcImpl : List of tables
    deactivate SvcImpl
    SvcImpl ->> SvcImpl : Assign tables to reservation and update status to confirmed
    SvcImpl ->> Repo : UpdateAsync(reservation, ct)
    activate SvcImpl
    Repo ->> RepoImpl : UpdateAsync(reservation, ct)
    activate Repo
    RepoImpl ->> DB : UPDATE Reservations and ReservationTables
    activate DB
    DB -->> RepoImpl : success
    deactivate DB
    RepoImpl -->> Repo : success
    deactivate Repo
    Repo -->> SvcImpl : success
    deactivate SvcImpl
    SvcImpl ->> UoW : CommitAsync(ct)
    activate SvcImpl
    UoW -->> SvcImpl : success
    deactivate SvcImpl
    SvcImpl -->> Svc : success
    deactivate Svc
    Svc -->> Ctrl : success
    deactivate Ctrl
    Ctrl -->> U : 200 OK
else reservation not found
    SvcImpl -->> Svc : KeyNotFoundException
    deactivate Svc
    Svc -->> Ctrl : KeyNotFoundException
    deactivate Ctrl
    Ctrl -->> U : 404 Not Found
end
deactivate U
@enduml