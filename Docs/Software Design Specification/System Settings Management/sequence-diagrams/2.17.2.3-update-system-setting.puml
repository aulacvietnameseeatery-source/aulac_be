@startuml
title 2.17.2.3 - Update System Setting

skinparam maxMessageSize 250
skinparam sequence {
    ParticipantBackgroundColor #ffffff
    ActorBackgroundColor #ffffff
}

autonumber

actor ":User" as U
participant ":SystemSettingsPage" as Client
participant ":SystemSettingController" as Ctrl
participant ":SystemSettingService" as Svc
participant ":SystemSettingRepository" as Repo
participant ":Database" as DB

activate U

U ->> Client : Edit setting value and submit
activate Client

Client ->> Ctrl : PUT /api/system-settings/{key}\n{ UpdateSettingValueDto }
activate Ctrl

Ctrl ->> Svc : SetStringAsync(key, value, description, isSensitive, updatedBy, ct)
activate Svc

Svc ->> Repo : SaveAsync(SystemSetting, ct)
activate Repo

Repo ->> DB : Find existing setting by key
activate DB
DB -->> Repo : Return existing SystemSetting or null
deactivate DB

alt#White Setting exists
    Repo ->> DB : Update setting value, description, updatedBy, updatedAt
    activate DB
    DB -->> Repo : Confirm update
    deactivate DB
else Setting does not exist
    Repo ->> DB : Insert new system setting record
    activate DB
    DB -->> Repo : Confirm insert
    deactivate DB
end

Repo -->> Svc : void
deactivate Repo

Svc ->> Svc : ClearCacheAsync(key)

Svc -->> Ctrl : void
deactivate Svc

alt#White Success
    Ctrl -->> Client : 200 OK with updated setting data
else Error occurred
    Ctrl -->> Client : 500 Internal Server Error
end

deactivate Ctrl

Client -->> U : Display success confirmation
deactivate Client
deactivate U

@enduml
