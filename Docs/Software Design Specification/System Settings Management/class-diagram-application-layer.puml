    interface IEmailTemplateService <<interface>> {
        +GetByCodeAsync(code: string, ct: CancellationToken) : Task<EmailTemplateDto?>
        +GetAllAsync(ct: CancellationToken) : Task<List<EmailTemplateDto>>
