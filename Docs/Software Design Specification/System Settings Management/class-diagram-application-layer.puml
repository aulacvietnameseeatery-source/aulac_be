        +UpdateAsync(id: long, request: UpdateEmailTemplateRequest, ct: CancellationToken) : Task<EmailTemplateDto>
        +DeleteAsync(id: long, ct: CancellationToken) : Task<bool>
    }

    class EmailTemplateService <<Service>> {
        -_repository : IEmailTemplateRepository
        +EmailTemplateService(repository: IEmailTemplateRepository)
        +GetByCodeAsync(code: string, ct: CancellationToken) : Task<EmailTemplateDto?>
        +GetAllAsync(ct: CancellationToken) : Task<List<EmailTemplateDto>>
        +CreateAsync(request: CreateEmailTemplateRequest, ct: CancellationToken) : Task<EmailTemplateDto>
        +UpdateAsync(id: long, request: UpdateEmailTemplateRequest, ct: CancellationToken) : Task<EmailTemplateDto>
        +DeleteAsync(id: long, ct: CancellationToken) : Task<bool>
        -MapToDto(template: EmailTemplate) : EmailTemplateDto
    }
}

SystemSettingService ..|> ISystemSettingService : implements
