@startuml
title 2.2.2.6 Reset Employee Password

skinparam maxMessageSize 250
skinparam sequence {
    ParticipantBackgroundColor #ffffff
    ActorBackgroundColor #ffffff
}

autonumber

actor ":Admin" as U
participant ":AccountDetailPage" as Client
participant ":AccountController" as Ctrl
participant ":AccountService" as Svc
participant ":AccountRepository" as Repo
participant ":Database" as DB

activate U

U ->> Client : Click reset password button for employee account

activate Client

Client ->> Ctrl : POST /api/account/{id}/reset-password
activate Ctrl

Ctrl ->> Svc : ResetToDefaultPasswordAsync(id: long, ct)
activate Svc

Svc ->> Svc : Retrieve default password from ISystemSettingService("default_password")

alt#White Default password not configured
    Svc -->> Ctrl : throw InvalidOperationException("Default password not configured")
    Ctrl -->> Client : 400 Bad Request - ApiResponse { "Default password not configured" }
    Client -->> U : Display configuration error
else Default password available
    Svc ->> Repo : FindByIdAsync(accountId: long, ct)
    activate Repo
    Repo ->> DB : Query staff account by ID
    activate DB
    DB -->> Repo : Return staff account or null
    deactivate DB
    Repo -->> Svc : StaffAccount?
    deactivate Repo

    alt#White Account not found
        Svc -->> Ctrl : throw NotFoundException("Account not found")
        Ctrl -->> Client : 404 Not Found - ApiResponse { "Account not found." }
        Client -->> U : Display account not found error
    else Account found
        Svc ->> Svc : Hash default password via IPasswordHasher
        Svc ->> Svc : Resolve LOCKED status ID via ILookupResolver
        Svc ->> Svc : Set PasswordHash, AccountStatusLvId = LOCKED, IsLocked = true

        Svc ->> Repo : UpdateAccountAsync(account: StaffAccount, ct)
        activate Repo
        Repo ->> DB : Update password hash and set account to LOCKED status
        activate DB
        DB -->> Repo : Confirm update
        deactivate DB
        Repo -->> Svc : void
        deactivate Repo

        Svc ->> Svc : Queue password-reset notification email via IEmailQueue

        Svc -->> Ctrl : PasswordResetResult
        deactivate Svc

        Ctrl -->> Client : 200 OK - ApiResponse<PasswordResetResult>
        deactivate Ctrl

        Client -->> U : Display password reset success confirmation
    end
end

deactivate Client
deactivate U

@enduml
