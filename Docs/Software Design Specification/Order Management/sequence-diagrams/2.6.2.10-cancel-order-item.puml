@startuml
title 2.6.2.10 Cancel Order Item

skinparam maxMessageSize 250
skinparam sequence {
    ParticipantBackgroundColor #ffffff
    ActorBackgroundColor #ffffff
}

autonumber

actor ":Customer" as U
participant ":QRMenuPage" as Client
participant ":OrderController" as Ctrl
participant ":OrderService" as Svc
participant ":ILookupResolver" as Lookup
participant ":IOrderRepository" as OrderRepo
participant ":IOrderRealtimeService" as Realtime
participant ":INotificationService" as Notif
participant ":IShiftLiveRealtimePublisher" as ShiftLive
participant ":Database" as DB

activate U

U ->> Client : Tap cancel on an order item (before kitchen starts)
activate Client

Client ->> Ctrl : PATCH /api/orders/items/{orderItemId}/cancel
activate Ctrl

Ctrl ->> Svc : CancelOrderItemAsync(orderItemId, ct)
activate Svc

Svc ->> OrderRepo : GetOrderItemAsync(orderItemId, ct)
activate OrderRepo
OrderRepo ->> DB : Query order item with order and table info
activate DB
DB -->> OrderRepo : Return order item with dish name and table code
deactivate DB
OrderRepo -->> Svc : OrderItem (for notification context)
deactivate OrderRepo

Svc ->> Lookup : ToOrderItemStatusIdAsync(CANCELLED)
activate Lookup
Lookup -->> Svc : cancelledStatusLvId
deactivate Lookup

Svc ->> Svc : Delegate to UpdateOrderItemStatusAsync(orderItemId, cancelledStatusLvId, null, ct)

Svc ->> Lookup : Resolve all order item status IDs (IN_PROGRESS, READY, SERVED, REJECTED, CANCELLED)
activate Lookup
Lookup -->> Svc : all item status LvIds
deactivate Lookup

Svc ->> Lookup : Resolve all order status IDs (PENDING, IN_PROGRESS, COMPLETED, CANCELLED) and table status (AVAILABLE)
activate Lookup
Lookup -->> Svc : all order/table status LvIds
deactivate Lookup

Svc ->> OrderRepo : UpdateOrderItemStatusAsync(orderItemId, cancelledStatusLvId, null, ...allLvIds, ct)
activate OrderRepo

OrderRepo ->> DB : Query order item by ID
activate DB
DB -->> OrderRepo : Return order item entity
deactivate DB

alt#White Order item not found
    OrderRepo -->> Svc : throw KeyNotFoundException
    Svc -->> Ctrl : throw KeyNotFoundException
    Ctrl -->> Client : 404 Not Found
    Client -->> U : Display "Item not found" error
else Item found

    OrderRepo ->> DB : Update order item status to CANCELLED
    activate DB
    DB -->> OrderRepo : Item status updated
    deactivate DB

    OrderRepo ->> DB : Query parent order with table
    activate DB
    DB -->> OrderRepo : Return order with table
    deactivate DB

    OrderRepo ->> OrderRepo : Subtract cancelled item amount from order totals
    OrderRepo ->> OrderRepo : Recalculate parent order status from all item statuses

    opt#White All items cancelled — auto-cancel order and free table
        OrderRepo ->> DB : Update order status to CANCELLED and table status to AVAILABLE
        activate DB
        DB -->> OrderRepo : Order and table status updated
        deactivate DB

        OrderRepo ->> Realtime : OrderUpdatedAsync(OrderRealtimeDTO)
        activate Realtime
        Realtime -->> OrderRepo : done
        deactivate Realtime
    end

    OrderRepo ->> Realtime : OrderItemUpdatedAsync(OrderItemRealtimeDTO)
    activate Realtime
    Realtime -->> OrderRepo : done
    deactivate Realtime

    OrderRepo -->> Svc : done
    deactivate OrderRepo

    Svc ->> ShiftLive : PublishBoardChangedAsync(order_item_changed event)
    activate ShiftLive
    ShiftLive -->> Svc : done
    deactivate ShiftLive

    Svc ->> Notif : PublishAsync(ORDER_ITEM_CANCELLED notification with dish name and table code)
    activate Notif
    Notif -->> Svc : done
    deactivate Notif

    Svc -->> Ctrl : (void - success)
    deactivate Svc

    Ctrl -->> Client : 200 OK ("Order item cancelled successfully")
    deactivate Ctrl

    Client -->> U : Item removed from order display
end

deactivate Client
deactivate U

@enduml
