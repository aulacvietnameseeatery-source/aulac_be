@startuml
title 2.6.2.2 Place Staff Order

skinparam maxMessageSize 250
skinparam sequence {
    ParticipantBackgroundColor #ffffff
    ActorBackgroundColor #ffffff
}

autonumber

actor ":Staff" as U
participant ":OrderPage" as Client
participant ":OrderController" as Ctrl
participant ":OrderService" as Svc
participant ":ILookupResolver" as Lookup
participant ":ITableRepository" as TableRepo
participant ":IDishRepository" as DishRepo
participant ":ITaxRepository" as TaxRepo
participant ":ICustomerService" as CustSvc
participant ":IOrderRepository" as OrderRepo
participant ":IUnitOfWork" as UoW
participant ":IOrderRealtimeService" as Realtime
participant ":INotificationService" as Notif
participant ":IShiftLiveRealtimePublisher" as ShiftLive
participant ":Database" as DB

activate U

U ->> Client : Select table, customer info, dishes, and submit
activate Client

Client ->> Ctrl : POST /api/orders/staff (CreateOrderRequest)
activate Ctrl

Ctrl ->> Ctrl : Extract staffId from JWT claims

Ctrl ->> Svc : CreateOrderAsync(staffId, CreateOrderRequest, ct)
activate Svc

Svc ->> Svc : Validate request (at least one item, DINE_IN requires table, TAKEAWAY cannot have table)

alt#White Validation fails
    Svc -->> Ctrl : throw InvalidOperationException
    Ctrl -->> Client : 400 Bad Request
    Client -->> U : Display validation error
else Validation passed

    Svc ->> UoW : BeginTransactionAsync(ct)
    activate UoW
    UoW -->> Svc : Transaction started
    deactivate UoW

    Svc ->> Lookup : Resolve lookup IDs (OrderStatus PENDING, OrderItemStatus CREATED, OrderSource, TableStatus OCCUPIED/LOCKED)
    activate Lookup
    Lookup -->> Svc : orderStatusId, orderItemStatusId, sourceId, occupiedTableStatusId, lockedTableStatusId
    deactivate Lookup

    opt#White TableId provided (DINE_IN)
        Svc ->> TableRepo : GetByIdAsync(tableId, ct)
        activate TableRepo
        TableRepo ->> DB : Query table by ID
        activate DB
        DB -->> TableRepo : Return table entity
        deactivate DB
        TableRepo -->> Svc : RestaurantTable
        deactivate TableRepo

        alt#White Table not found
            Svc -->> Ctrl : throw NotFoundException
            Ctrl -->> Client : 404 Not Found
            Client -->> U : Display "Table not found" error
        else Table found
            alt#White Table is LOCKED or OCCUPIED
                Svc -->> Ctrl : throw InvalidOperationException
                Ctrl -->> Client : 400 Bad Request
                Client -->> U : Display "Table not available" error
            else Table is available
                Svc ->> Svc : Set table.TableStatusLvId = occupiedTableStatusId
                Svc ->> TableRepo : UpdateAsync(table, ct)
                activate TableRepo
                TableRepo -->> Svc : done
                deactivate TableRepo
            end
        end
    end

    Svc ->> CustSvc : ResolveCustomerAsync(OrderCustomerDto, ct)
    activate CustSvc
    CustSvc -->> Svc : customerId
    deactivate CustSvc

    Svc ->> DishRepo : GetByIdsAsync(dishIds, ct)
    activate DishRepo
    DishRepo ->> DB : Query dishes by IDs in single query
    activate DB
    DB -->> DishRepo : Return list of dishes
    deactivate DB
    DishRepo -->> Svc : List<Dish>
    deactivate DishRepo

    alt#White One or more dishes not found
        Svc -->> Ctrl : throw NotFoundException
        Ctrl -->> Client : 404 Not Found
        Client -->> U : Display "Dish not found" error
    else All dishes valid

        Svc ->> Svc : Build Order entity with items, staffId, source, customer, calculate totals

        Svc ->> Svc : ApplyTaxToOrderAsync(order, ct)
        activate Svc
        Svc ->> TaxRepo : GetDefaultTaxAsync(ct)
        activate TaxRepo
        TaxRepo -->> Svc : Tax
        deactivate TaxRepo
        Svc ->> Svc : Calculate tax amount
        deactivate Svc

        Svc ->> OrderRepo : AddAsync(order, ct)
        activate OrderRepo
        OrderRepo ->> DB : Insert order with order items
        activate DB
        DB -->> OrderRepo : Order persisted
        deactivate DB
        OrderRepo -->> Svc : done
        deactivate OrderRepo

        Svc ->> UoW : CommitAsync(ct)
        activate UoW
        UoW -->> Svc : Transaction committed
        deactivate UoW

        Svc ->> Realtime : OrderCreatedAsync(OrderRealtimeDTO)
        activate Realtime
        Realtime -->> Svc : done
        deactivate Realtime

        Svc ->> ShiftLive : PublishBoardChangedAsync(order_created event)
        activate ShiftLive
        ShiftLive -->> Svc : done
        deactivate ShiftLive

        Svc ->> Notif : PublishAsync(NEW_ORDER notification with item count, table code, total)
        activate Notif
        Notif -->> Svc : done
        deactivate Notif

        Svc -->> Ctrl : orderId (long)
        deactivate Svc

        Ctrl -->> Client : 200 OK (orderId)
        deactivate Ctrl

        Client -->> U : Display order created successfully
    end
end

deactivate Client
deactivate U

@enduml
