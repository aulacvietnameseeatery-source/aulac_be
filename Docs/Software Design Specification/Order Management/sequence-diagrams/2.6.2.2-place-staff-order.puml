@startuml
title 2.6.2.2 Place Staff Order

skinparam maxMessageSize 250
skinparam sequence {
    ParticipantBackgroundColor #ffffff
    ActorBackgroundColor #ffffff
}

autonumber

actor ":Staff" as U
participant ":OrderPage" as Client
participant ":OrderController" as Ctrl
participant ":OrderService" as Svc
participant ":ILookupResolver" as Lookup
participant ":ITableRepository" as TableRepo
participant ":IDishRepository" as DishRepo
participant ":ITaxRepository" as TaxRepo
participant ":ICustomerService" as CustSvc
participant ":IOrderRepository" as OrderRepo
participant ":IUnitOfWork" as UoW
participant ":IOrderRealtimeService" as Realtime
participant ":INotificationService" as Notif
participant ":Database" as DB

activate U

U ->> Client : Select table, customer info, dishes, and submit
activate Client

Client ->> Ctrl : POST /api/orders/staff (CreateOrderRequest)
activate Ctrl

note right of Ctrl : [HasPermission(Permissions.CreateOrder)]
Ctrl ->> Ctrl : Extract staffId from JWT claims

Ctrl ->> Svc : CreateOrderAsync(staffId, CreateOrderRequest, ct)
activate Svc

Svc ->> Lookup : GetIdAsync(OrderSource, request.Source)
activate Lookup
Lookup -->> Svc : sourceLvId
deactivate Lookup

Svc ->> Lookup : GetIdAsync(OrderStatus, PENDING)
activate Lookup
Lookup -->> Svc : pendingStatusLvId
deactivate Lookup

Svc ->> Lookup : GetIdAsync(OrderItemStatus, CREATED)
activate Lookup
Lookup -->> Svc : createdItemStatusLvId
deactivate Lookup

opt#White TableId provided (DINE_IN)
    Svc ->> TableRepo : GetByIdAsync(tableId, ct)
    activate TableRepo
    TableRepo ->> DB : SELECT table by id
    activate DB
    DB -->> TableRepo : RestaurantTable
    deactivate DB
    TableRepo -->> Svc : RestaurantTable
    deactivate TableRepo

    alt#White Table not found
        Svc -->> Ctrl : throw NotFoundException
        Ctrl -->> Client : 404 Not Found
        Client -->> U : Display error
    end
end

Svc ->> CustSvc : Resolve or create customer from OrderCustomerDto
activate CustSvc
CustSvc -->> Svc : Customer (with CustomerId)
deactivate CustSvc

loop For each item in request.Items
    Svc ->> DishRepo : GetByIdAsync(dishId, ct)
    activate DishRepo
    DishRepo -->> Svc : Dish (validate and get price)
    deactivate DishRepo
end

Svc ->> Svc : Build Order entity with items, staffId, source, customer

Svc ->> Svc : ApplyTaxToOrderAsync(order, ct)
activate Svc
Svc ->> TaxRepo : GetDefaultTaxAsync(ct)
activate TaxRepo
TaxRepo -->> Svc : Tax
deactivate TaxRepo
Svc ->> Svc : Calculate tax amount
deactivate Svc

Svc ->> UoW : BeginTransactionAsync(ct)
activate UoW

Svc ->> OrderRepo : AddAsync(order, ct)
activate OrderRepo
OrderRepo ->> DB : INSERT Order + OrderItems
activate DB
DB -->> OrderRepo : done
deactivate DB
OrderRepo -->> Svc : done
deactivate OrderRepo

Svc ->> UoW : SaveChangesAsync(ct)
Svc ->> UoW : CommitAsync(ct)
deactivate UoW

Svc ->> Realtime : OrderCreatedAsync(OrderRealtimeDTO)
activate Realtime
Realtime -->> Svc : done
deactivate Realtime

Svc ->> Notif : PublishAsync(new order notification)
activate Notif
Notif -->> Svc : done
deactivate Notif

Svc -->> Ctrl : orderId (long)
deactivate Svc

Ctrl -->> Client : 200 OK (orderId)
deactivate Ctrl

Client -->> U : Display order created successfully

deactivate Client
deactivate U

@enduml
