@startuml
title 2.6.2.7 Update Order Status

skinparam maxMessageSize 250
skinparam sequence {
    ParticipantBackgroundColor #ffffff
    ActorBackgroundColor #ffffff
}

autonumber

actor ":Staff" as U
participant ":OrderListPage" as Client
participant ":OrderController" as Ctrl
participant ":OrderService" as Svc
participant ":ILookupResolver" as Lookup
participant ":IOrderRepository" as OrderRepo
participant ":ITableRepository" as TableRepo
participant ":IUnitOfWork" as UoW
participant ":IOrderRealtimeService" as Realtime
participant ":INotificationService" as Notif
participant ":IShiftLiveRealtimePublisher" as ShiftLive
participant ":Database" as DB

activate U

U ->> Client : Select new status for an order (e.g., IN_PROGRESS, COMPLETED, CANCELLED)
activate Client

Client ->> Ctrl : PATCH /api/orders/{id}/status (UpdateOrderStatusDTO)
activate Ctrl

Ctrl ->> Ctrl : Parse dto.Status string to OrderStatusCode enum

alt#White Invalid status string
    Ctrl -->> Client : 400 Bad Request ("Invalid status")
    Client -->> U : Display invalid status error
else Valid status parsed

    Ctrl ->> Svc : UpdateOrderStatusAsync(orderId, OrderStatusCode, ct)
    activate Svc

    Svc ->> Lookup : Resolve all order status IDs (PENDING, IN_PROGRESS, COMPLETED, CANCELLED)
    activate Lookup
    Lookup -->> Svc : pendingId, inProgressId, completedId, cancelledId
    deactivate Lookup

    Svc ->> Lookup : Resolve table status IDs (AVAILABLE, OCCUPIED)
    activate Lookup
    Lookup -->> Svc : availableTableStatusId, occupiedTableStatusId
    deactivate Lookup

    Svc ->> OrderRepo : GetByIdForUpdateAsync(orderId, ct)
    activate OrderRepo
    OrderRepo ->> DB : Query order by ID with payments and table
    activate DB
    DB -->> OrderRepo : Return order entity
    deactivate DB
    OrderRepo -->> Svc : Order
    deactivate OrderRepo

    alt#White Order not found
        Svc -->> Ctrl : throw NotFoundException
        Ctrl -->> Client : 404 Not Found
        Client -->> U : Display "Order not found" error
    else Order found

        Svc ->> Svc : Determine current status from OrderStatusLvId
        Svc ->> Svc : Validate status transition is allowed (PENDING→IN_PROGRESS, PENDING→CANCELLED, IN_PROGRESS→COMPLETED, IN_PROGRESS→CANCELLED, CANCELLED→PENDING, COMPLETED→IN_PROGRESS)

        alt#White Invalid status transition or cannot cancel paid order
            Svc -->> Ctrl : throw InvalidOperationException
            Ctrl -->> Client : 400 Bad Request
            Client -->> U : Display transition error
        else Valid transition

            Svc ->> UoW : BeginTransactionAsync(ct)
            activate UoW
            UoW -->> Svc : Transaction started
            deactivate UoW

            Svc ->> Svc : Set order.OrderStatusLvId = target status ID

            opt#White Order has a table and status is CANCELLED or COMPLETED
                Svc ->> TableRepo : GetByIdAsync(tableId, ct)
                activate TableRepo
                TableRepo -->> Svc : RestaurantTable
                deactivate TableRepo
                Svc ->> Svc : Set table.TableStatusLvId = availableTableStatusId
            end

            opt#White Reactivating cancelled order (CANCELLED → PENDING) with table
                Svc ->> TableRepo : GetByIdAsync(tableId, ct)
                activate TableRepo
                TableRepo -->> Svc : RestaurantTable
                deactivate TableRepo
                Svc ->> Svc : Set table.TableStatusLvId = occupiedTableStatusId
            end

            Svc ->> UoW : SaveChangesAsync(ct)
            activate UoW
            UoW ->> DB : Persist order status and table status changes
            activate DB
            DB -->> UoW : Changes saved
            deactivate DB
            UoW -->> Svc : done
            deactivate UoW

            Svc ->> UoW : CommitAsync(ct)
            activate UoW
            UoW -->> Svc : Transaction committed
            deactivate UoW

            opt#White Status is CANCELLED
                Svc ->> Notif : PublishAsync(ORDER_CANCELLED notification)
                activate Notif
                Notif -->> Svc : done
                deactivate Notif
            end

            Svc ->> Realtime : OrderUpdatedAsync(OrderRealtimeDTO)
            activate Realtime
            Realtime -->> Svc : done
            deactivate Realtime

            Svc ->> ShiftLive : PublishBoardChangedAsync(order_status_changed event)
            activate ShiftLive
            ShiftLive -->> Svc : done
            deactivate ShiftLive

            Svc -->> Ctrl : (void - success)
            deactivate Svc

            Ctrl -->> Client : 200 OK ("Order status updated successfully")
            deactivate Ctrl

            Client -->> U : Display updated order status
        end
    end
end

deactivate Client
deactivate U

@enduml
