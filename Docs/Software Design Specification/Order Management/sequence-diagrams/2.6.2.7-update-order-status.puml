@startuml
title 2.6.2.7 Update Order Status

skinparam maxMessageSize 250
skinparam sequence {
    ParticipantBackgroundColor #ffffff
    ActorBackgroundColor #ffffff
}

autonumber

actor ":Staff" as U
participant ":OrderListPage" as Client
participant ":OrderController" as Ctrl
participant ":OrderService" as Svc
participant ":ILookupResolver" as Lookup
participant ":IOrderRepository" as OrderRepo
participant ":IOrderRealtimeService" as Realtime
participant ":INotificationService" as Notif
participant ":IOrderRealtimeService" as OrderRT
participant ":IShiftLiveRealtimePublisher" as ShiftRT
participant ":Database" as DB

activate U

U ->> Client : Select new status for an order (e.g., IN_PROGRESS, COMPLETED, CANCELLED)
activate Client

Client ->> Ctrl : PATCH /api/orders/{id}/status (UpdateOrderStatusDTO)
activate Ctrl

note right of Ctrl : [HasPermission(Permissions.EditOrder)]

Ctrl ->> Ctrl : Parse status string to OrderStatusCode enum

Ctrl ->> Svc : UpdateOrderStatusAsync(orderId, OrderStatusCode, ct)
activate Svc

Svc ->> Lookup : GetIdAsync(OrderStatus, newStatusCode)
activate Lookup
Lookup -->> Svc : newStatusLvId
deactivate Lookup

Svc ->> OrderRepo : GetByIdForUpdateAsync(orderId, ct)
activate OrderRepo
OrderRepo ->> DB : SELECT order by id
activate DB
DB -->> OrderRepo : Order
deactivate DB
OrderRepo -->> Svc : Order
deactivate OrderRepo

alt#White Order not found
    Svc -->> Ctrl : throw NotFoundException
    Ctrl -->> Client : 404 Not Found
    Client -->> U : Display "Order not found" error
else Order found
    Svc ->> Svc : Validate status transition is allowed

    alt#White Invalid status transition
        Svc -->> Ctrl : throw InvalidOperationException
        Ctrl -->> Client : 400 Bad Request
        Client -->> U : Display invalid transition error
        else Cancelling an already paid order
            Svc -->> Ctrl : throw InvalidOperationException
            deactivate Svc
            Ctrl -->> Client : 400 Bad Request ApiResponse<object>
            deactivate Ctrl
            Client -->> U : Display paid order cancellation error
    else Valid transition
        Svc ->> Svc : Update order.OrderStatusLvId = newStatusLvId

        Svc ->> OrderRepo : Save updated order (via context tracking)
        activate OrderRepo
        OrderRepo ->> DB : UPDATE Order SET OrderStatusLvId = newStatusLvId
        activate DB
        DB -->> OrderRepo : done
        deactivate DB
        OrderRepo -->> Svc : done
        deactivate OrderRepo

        Svc ->> Realtime : OrderUpdatedAsync(OrderRealtimeDTO)
        activate Realtime
        Realtime -->> Svc : done
        deactivate Realtime

        Svc ->> Notif : PublishAsync(order status changed notification)
        activate Notif
        Notif -->> Svc : done
        deactivate Notif
            end

            Svc ->> OrderRT : OrderUpdatedAsync(OrderRealtimeDTO)
            activate OrderRT
            OrderRT -->> Svc : OK
            deactivate OrderRT

            Svc ->> ShiftRT : PublishBoardChangedAsync(order_status_changed)
            activate ShiftRT
            ShiftRT -->> Svc : OK
            deactivate ShiftRT

        Svc -->> Ctrl : (void - success)
        deactivate Svc

        Ctrl -->> Client : 200 OK
        deactivate Ctrl

        Client -->> U : Display updated order status
    end
end
end

deactivate Client
deactivate U

@enduml
