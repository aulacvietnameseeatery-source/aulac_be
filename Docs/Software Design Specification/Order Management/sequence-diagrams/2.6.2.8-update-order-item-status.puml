@startuml
title 2.6.2.8 Update Order Item Status

skinparam maxMessageSize 250
skinparam sequence {
    ParticipantBackgroundColor #ffffff
    ActorBackgroundColor #ffffff
}

autonumber

actor ":Kitchen Staff" as U
participant ":KitchenDisplayPage" as Client
participant ":OrderController" as Ctrl
participant ":ILookupResolver" as Lookup
participant ":OrderService" as Svc
participant ":IOrderRepository" as OrderRepo
participant ":IOrderRealtimeService" as Realtime
participant ":INotificationService" as Notif
participant ":IShiftLiveRealtimePublisher" as ShiftLive
participant ":Database" as DB

activate U

U ->> Client : Change item status (e.g., IN_PROGRESS, READY, SERVED, or REJECTED with reason)
activate Client

Client ->> Ctrl : PATCH /api/orders/items/{id}/status (UpdateOrderItemStatusDTO)
activate Ctrl

Ctrl ->> Ctrl : Parse dto.Status string to OrderItemStatusCode enum

alt#White Invalid status string
    Ctrl -->> Client : 400 Bad Request ("Invalid status")
    Client -->> U : Display invalid status error
else Valid status parsed

    alt#White Status is REJECTED but RejectReason is empty
        Ctrl -->> Client : 400 Bad Request ("RejectReason is required when status is REJECTED")
        Client -->> U : Display reject reason required error
    else Validation passed

        Ctrl ->> Lookup : ToOrderItemStatusIdAsync(statusCode)
        activate Lookup
        Lookup -->> Ctrl : newStatusLvId
        deactivate Lookup

        Ctrl ->> Svc : UpdateOrderItemStatusAsync(orderItemId, newStatusLvId, rejectReason, ct)
        activate Svc

        Svc ->> Lookup : Resolve all order item status IDs (IN_PROGRESS, READY, SERVED, REJECTED, CANCELLED)
        activate Lookup
        Lookup -->> Svc : all item status LvIds
        deactivate Lookup

        Svc ->> Lookup : Resolve all order status IDs (PENDING, IN_PROGRESS, COMPLETED, CANCELLED)
        activate Lookup
        Lookup -->> Svc : all order status LvIds
        deactivate Lookup

        Svc ->> Lookup : GetIdAsync(TableStatus, AVAILABLE)
        activate Lookup
        Lookup -->> Svc : availableTableStatusId
        deactivate Lookup

        Svc ->> OrderRepo : UpdateOrderItemStatusAsync(orderItemId, newStatusLvId, rejectReason, ...allLvIds, ct)
        activate OrderRepo

        OrderRepo ->> DB : Query order item by ID
        activate DB
        DB -->> OrderRepo : Return order item entity
        deactivate DB

        alt#White Order item not found
            OrderRepo -->> Svc : throw KeyNotFoundException
            Svc -->> Ctrl : throw KeyNotFoundException
            Ctrl -->> Client : 404 Not Found
            Client -->> U : Display "Order item not found" error
        else Item found

            OrderRepo ->> DB : Update order item status and reject reason
            activate DB
            DB -->> OrderRepo : Item status updated
            deactivate DB

            OrderRepo ->> DB : Query parent order with table
            activate DB
            DB -->> OrderRepo : Return order with table
            deactivate DB

            OrderRepo ->> OrderRepo : Recalculate parent order status based on all item statuses

            opt#White Item rejected or cancelled — subtract from order total
                OrderRepo ->> OrderRepo : Adjust order.TotalAmount and order.SubTotalAmount
            end

            opt#White Any item IN_PROGRESS and order is PENDING — auto-transition order to IN_PROGRESS
                OrderRepo ->> OrderRepo : Set order.OrderStatusLvId = inProgressOrderStatusId
            end

            opt#White All items finished (SERVED/READY/REJECTED/CANCELLED)
                OrderRepo ->> OrderRepo : Auto-complete order (if any worked items) or auto-cancel (if all cancelled)

                opt#White Order auto-cancelled and has table
                    OrderRepo ->> DB : Update table status to AVAILABLE
                    activate DB
                    DB -->> OrderRepo : Table status updated
                    deactivate DB
                end
            end

            opt#White Order status changed
                OrderRepo ->> DB : Persist order status changes
                activate DB
                DB -->> OrderRepo : Order status updated
                deactivate DB

                OrderRepo ->> Realtime : OrderUpdatedAsync(OrderRealtimeDTO)
                activate Realtime
                Realtime -->> OrderRepo : done
                deactivate Realtime
            end

            OrderRepo ->> Realtime : OrderItemUpdatedAsync(OrderItemRealtimeDTO)
            activate Realtime
            Realtime -->> OrderRepo : done
            deactivate Realtime

            OrderRepo -->> Svc : done
            deactivate OrderRepo

            opt#White Item status is READY
                Svc ->> Notif : PublishAsync(ORDER_ITEM_READY notification)
                activate Notif
                Notif -->> Svc : done
                deactivate Notif
            end

            opt#White Item status is REJECTED
                Svc ->> Notif : PublishAsync(ORDER_ITEM_REJECTED notification)
                activate Notif
                Notif -->> Svc : done
                deactivate Notif
            end

            Svc ->> ShiftLive : PublishBoardChangedAsync(order_item_changed event)
            activate ShiftLive
            ShiftLive -->> Svc : done
            deactivate ShiftLive

            Svc -->> Ctrl : (void - success)
            deactivate Svc

            Ctrl -->> Client : 200 OK ("Order item status updated successfully")
            deactivate Ctrl

            Client -->> U : Display updated item status on kitchen board
        end
    end
end

deactivate Client
deactivate U

@enduml
