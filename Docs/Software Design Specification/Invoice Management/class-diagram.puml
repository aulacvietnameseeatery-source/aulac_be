@startuml "Invoice Management Module - Specification Class Diagram"

!theme plain
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam shadowing false

title Invoice Management Module — Specification Class Diagram

' ============================================================
'  PRESENTATION LAYER
' ============================================================
package "Presentation Layer" <<Rectangle>> {

    class InvoiceController <<Controller>> {
        - _saleInvoiceService : ISaleInvoiceService
        + GetSaleInvoiceList(query: SaleInvoiceListQueryDTO, ct: CancellationToken) : Task<IActionResult>
        + GetSaleInvoiceDetail(id: long, ct: CancellationToken) : Task<IActionResult>
    }

    ' ── Query DTOs ──

    class SaleInvoiceListQueryDTO <<DTO>> {
        + Search : string?
        + PageIndex : int
        + PageSize : int
        + FromDate : DateTime?
        + ToDate : DateTime?
        + OrderStatusCode : string?
    }

    ' ── Response DTOs ──

    class SaleInvoiceListDTO <<DTO>> {
        + OrderId : long
        + InvoiceCode : string
        + CreatedAt : DateTime?
        + TableCode : string
        + StaffName : string
        + CustomerName : string
        + TotalAmount : decimal
        + TipAmount : decimal?
        + OrderStatus : string
        + PaymentMethod : string
    }

    class SaleInvoiceDTO <<DTO>> {
        + OrderId : long
        + InvoiceCode : string
        + CreatedAt : DateTime?
        + RestaurantName : string
        + RestaurantAddress : string
        + RestaurantPhone : string
        + OrderType : string
        + TableCode : string
        + StaffName : string
        + CustomerName : string
        + CustomerPhone : string
        + SubTotal : decimal
        + DiscountAmount : decimal
        + TipAmount : decimal
        + TotalAmount : decimal
        + IsPaid : bool
        + PaymentMethod : string
        + Items : List<SaleInvoiceItemDTO>
    }

    class SaleInvoiceItemDTO <<DTO>> {
        + OrderItemId : long
        + Quantity : int
        + ItemName : string
        + ItemPrice : decimal
        + Amount : decimal
        + Note : string?
    }

    class "PagedResultDTO<T>" as PagedResultDTO <<DTO>> {
        + PageData : List<T>
        + PageIndex : int
        + PageSize : int
        + TotalCount : int
        + TotalPage : int
    }
}

' ============================================================
'  APPLICATION LAYER
' ============================================================
package "Application Layer" <<Rectangle>> {

    interface ISaleInvoiceService <<interface>> {
        + GetSaleInvoiceDetailAsync(orderId: long, ct: CancellationToken) : Task<SaleInvoiceDTO>
        + GetSaleInvoiceListAsync(query: SaleInvoiceListQueryDTO, ct: CancellationToken) : Task<PagedResultDTO<SaleInvoiceListDTO>>
    }

    class SaleInvoiceService <<Service>> {
        - _saleInvoiceRepository : ISaleInvoiceRepository
        + GetSaleInvoiceDetailAsync(orderId: long, ct: CancellationToken) : Task<SaleInvoiceDTO>
        + GetSaleInvoiceListAsync(query: SaleInvoiceListQueryDTO, ct: CancellationToken) : Task<PagedResultDTO<SaleInvoiceListDTO>>
    }
}

' ============================================================
'  PERSISTENCE LAYER
' ============================================================
package "Persistence Layer" <<Rectangle>> {

    interface ISaleInvoiceRepository <<interface>> {
        + GetOrderForInvoiceAsync(orderId: long, ct: CancellationToken) : Task<Order?>
        + GetTotalDiscountAsync(orderId: long, ct: CancellationToken) : Task<decimal>
        + GetOrdersForInvoiceListAsync(query: SaleInvoiceListQueryDTO, ct: CancellationToken) : Task<PagedResultDTO<SaleInvoiceListDTO>>
    }

    class SaleInvoiceRepository <<Repository>> {
        - _context : RestaurantMgmtContext
        + GetOrderForInvoiceAsync(orderId: long, ct: CancellationToken) : Task<Order?>
        + GetTotalDiscountAsync(orderId: long, ct: CancellationToken) : Task<decimal>
        + GetOrdersForInvoiceListAsync(query: SaleInvoiceListQueryDTO, ct: CancellationToken) : Task<PagedResultDTO<SaleInvoiceListDTO>>
    }

    class RestaurantMgmtContext <<DbContext>> {
        + Orders : DbSet<Order>
        + OrderItems : DbSet<OrderItem>
        + OrderCoupons : DbSet<OrderCoupon>
        + OrderPromotions : DbSet<OrderPromotion>
        + Payments : DbSet<Payment>
        + RestaurantTables : DbSet<RestaurantTable>
        + Customers : DbSet<Customer>
        + Dishes : DbSet<Dish>
        + LookupValues : DbSet<LookupValue>
    }
}

' ============================================================
'  DOMAIN LAYER
' ============================================================
package "Domain Layer" <<Rectangle>> {

    enum OrderStatusCode <<Enum>> {
        PENDING
        IN_PROGRESS
        COMPLETED
        CANCELLED
    }

    class Order <<Entity>> {
        + OrderId : long
        + TableId : long?
        + StaffId : long?
        + CustomerId : long
        + SubTotalAmount : decimal
        + TotalAmount : decimal
        + TipAmount : decimal?
        + TaxId : long?
        + TaxAmount : decimal
        + SourceLvId : uint
        + OrderStatusLvId : uint
        + CreatedAt : DateTime?
        + UpdatedAt : DateTime?
    }

    class OrderItem <<Entity>> {
        + OrderItemId : long
        + OrderId : long
        + DishId : long
        + Quantity : int
        + Price : decimal
        + ItemStatusLvId : uint
        + RejectReason : string?
        + Note : string?
    }

    class OrderCoupon <<Entity>> {
        + OrderCouponId : long
        + OrderId : long
        + CouponId : long
        + DiscountAmount : decimal
        + AppliedAt : DateTime?
    }

    class OrderPromotion <<Entity>> {
        + OrderPromotionId : long
        + OrderId : long
        + PromotionId : long
        + DiscountAmount : decimal
        + AppliedAt : DateTime?
    }

    class Payment <<Entity>> {
        + PaymentId : long
        + OrderId : long
        + ReceivedAmount : decimal
        + ChangeAmount : decimal
        + PaidAt : DateTime?
        + MethodLvId : uint
    }

    class Customer <<Entity>> {
        + CustomerId : long
        + FullName : string
        + Phone : string
        + Email : string?
    }

    class RestaurantTable <<Entity>> {
        + TableId : long
        + TableCode : string
    }

    class StaffAccount <<Entity>> {
        + StaffId : long
        + FullName : string
    }

    class Dish <<Entity>> {
        + DishId : long
        + DishName : string
        + Price : decimal
    }

    class LookupValue <<Entity>> {
        + ValueId : uint
        + TypeId : ushort
        + ValueCode : string
        + ValueName : string
        + SortOrder : short
        + IsActive : bool?
    }
}

' ============================================================
'  RELATIONSHIPS
' ============================================================

' --- Presentation → Application ---
InvoiceController --> ISaleInvoiceService : uses

' --- Presentation → DTOs ---
InvoiceController ..> SaleInvoiceListQueryDTO : receives
InvoiceController ..> SaleInvoiceListDTO : returns
InvoiceController ..> SaleInvoiceDTO : returns
InvoiceController ..> PagedResultDTO : paginates results

SaleInvoiceDTO *-- "0..*" SaleInvoiceItemDTO : contains items

' --- Application: realization ---
SaleInvoiceService ..|> ISaleInvoiceService

' --- Application → Persistence ---
SaleInvoiceService --> ISaleInvoiceRepository : uses

' --- Application → DTOs ---
SaleInvoiceService ..> SaleInvoiceDTO : creates
SaleInvoiceService ..> SaleInvoiceListDTO : returns

' --- Persistence: realization ---
SaleInvoiceRepository ..|> ISaleInvoiceRepository

' --- Persistence → DbContext ---
SaleInvoiceRepository --> RestaurantMgmtContext : uses

' --- Persistence → Domain ---
ISaleInvoiceRepository ..> Order : queries with eager loading (Table, Staff, Customer, Payments, OrderItems+Dish)
ISaleInvoiceRepository ..> OrderCoupon : queries discount amounts
ISaleInvoiceRepository ..> OrderPromotion : queries discount amounts
ISaleInvoiceRepository ..> SaleInvoiceListDTO : projects to list DTO

' --- Domain: entity relationships ---
Order *-- "1..*" OrderItem : contains items
Order *-- "0..*" OrderCoupon : applied coupons
Order *-- "0..*" OrderPromotion : applied promotions
Order *-- "0..*" Payment : payments received
Order --> "1" Customer : placed by
Order --> "0..1" RestaurantTable : served at
Order --> "0..1" StaffAccount : handled by
Order --> "1" LookupValue : order status
Order --> "1" LookupValue : source type

OrderItem --> "1" Dish : references dish
OrderItem --> "1" LookupValue : item status

Payment --> "1" LookupValue : payment method

@enduml
