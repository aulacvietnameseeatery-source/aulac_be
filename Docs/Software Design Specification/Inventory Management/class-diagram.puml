@startuml
skinparam classAttributeIconSize 0

' === ENUMS ===

enum InventoryTxTypeCode {
    IN
    OUT
    ADJUST
}

enum InventoryTxStatusCode {
    DRAFT
    PENDING_APPROVAL
    COMPLETED
    CANCELLED
}

enum InventoryCategoryCode {
    FOOD_INGREDIENT
    KITCHEN_TOOL
    CONSUMABLE_SUPPLY
    EQUIPMENT
}

enum ExportReasonCode {
    COOKING
    SPOILED
    EXPIRED
    BROKEN
    LOST
    DISPOSED
    WORN_OUT
}

enum VarianceReasonCode {
    BREAKAGE
    NATURAL_LOSS
    COUNTING_ERROR
}

enum IngredientUnitCode {
    KG
    GRAM
    LITER
    ML
    PCS
}

' === ENTITIES ===

class InventoryTransaction {
    +TransactionId: long
    +TransactionCode: string
    +CreatedBy: long
    +CreatedAt: DateTime
    +SubmittedAt: DateTime
    +ApprovedBy: long
    +ApprovedAt: DateTime
    +Note: string
    +TypeLvId: uint
    +StatusLvId: uint
    +SupplierId: long
    +ExportReasonLvId: uint
    +StockCheckAreaNote: string
}

class InventoryTransactionItem {
    +TransactionItemId: long
    +TransactionId: long
    +IngredientId: long
    +Quantity: decimal
    +UnitLvId: uint
    +UnitPrice: decimal
    +SystemQuantity: decimal
    +ActualQuantity: decimal
    +VarianceReasonLvId: uint
    +Note: string
}

class InventoryTransactionMedium {
    +TransactionId: long
    +MediaId: long
    +IsPrimary: bool
}

class Ingredient {
    +IngredientId: long
    +IngredientName: string
    +UnitLvId: uint
    +TypeLvId: uint
    +CategoryLvId: uint
    +ImageId: long
}

class CurrentStock {
    +IngredientId: long
    +QuantityOnHand: decimal
    +MinStockLevel: decimal
    +LastUpdatedAt: DateTime
}

class Supplier {
    +SupplierId: long
    +SupplierName: string
    +Phone: string
    +Email: string
    +Address: string
    +TaxCode: string
}

class LookupValue <<cross-module>> {
    +LookupValueId: uint
    +ValueCode: string
    +ValueName: string
}

class StaffAccount <<cross-module>> {
    +AccountId: long
    +FullName: string
}

class MediaAsset <<cross-module>> {
    +MediaId: long
    +Url: string
    +MimeType: string
}

' === Entity Relationships ===

InventoryTransaction "1" *-- "0..*" InventoryTransactionItem : Items
InventoryTransaction "1" *-- "0..*" InventoryTransactionMedium : Media
InventoryTransaction --> LookupValue : TypeLv
InventoryTransaction --> LookupValue : StatusLv
InventoryTransaction --> LookupValue : ExportReasonLv
InventoryTransaction --> Supplier : Supplier
InventoryTransaction --> StaffAccount : CreatedByNavigation
InventoryTransaction --> StaffAccount : ApprovedByNavigation
InventoryTransactionItem --> Ingredient : Ingredient
InventoryTransactionItem --> LookupValue : UnitLv
InventoryTransactionItem --> LookupValue : VarianceReasonLv
InventoryTransactionMedium --> MediaAsset : Media
Ingredient "1" o-- "0..1" CurrentStock : CurrentStock
Ingredient --> LookupValue : UnitLv
Ingredient --> LookupValue : TypeLv
Ingredient --> LookupValue : CategoryLv
Ingredient --> MediaAsset : Image
Supplier "1" o-- "0..*" InventoryTransaction : Transactions

' === Request DTOs ===

class GetInventoryItemsFilterRequest {
    +PageIndex: int
    +PageSize: int
    +Search: string
    +CategoryLvId: uint
    +TypeLvId: uint
    +IsLowStock: bool
}

class GetTransactionsFilterRequest {
    +PageIndex: int
    +PageSize: int
    +Search: string
    +TypeLvId: uint
    +StatusLvId: uint
    +ExportReasonLvId: uint
    +SupplierId: long
    +FromDate: DateTime
    +ToDate: DateTime
}

class CreateInventoryTransactionRequest {
    +TypeLvId: uint
    +ExportReasonLvId: uint
    +SupplierId: long
    +StockCheckAreaNote: string
    +Note: string
    +Items: List<TransactionItemRequest>
}

class TransactionItemRequest {
    +IngredientId: long
    +Quantity: decimal
    +UnitLvId: uint
    +UnitPrice: decimal
    +Note: string
}

class SubmitTransactionRequest {
    +MediaIds: List<long>
}

class ApproveTransactionRequest {
    +IsApproved: bool
    +Note: string
}

class CreateInventoryTransactionFormRequest {
    +RequestJson: string
    +EvidenceFiles: List<IFormFile>
}

CreateInventoryTransactionRequest *-- TransactionItemRequest : Items

' === Response DTOs ===

class InventoryItemDto {
    +IngredientId: long
    +IngredientName: string
    +UnitLvId: uint
    +UnitName: string
    +TypeLvId: uint
    +TypeName: string
    +CategoryLvId: uint
    +CategoryCode: string
    +CategoryName: string
    +ImageId: long
    +ImageUrl: string
    +QuantityOnHand: decimal
    +MinStockLevel: decimal
    +LastUpdatedAt: DateTime
    +IsLowStock: bool
}

class InventoryTransactionListDto {
    +TransactionId: long
    +TransactionCode: string
    +TypeLvId: uint
    +TypeCode: string
    +TypeName: string
    +StatusLvId: uint
    +StatusCode: string
    +StatusName: string
    +ExportReasonLvId: uint
    +ExportReasonName: string
    +SupplierId: long
    +SupplierName: string
    +CreatedBy: long
    +CreatedByName: string
    +CreatedAt: DateTime
    +SubmittedAt: DateTime
    +ApprovedBy: long
    +ApprovedByName: string
    +ApprovedAt: DateTime
    +Note: string
    +ItemCount: int
    +TotalValue: decimal
}

class InventoryTransactionDetailDto {
    +TransactionId: long
    +TransactionCode: string
    +TypeLvId: uint
    +TypeCode: string
    +TypeName: string
    +StatusLvId: uint
    +StatusCode: string
    +StatusName: string
    +ExportReasonLvId: uint
    +ExportReasonCode: string
    +ExportReasonName: string
    +SupplierId: long
    +SupplierName: string
    +CreatedBy: long
    +CreatedByName: string
    +CreatedAt: DateTime
    +SubmittedAt: DateTime
    +ApprovedBy: long
    +ApprovedByName: string
    +ApprovedAt: DateTime
    +Note: string
    +StockCheckAreaNote: string
    +Items: List<TransactionItemDto>
    +Media: List<TransactionMediaDto>
}

class TransactionItemDto {
    +TransactionItemId: long
    +IngredientId: long
    +IngredientName: string
    +IngredientImageUrl: string
    +CategoryLvId: uint
    +CategoryCode: string
    +CategoryName: string
    +Quantity: decimal
    +UnitLvId: uint
    +UnitName: string
    +UnitPrice: decimal
    +SystemQuantity: decimal
    +ActualQuantity: decimal
    +VarianceReasonLvId: uint
    +VarianceReasonName: string
    +Note: string
}

class TransactionMediaDto {
    +MediaId: long
    +Url: string
    +MediaType: string
}

class StockCardDto {
    +TransactionItemId: long
    +TransactionId: long
    +TransactionCode: string
    +TypeCode: string
    +TypeName: string
    +StatusCode: string
    +QuantityChanged: decimal
    +UnitName: string
    +UnitPrice: decimal
    +ExportReasonName: string
    +Note: string
    +CreatedByName: string
    +CreatedAt: DateTime
}

class InventoryDashboardDto {
    +TotalItems: int
    +LowStockItems: int
    +OutOfStockItems: int
    +PendingTransactions: int
    +LowStockList: List<LowStockItemDto>
    +RecentTransactions: List<RecentTransactionDto>
}

class LowStockItemDto {
    +IngredientId: long
    +IngredientName: string
    +CategoryName: string
    +QuantityOnHand: decimal
    +MinStockLevel: decimal
    +UnitName: string
}

class RecentTransactionDto {
    +TransactionId: long
    +TransactionCode: string
    +TypeName: string
    +StatusName: string
    +CreatedByName: string
    +CreatedAt: DateTime
    +ItemCount: int
}

InventoryTransactionDetailDto *-- TransactionItemDto : Items
InventoryTransactionDetailDto *-- TransactionMediaDto : Media
InventoryDashboardDto *-- LowStockItemDto : LowStockList
InventoryDashboardDto *-- RecentTransactionDto : RecentTransactions

' === INTERFACES ===

interface IInventoryService {
    +GetItemsAsync(filter, ct): PagedResultDTO<InventoryItemDto>
    +CreateTransactionAsync(request, userId, files, ct): InventoryTransactionDetailDto
    +GetTransactionDetailAsync(transactionId, ct): InventoryTransactionDetailDto
    +GetTransactionsAsync(filter, ct): PagedResultDTO<InventoryTransactionListDto>
    +SubmitTransactionAsync(transactionId, request, userId, ct): InventoryTransactionDetailDto
    +ApproveTransactionAsync(transactionId, request, userId, ct): InventoryTransactionDetailDto
    +GetStockCardAsync(ingredientId, pageIndex, pageSize, ct): PagedResultDTO<StockCardDto>
    +GetDashboardAsync(ct): InventoryDashboardDto
}

interface IInventoryRepository {
    +GetItemsPagedAsync(filter, ct): PagedResultDTO<InventoryItemDto>
    +CreateTransactionAsync(transaction, items, ct): long
    +GetTransactionByIdAsync(transactionId, ct): InventoryTransaction
    +GetTransactionsPagedAsync(filter, ct): PagedResultDTO<InventoryTransactionListDto>
    +UpdateTransactionAsync(transaction, ct): void
    +GetCurrentStockAsync(ingredientId, ct): CurrentStock
    +UpdateStockAsync(ingredientId, quantityChange, ct): void
    +GetStockCardAsync(ingredientId, pageIndex, pageSize, ct): PagedResultDTO<StockCardDto>
    +GetDashboardAsync(ct): InventoryDashboardDto
    +GetTodayTransactionCountByTypeAsync(typeCode, ct): int
}

' === SERVICE & REPOSITORY IMPLEMENTATIONS ===

class InventoryService {
    -_repo: IInventoryRepository
    -_unitOfWork: IUnitOfWork
    -_lookupResolver: ILookupResolver
    -_notificationService: INotificationService
    -_fileStorage: IFileStorage
    -_mediaRepository: IMediaRepository
    +GetItemsAsync(filter, ct)
    +CreateTransactionAsync(request, userId, files, ct)
    +GetTransactionDetailAsync(transactionId, ct)
    +GetTransactionsAsync(filter, ct)
    +SubmitTransactionAsync(transactionId, request, userId, ct)
    +ApproveTransactionAsync(transactionId, request, userId, ct)
    +GetStockCardAsync(ingredientId, pageIndex, pageSize, ct)
    +GetDashboardAsync(ct)
    -ResolveTypeCodeAsync(typeLvId, ct)
    -GenerateTransactionCodeAsync(typeCode, ct)
    -ValidateExportReasonScopingAsync(entity, ct)
    -ApplyStockChangesAsync(entity, ct)
    -CheckLowStockAlertsAsync(entity, ct)
    -NotifyTransactionStatusAsync(entity, action, ct)
    -SaveEvidenceFilesAsync(transactionId, transaction, files, ct)
    -{static}MapToDetailDto(entity)
}

class InventoryRepository {
    -_context: RestaurantMgmtContext
    +GetItemsPagedAsync(filter, ct)
    +CreateTransactionAsync(transaction, items, ct)
    +GetTransactionByIdAsync(transactionId, ct)
    +GetTransactionsPagedAsync(filter, ct)
    +UpdateTransactionAsync(transaction, ct)
    +GetCurrentStockAsync(ingredientId, ct)
    +UpdateStockAsync(ingredientId, quantityChange, ct)
    +GetStockCardAsync(ingredientId, pageIndex, pageSize, ct)
    +GetDashboardAsync(ct)
    +GetTodayTransactionCountByTypeAsync(typeCode, ct)
}

' === CONTROLLER ===

class InventoryController {
    -_inventoryService: IInventoryService
    -_logger: ILogger
    +GetItems(filter, ct): IActionResult
    +GetTransactions(filter, ct): IActionResult
    +GetTransactionDetail(id, ct): IActionResult
    +CreateTransaction(formRequest, ct): IActionResult
    +SubmitTransaction(id, request, ct): IActionResult
    +ApproveTransaction(id, request, ct): IActionResult
    +GetStockCard(ingredientId, pageIndex, pageSize, ct): IActionResult
    +GetDashboard(ct): IActionResult
    -{static}MapFiles(files): List<MediaFileInput>
    -GetCurrentUserId(): long
}

' === Realization & Dependencies ===

InventoryService ..|> IInventoryService : implements
InventoryRepository ..|> IInventoryRepository : implements
InventoryController --> IInventoryService : uses for inventory operations
InventoryService --> IInventoryRepository : uses for persistence
InventoryService --> IUnitOfWork : uses for transactions
InventoryService --> INotificationService : uses for notifications
InventoryService --> IFileStorage : uses for file uploads
InventoryService --> IMediaRepository : uses for media persistence
InventoryService --> ILookupResolver : uses for lookup resolution

' === Cross-module Interfaces ===

interface IUnitOfWork <<cross-module>> {
}

interface INotificationService <<cross-module>> {
}

interface IFileStorage <<cross-module>> {
}

interface IMediaRepository <<cross-module>> {
}

interface ILookupResolver <<cross-module>> {
}

@enduml
