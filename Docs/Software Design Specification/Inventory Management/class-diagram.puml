@startuml
skinparam nodesep 2
skinparam ranksep 10
skinparam padding 2
skinparam ClassPadding 2
skinparam packagePadding 4
skinparam BoxPadding 2
skinparam classFontSize 10
skinparam classAttributeFontSize 10
skinparam classMethodFontSize 10
title Inventory Management Module - Specification Class Diagram


' ══════════════════════════════════════════════════════════════
'  PRESENTATION LAYER
' ══════════════════════════════════════════════════════════════

package "Presentation Layer" {

    class InventoryController <<Controller>> {
        -_inventoryService: IInventoryService
        -_logger: ILogger<InventoryController>
        -GetCurrentUserId(): long
        +GetItems(filter: GetInventoryItemsFilterRequest): IActionResult
        +GetTransactions(filter: GetTransactionsFilterRequest): IActionResult
        +GetTransactionDetail(id: long): IActionResult
        +CreateTransaction(formRequest: CreateInventoryTransactionFormRequest): IActionResult
        +SubmitTransaction(id: long, request: SubmitTransactionRequest?): IActionResult
        +ApproveTransaction(id: long, request: ApproveTransactionRequest): IActionResult
        +GetStockCard(ingredientId: long, pageIndex: int, pageSize: int): IActionResult
        +GetDashboard(): IActionResult
    }

    ' ── Item DTOs ──

    class GetInventoryItemsFilterRequest <<DTO>> {
        +PageIndex: int
        +PageSize: int
        +Search: string?
        +CategoryLvId: uint?
        +TypeLvId: uint?
        +IsLowStock: bool?
    }

    class InventoryItemDto <<DTO>> {
        +IngredientId: long
        +IngredientName: string
        +UnitLvId: uint
        +UnitName: string?
        +TypeLvId: uint?
        +TypeName: string?
        +CategoryLvId: uint?
        +CategoryCode: string?
        +CategoryName: string?
        +ImageId: long?
        +ImageUrl: string?
        +QuantityOnHand: decimal
        +MinStockLevel: decimal
        +LastUpdatedAt: DateTime?
        +IsLowStock: bool
    }

    ' ── Transaction Request DTOs ──

    class CreateInventoryTransactionFormRequest <<DTO>> {
        +RequestJson: string
        +EvidenceFiles: List<IFormFile>?
    }

    class CreateInventoryTransactionRequest <<DTO>> {
        +TypeLvId: uint
        +ExportReasonLvId: uint?
        +SupplierId: long?
        +StockCheckAreaNote: string?
        +Note: string?
        +Items: List<TransactionItemRequest>
    }

    class TransactionItemRequest <<DTO>> {
        +IngredientId: long
        +Quantity: decimal
        +UnitLvId: uint
        +UnitPrice: decimal?
        +Note: string?
    }

    class SubmitTransactionRequest <<DTO>> {
        +MediaIds: List<long>?
    }

    class ApproveTransactionRequest <<DTO>> {
        +IsApproved: bool
        +Note: string?
    }

    class GetTransactionsFilterRequest <<DTO>> {
        +PageIndex: int
        +PageSize: int
        +Search: string?
        +TypeLvId: uint?
        +StatusLvId: uint?
        +ExportReasonLvId: uint?
        +SupplierId: long?
        +FromDate: DateTime?
        +ToDate: DateTime?
    }

    ' ── Transaction Response DTOs ──

    class InventoryTransactionListDto <<DTO>> {
        +TransactionId: long
        +TransactionCode: string?
        +TypeLvId: uint
        +TypeCode: string?
        +TypeName: string?
        +StatusLvId: uint
        +StatusCode: string?
        +StatusName: string?
        +ExportReasonLvId: uint?
        +ExportReasonName: string?
        +SupplierId: long?
        +SupplierName: string?
        +CreatedBy: long?
        +CreatedByName: string?
        +CreatedAt: DateTime?
        +SubmittedAt: DateTime?
        +ApprovedBy: long?
        +ApprovedByName: string?
        +ApprovedAt: DateTime?
        +Note: string?
        +ItemCount: int
        +TotalValue: decimal?
    }

    class InventoryTransactionDetailDto <<DTO>> {
        +TransactionId: long
        +TransactionCode: string?
        +TypeLvId: uint
        +TypeCode: string?
        +TypeName: string?
        +StatusLvId: uint
        +StatusCode: string?
        +StatusName: string?
        +ExportReasonLvId: uint?
        +ExportReasonCode: string?
        +ExportReasonName: string?
        +SupplierId: long?
        +SupplierName: string?
        +CreatedBy: long?
        +CreatedByName: string?
        +CreatedAt: DateTime?
        +SubmittedAt: DateTime?
        +ApprovedBy: long?
        +ApprovedByName: string?
        +ApprovedAt: DateTime?
        +Note: string?
        +StockCheckAreaNote: string?
        +Items: List<TransactionItemDto>
        +Media: List<TransactionMediaDto>
    }

    class TransactionItemDto <<DTO>> {
        +TransactionItemId: long
        +IngredientId: long
        +IngredientName: string?
        +IngredientImageUrl: string?
        +CategoryLvId: uint?
        +CategoryCode: string?
        +CategoryName: string?
        +Quantity: decimal
        +UnitLvId: uint
        +UnitName: string?
        +UnitPrice: decimal?
        +SystemQuantity: decimal?
        +ActualQuantity: decimal?
        +VarianceReasonLvId: uint?
        +VarianceReasonName: string?
        +Note: string?
    }

    class TransactionMediaDto <<DTO>> {
        +MediaId: long
        +Url: string?
        +MediaType: string?
    }

    ' ── Stock Card DTO ──

    class StockCardDto <<DTO>> {
        +TransactionItemId: long
        +TransactionId: long
        +TransactionCode: string?
        +TypeCode: string?
        +TypeName: string?
        +StatusCode: string?
        +QuantityChanged: decimal
        +UnitName: string?
        +UnitPrice: decimal?
        +ExportReasonName: string?
        +Note: string?
        +CreatedByName: string?
        +CreatedAt: DateTime?
    }

    ' ── Dashboard DTOs ──

    class InventoryDashboardDto <<DTO>> {
        +TotalItems: int
        +LowStockItems: int
        +OutOfStockItems: int
        +PendingTransactions: int
        +LowStockList: List<LowStockItemDto>
        +RecentTransactions: List<RecentTransactionDto>
    }

    class LowStockItemDto <<DTO>> {
        +IngredientId: long
        +IngredientName: string?
        +CategoryName: string?
        +QuantityOnHand: decimal
        +MinStockLevel: decimal
        +UnitName: string?
    }

    class RecentTransactionDto <<DTO>> {
        +TransactionId: long
        +TransactionCode: string?
        +TypeName: string?
        +StatusName: string?
        +CreatedByName: string?
        +CreatedAt: DateTime?
        +ItemCount: int
    }
}

' ══════════════════════════════════════════════════════════════
'  APPLICATION LAYER
' ══════════════════════════════════════════════════════════════

package "Application Layer" {

    interface IInventoryService <<interface>> {
        +GetItemsAsync(filter: GetInventoryItemsFilterRequest): Task<PagedResultDTO<InventoryItemDto>>
        +CreateTransactionAsync(request: CreateInventoryTransactionRequest, userId: long, files: IReadOnlyList<MediaFileInput>?): Task<InventoryTransactionDetailDto>
        +GetTransactionDetailAsync(id: long): Task<InventoryTransactionDetailDto>
        +GetTransactionsAsync(filter: GetTransactionsFilterRequest): Task<PagedResultDTO<InventoryTransactionListDto>>
        +SubmitTransactionAsync(id: long, request: SubmitTransactionRequest?, userId: long): Task<InventoryTransactionDetailDto>
        +ApproveTransactionAsync(id: long, request: ApproveTransactionRequest, userId: long): Task<InventoryTransactionDetailDto>
        +GetStockCardAsync(ingredientId: long, pageIndex: int, pageSize: int): Task<PagedResultDTO<StockCardDto>>
        +GetDashboardAsync(): Task<InventoryDashboardDto>
    }

    class InventoryService <<Service>> {
        -_repo: IInventoryRepository
        -_unitOfWork: IUnitOfWork
        -_lookupResolver: ILookupResolver
        -_notificationService: INotificationService
        -_fileStorage: IFileStorage
        -_mediaRepository: IMediaRepository
        +GetItemsAsync(filter: GetInventoryItemsFilterRequest): Task<PagedResultDTO<InventoryItemDto>>
        +CreateTransactionAsync(request: CreateInventoryTransactionRequest, userId: long, files: IReadOnlyList<MediaFileInput>?): Task<InventoryTransactionDetailDto>
        +GetTransactionDetailAsync(id: long): Task<InventoryTransactionDetailDto>
        +GetTransactionsAsync(filter: GetTransactionsFilterRequest): Task<PagedResultDTO<InventoryTransactionListDto>>
        +SubmitTransactionAsync(id: long, request: SubmitTransactionRequest?, userId: long): Task<InventoryTransactionDetailDto>
        +ApproveTransactionAsync(id: long, request: ApproveTransactionRequest, userId: long): Task<InventoryTransactionDetailDto>
        +GetStockCardAsync(ingredientId: long, pageIndex: int, pageSize: int): Task<PagedResultDTO<StockCardDto>>
        +GetDashboardAsync(): Task<InventoryDashboardDto>
        -SaveEvidenceFilesAsync(txId: long, tx: InventoryTransaction, files: IReadOnlyList<MediaFileInput>): Task
        -GenerateTransactionCodeAsync(typeCode: string): Task<string>
        -ValidateExportReasonScopingAsync(entity: InventoryTransaction): Task
    }

    InventoryService ..|> IInventoryService : implements
}

' ══════════════════════════════════════════════════════════════
'  PERSISTENCE LAYER
' ══════════════════════════════════════════════════════════════

package "Persistence Layer" {

    interface IInventoryRepository <<interface>> {
        +GetItemsPagedAsync(filter: GetInventoryItemsFilterRequest): Task<PagedResultDTO<InventoryItemDto>>
        +CreateTransactionAsync(tx: InventoryTransaction, items: List<InventoryTransactionItem>): Task<long>
        +GetTransactionByIdAsync(id: long): Task<InventoryTransaction?>
        +GetTransactionsPagedAsync(filter: GetTransactionsFilterRequest): Task<PagedResultDTO<InventoryTransactionListDto>>
        +UpdateTransactionAsync(tx: InventoryTransaction): Task
        +GetCurrentStockAsync(ingredientId: long): Task<CurrentStock?>
        +UpdateStockAsync(ingredientId: long, quantityChange: decimal): Task
        +GetStockCardAsync(ingredientId: long, pageIndex: int, pageSize: int): Task<PagedResultDTO<StockCardDto>>
        +GetDashboardAsync(): Task<InventoryDashboardDto>
        +GetTodayTransactionCountByTypeAsync(typeCode: string): Task<int>
    }

    class InventoryRepository <<Repository>> {
        -_context: AuLacDbContext
    }

    interface IMediaRepository <<interface>> {
        +AddMediaAsync(asset: MediaAsset): Task<MediaAsset>
    }

    interface IUnitOfWork <<interface>> {
        +BeginTransactionAsync(): Task
        +CommitAsync(): Task
        +RollbackAsync(): Task
        +SaveChangesAsync(): Task
    }

    InventoryRepository ..|> IInventoryRepository : implements
}

' ══════════════════════════════════════════════════════════════
'  DOMAIN LAYER
' ══════════════════════════════════════════════════════════════

package "Domain Layer" {

    class InventoryTransaction <<Entity>> {
        +TransactionId: long
        +TransactionCode: string?
        +CreatedBy: long?
        +CreatedAt: DateTime?
        +SubmittedAt: DateTime?
        +ApprovedBy: long?
        +ApprovedAt: DateTime?
        +Note: string?
        +TypeLvId: uint
        +StatusLvId: uint
        +SupplierId: long?
        +ExportReasonLvId: uint?
        +StockCheckAreaNote: string?
    }

    class InventoryTransactionItem <<Entity>> {
        +TransactionItemId: long
        +TransactionId: long
        +IngredientId: long
        +Quantity: decimal
        +UnitLvId: uint
        +UnitPrice: decimal?
        +SystemQuantity: decimal?
        +ActualQuantity: decimal?
        +VarianceReasonLvId: uint?
        +Note: string?
    }

    class InventoryTransactionMedium <<Entity>> {
        +TransactionId: long
        +MediaId: long
        +IsPrimary: bool?
    }

    class Ingredient <<Entity>> {
        +IngredientId: long
        +IngredientName: string
        +UnitLvId: uint
        +TypeLvId: uint?
        +CategoryLvId: uint?
        +IngredientNameTextId: long?
        +ImageId: long?
    }

    class CurrentStock <<Entity>> {
        +IngredientId: long
        +QuantityOnHand: decimal
        +MinStockLevel: decimal
        +LastUpdatedAt: DateTime?
    }

    class Supplier <<Entity>> {
        +SupplierId: long
        +SupplierName: string
        +Phone: string?
        +Email: string?
        +Address: string?
        +TaxCode: string?
    }

    class LookupValue <<Entity>> {
        +ValueId: uint
        +TypeId: ushort
        +ValueCode: string
        +ValueName: string
    }

    class MediaAsset <<Entity>> {
        +MediaId: long
        +Url: string
        +MimeType: string
        +MediaTypeLvId: uint
        +CreatedAt: DateTime
    }

    class StaffAccount <<Entity>> {
        +AccountId: long
        +FullName: string
        +RoleId: long
    }

    ' ── Domain Relationships ──

    InventoryTransaction "1" *-- "1..*" InventoryTransactionItem : contains line items
    InventoryTransaction "1" *-- "0..*" InventoryTransactionMedium : has evidence media
    InventoryTransactionItem "0..*" --> "1" Ingredient : references ingredient
    InventoryTransactionMedium "0..*" --> "1" MediaAsset : references media
    Ingredient "1" *-- "0..1" CurrentStock : tracks current stock
    InventoryTransaction "0..*" --> "0..1" Supplier : supplied by
    InventoryTransaction "0..*" --> "1" LookupValue : transaction type
    InventoryTransaction "0..*" --> "1" LookupValue : transaction status
    InventoryTransaction "0..*" --> "0..1" LookupValue : export reason
    InventoryTransactionItem "0..*" --> "1" LookupValue : unit
    Ingredient "0..*" --> "0..1" LookupValue : ingredient type
    Ingredient "0..*" --> "0..1" LookupValue : inventory category
    InventoryTransaction "0..*" --> "0..1" StaffAccount : created by
    InventoryTransaction "0..*" --> "0..1" StaffAccount : approved by
}

' ══════════════════════════════════════════════════════════════
'  CROSS-LAYER RELATIONSHIPS
' ══════════════════════════════════════════════════════════════

' Presentation → Application
InventoryController --> IInventoryService : uses for all inventory operations
InventoryController ..> CreateInventoryTransactionFormRequest : receives multipart form payload
InventoryController ..> CreateInventoryTransactionRequest : deserializes from RequestJson
InventoryController ..> ApproveTransactionRequest : receives
InventoryController ..> SubmitTransactionRequest : receives
InventoryController ..> GetInventoryItemsFilterRequest : receives
InventoryController ..> GetTransactionsFilterRequest : receives
InventoryController ..> InventoryTransactionDetailDto : returns
InventoryController ..> InventoryItemDto : returns
InventoryController ..> StockCardDto : returns
InventoryController ..> InventoryDashboardDto : returns

' DTO-to-DTO dependencies
CreateInventoryTransactionRequest ..> TransactionItemRequest : contains item requests
InventoryTransactionDetailDto ..> TransactionItemDto : contains transaction items
InventoryTransactionDetailDto ..> TransactionMediaDto : contains evidence media
InventoryDashboardDto ..> LowStockItemDto : contains low-stock summaries
InventoryDashboardDto ..> RecentTransactionDto : contains recent transaction summaries

' Application → Persistence
InventoryService --> IInventoryRepository : uses for data access
InventoryService --> IUnitOfWork : uses for transactions
InventoryService --> IMediaRepository : saves evidence files

' Contract DTO dependencies
IInventoryService ..> InventoryTransactionListDto : returns paged transaction summaries
IInventoryRepository ..> InventoryTransactionListDto : returns paged transaction summaries

' Persistence → Domain
InventoryRepository ..> InventoryTransaction : persists
InventoryRepository ..> InventoryTransactionItem : persists
InventoryRepository ..> CurrentStock : updates stock levels
InventoryRepository ..> Ingredient : reads items

@enduml
