@startuml
title Inventory Management - Presentation Layer Class DiagramBorderColor
skinparam linetype ortho
left to right direction

package "Presentation Layer" {

    class InventoryController <<Controller>> {
        -_inventoryService: IInventoryService
        -_logger: ILogger<InventoryController>
        -GetCurrentUserId(): long
        +GetItems(filter: GetInventoryItemsFilterRequest): IActionResult
        +GetTransactions(filter: GetTransactionsFilterRequest): IActionResult
        +GetTransactionDetail(id: long): IActionResult
        +CreateTransaction(formRequest: CreateInventoryTransactionFormRequest): IActionResult
        +SubmitTransaction(id: long, request: SubmitTransactionRequest?): IActionResult
        +ApproveTransaction(id: long, request: ApproveTransactionRequest): IActionResult
        +GetStockCard(ingredientId: long, pageIndex: int, pageSize: int): IActionResult
        +GetDashboard(): IActionResult
    }

    class GetInventoryItemsFilterRequest <<DTO>> {
        +PageIndex: int
        +PageSize: int
        +Search: string?
        +CategoryLvId: uint?
        +TypeLvId: uint?
        +IsLowStock: bool?
    }

    class InventoryItemDto <<DTO>> {
        +IngredientId: long
        +IngredientName: string
        +UnitLvId: uint
        +UnitName: string?
        +TypeLvId: uint?
        +TypeName: string?
        +CategoryLvId: uint?
        +CategoryCode: string?
        +CategoryName: string?
        +ImageId: long?
        +ImageUrl: string?
        +QuantityOnHand: decimal
        +MinStockLevel: decimal
        +LastUpdatedAt: DateTime?
        +IsLowStock: bool
    }

    class CreateInventoryTransactionFormRequest <<DTO>> {
        +RequestJson: string
        +EvidenceFiles: List<IFormFile>?
    }

    class CreateInventoryTransactionRequest <<DTO>> {
        +TypeLvId: uint
        +ExportReasonLvId: uint?
        +SupplierId: long?
        +StockCheckAreaNote: string?
        +Note: string?
        +Items: List<TransactionItemRequest>
    }

    class TransactionItemRequest <<DTO>> {
        +IngredientId: long
        +Quantity: decimal
        +UnitLvId: uint
        +UnitPrice: decimal?
        +Note: string?
    }

    class SubmitTransactionRequest <<DTO>> {
        +MediaIds: List<long>?
    }

    class ApproveTransactionRequest <<DTO>> {
        +IsApproved: bool
        +Note: string?
    }

    class GetTransactionsFilterRequest <<DTO>> {
        +PageIndex: int
        +PageSize: int
        +Search: string?
        +TypeLvId: uint?
        +StatusLvId: uint?
        +ExportReasonLvId: uint?
        +SupplierId: long?
        +FromDate: DateTime?
        +ToDate: DateTime?
    }

    class InventoryTransactionListDto <<DTO>> {
        +TransactionId: long
        +TransactionCode: string?
        +TypeLvId: uint
        +TypeCode: string?
        +TypeName: string?
        +StatusLvId: uint
        +StatusCode: string?
        +StatusName: string?
        +ExportReasonLvId: uint?
        +ExportReasonName: string?
        +SupplierId: long?
        +SupplierName: string?
        +CreatedBy: long?
        +CreatedByName: string?
        +CreatedAt: DateTime?
        +SubmittedAt: DateTime?
        +ApprovedBy: long?
        +ApprovedByName: string?
        +ApprovedAt: DateTime?
        +Note: string?
        +ItemCount: int
        +TotalValue: decimal?
    }

    class InventoryTransactionDetailDto <<DTO>> {
        +TransactionId: long
        +TransactionCode: string?
        +TypeLvId: uint
        +TypeCode: string?
        +TypeName: string?
        +StatusLvId: uint
        +StatusCode: string?
        +StatusName: string?
        +ExportReasonLvId: uint?
        +ExportReasonCode: string?
        +ExportReasonName: string?
        +SupplierId: long?
        +SupplierName: string?
        +CreatedBy: long?
        +CreatedByName: string?
        +CreatedAt: DateTime?
        +SubmittedAt: DateTime?
        +ApprovedBy: long?
        +ApprovedByName: string?
        +ApprovedAt: DateTime?
        +Note: string?
        +StockCheckAreaNote: string?
        +Items: List<TransactionItemDto>
        +Media: List<TransactionMediaDto>
    }

    class TransactionItemDto <<DTO>> {
        +TransactionItemId: long
        +IngredientId: long
        +IngredientName: string?
        +IngredientImageUrl: string?
        +CategoryLvId: uint?
        +CategoryCode: string?
        +CategoryName: string?
        +Quantity: decimal
        +UnitLvId: uint
        +UnitName: string?
        +UnitPrice: decimal?
        +SystemQuantity: decimal?
        +ActualQuantity: decimal?
        +VarianceReasonLvId: uint?
        +VarianceReasonName: string?
        +Note: string?
    }

    class TransactionMediaDto <<DTO>> {
        +MediaId: long
        +Url: string?
        +MediaType: string?
    }

    class StockCardDto <<DTO>> {
        +TransactionItemId: long
        +TransactionId: long
        +TransactionCode: string?
        +TypeCode: string?
        +TypeName: string?
        +StatusCode: string?
        +QuantityChanged: decimal
        +UnitName: string?
        +UnitPrice: decimal?
        +ExportReasonName: string?
        +Note: string?
        +CreatedByName: string?
        +CreatedAt: DateTime?
    }

    class InventoryDashboardDto <<DTO>> {
        +TotalItems: int
        +LowStockItems: int
        +OutOfStockItems: int
        +PendingTransactions: int
        +LowStockList: List<LowStockItemDto>
        +RecentTransactions: List<RecentTransactionDto>
    }

    class LowStockItemDto <<DTO>> {
        +IngredientId: long
        +IngredientName: string?
        +CategoryName: string?
        +QuantityOnHand: decimal
        +MinStockLevel: decimal
        +UnitName: string?
    }

    class RecentTransactionDto <<DTO>> {
        +TransactionId: long
        +TransactionCode: string?
        +TypeName: string?
        +StatusName: string?
        +CreatedByName: string?
        +CreatedAt: DateTime?
        +ItemCount: int
    }

    CreateInventoryTransactionFormRequest -[hidden]right-> CreateInventoryTransactionRequest
    CreateInventoryTransactionRequest -[hidden]right-> GetInventoryItemsFilterRequest
    GetInventoryItemsFilterRequest -[hidden]right-> GetTransactionsFilterRequest
    SubmitTransactionRequest -[hidden]right-> ApproveTransactionRequest

    InventoryItemDto -[hidden]right-> InventoryTransactionListDto
    InventoryTransactionListDto -[hidden]right-> InventoryTransactionDetailDto
    InventoryTransactionDetailDto -[hidden]right-> StockCardDto

    InventoryDashboardDto -[hidden]right-> LowStockItemDto
    LowStockItemDto -[hidden]right-> RecentTransactionDto

    InventoryController -[hidden]down-> CreateInventoryTransactionRequest
    GetTransactionsFilterRequest -[hidden]down-> InventoryTransactionListDto
    InventoryTransactionListDto -[hidden]down-> InventoryDashboardDto
}

InventoryController ..> CreateInventoryTransactionFormRequest : receives multipart form payload
InventoryController ..> CreateInventoryTransactionRequest : deserializes from RequestJson
InventoryController ..> ApproveTransactionRequest : receives
InventoryController ..> SubmitTransactionRequest : receives
InventoryController ..> GetInventoryItemsFilterRequest : receives
InventoryController ..> GetTransactionsFilterRequest : receives
InventoryController ..> InventoryTransactionDetailDto : returns
InventoryController ..> InventoryTransactionListDto : returns paged rows
InventoryController ..> InventoryItemDto : returns
InventoryController ..> StockCardDto : returns
InventoryController ..> InventoryDashboardDto : returns

CreateInventoryTransactionRequest ..> TransactionItemRequest : contains item requests
InventoryTransactionDetailDto ..> TransactionItemDto : contains transaction items
InventoryTransactionDetailDto ..> TransactionMediaDto : contains evidence media
InventoryDashboardDto ..> LowStockItemDto : contains low-stock summaries
InventoryDashboardDto ..> RecentTransactionDto : contains recent transaction summaries
@enduml