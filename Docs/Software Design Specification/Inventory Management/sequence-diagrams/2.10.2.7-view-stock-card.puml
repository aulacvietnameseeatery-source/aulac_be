@startuml
autonumber
title 2.10.2.7 View Stock Card
skinparam sequence {
	ParticipantBackgroundColor #ffffff
	ActorBackgroundColor #ffffff
}

actor ":User" as U
participant ":StockCardPage" as Client
participant ":InventoryController" as Ctrl
participant ":InventoryService" as Svc
participant ":IInventoryRepository" as Repo
participant ":Database" as DB

activate U
U ->> Client : Open stock card page
activate Client
Client ->> Ctrl : GET /api/inventory/items/{ingredientId}/stock-card\n(pageIndex, pageSize)
activate Ctrl
Ctrl ->> Svc : GetStockCardAsync(ingredientId, pageIndex, pageSize, ct)
activate Svc

Svc ->> Repo : GetStockCardAsync(ingredientId, pageIndex, pageSize, ct)
activate Repo
Repo ->> DB : Query stock card entries for ingredient with related transaction, type, status, export reason, and creator\nordered by latest created time
activate DB
DB -->> Repo : Return stock card rows
deactivate DB
Repo -->> Svc : PagedResultDTO<StockCardDto>
deactivate Repo

Svc -->> Ctrl : PagedResultDTO<StockCardDto>
deactivate Svc
Ctrl -->> Client : 200 ApiResponse<PagedResultDTO<StockCardDto>>
deactivate Ctrl
Client -->> U : Display stock card entries
deactivate Client
deactivate U

@enduml
