@startuml
skinparam linetype ortho
autonumber
title 2.10.2.6 Enter Manual Invoice Upload

actor C as "Client"
participant "InventoryController" as Ctrl
participant "InventoryService" as Svc
participant "InventoryRepository" as Repo
participant "IFileStorage" as FS
participant "IMediaRepository" as MR
database "Database" as DB

== Create IN transaction with invoice: POST /api/inventory/transactions (TypeLvId=IN, SupplierId, EvidenceFiles=invoice photos) ==

C -> Ctrl : POST /transactions (multipart/form-data)
activate Ctrl
note right of Ctrl : RequestJson: TypeLvId=IN, SupplierId, Items with UnitPrice
note right of Ctrl : EvidenceFiles: invoice document images
Ctrl -> Ctrl : Deserialize RequestJson to CreateInventoryTransactionRequest
Ctrl -> Ctrl : GetCurrentUserId()
Ctrl -> Ctrl : MapFiles(EvidenceFiles) -> List of MediaFileInput

Ctrl -> Svc : CreateTransactionAsync(request, userId, evidenceFiles, ct)
activate Svc

Svc -> Svc : Resolve DRAFT status via LookupResolver
Svc -> Svc : ResolveTypeCodeAsync(TypeLvId) returns IN
Svc -> Repo : GetTodayTransactionCountByTypeAsync(IN, ct)
activate Repo
Repo -> DB : COUNT WHERE TypeCode=IN AND today
activate DB
DB --> Repo : count
deactivate DB
Repo --> Svc : count
deactivate Repo
Svc -> Svc : GenerateTransactionCodeAsync -> IN-YYYYMMDD-SEQ

note right of Svc : Build InventoryTransaction with SupplierId set
note right of Svc : Build InventoryTransactionItems with UnitPrice per item

Svc -> Repo : CreateTransactionAsync(transaction, items, ct)
activate Repo
Repo -> DB : INSERT InventoryTransaction (type=IN, status=DRAFT, supplierId)
activate DB
DB --> Repo : TransactionId
deactivate DB
Repo -> DB : INSERT InventoryTransactionItems (ingredientId, quantity, unitLvId, unitPrice)
activate DB
DB --> Repo : ok
deactivate DB
Repo --> Svc : transactionId
deactivate Repo

note right of Svc : SaveEvidenceFilesAsync - upload invoice document images

Svc -> Svc : Resolve IMAGE MediaType LookupValue
Svc -> FS : SaveManyAsync(uploadRequests, inventory-evidence, ImageUpload, ct)
activate FS
FS --> Svc : uploadResults (relativePaths)
deactivate FS

loop Each uploaded invoice image
    Svc -> MR : AddMediaAsync(MediaAsset with url, mimeType, mediaTypeLvId, ct)
    activate MR
    MR -> DB : INSERT MediaAssets
    activate DB
    DB --> MR : MediaAsset
    deactivate DB
    MR --> Svc : MediaAsset
    deactivate MR
    Svc -> Svc : Add InventoryTransactionMedium(transactionId, mediaId)
end

Svc -> Repo : UpdateTransactionAsync(transaction, ct)
activate Repo
Repo -> DB : UPDATE InventoryTransactions + INSERT InventoryTransactionMedia
activate DB
DB --> Repo : ok
deactivate DB
Repo --> Svc : ok
deactivate Repo

Svc -> Repo : GetTransactionByIdAsync(transactionId, ct)
activate Repo
Repo -> DB : SELECT with all Includes
activate DB
DB --> Repo : entity
deactivate DB
Repo --> Svc : entity
deactivate Repo
Svc -> Svc : MapToDetailDto(entity)
note right of Svc : Detail includes Media list with invoice image URLs
Svc --> Ctrl : InventoryTransactionDetailDto
deactivate Svc
Ctrl --> C : 200 ApiResponse with InventoryTransactionDetailDto
deactivate Ctrl

@enduml
