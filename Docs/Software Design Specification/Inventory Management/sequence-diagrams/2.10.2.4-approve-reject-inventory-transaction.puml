@startuml
autonumber
title 2.10.2.4 Approve or Reject Inventory Transaction

actor Client
participant "InventoryController" as Ctrl
participant "InventoryService" as Svc
participant "IInventoryRepository" as Repo
participant "IUnitOfWork" as UoW
participant "INotificationService" as NS
database "Database" as DB

Client -> Ctrl : POST /api/inventory/transactions/{id}/approve\n(ApproveTransactionRequest)
activate Ctrl
Ctrl -> Ctrl : GetCurrentUserId()
Ctrl -> Svc : ApproveTransactionAsync(id, request, approvedByUserId, ct)
activate Svc

Svc -> Repo : GetTransactionByIdAsync(id, ct)
activate Repo
Repo -> DB : SELECT InventoryTransaction with all Includes
activate DB
DB --> Repo : entity
deactivate DB
Repo --> Svc : entity
deactivate Repo

alt Transaction not found
    Svc --> Ctrl : throw KeyNotFoundException
    Ctrl --> Client : 404 ApiResponse (Transaction not found)
end

alt Status is not PENDING_APPROVAL
    Svc --> Ctrl : throw InvalidOperationException
    Ctrl --> Client : 400 ApiResponse (Only PENDING_APPROVAL can be processed)
end

Svc -> Svc : Set ApprovedBy = approvedByUserId\nSet ApprovedAt = UtcNow

alt request.IsApproved == true (Approve)
    Svc -> Svc : Set StatusLvId = COMPLETED
    Svc -> Svc : Append approval note (if provided)

    Svc -> UoW : BeginTransactionAsync(ct)
    activate UoW
    UoW --> Svc : ok
    deactivate UoW

    Svc -> Repo : UpdateTransactionAsync(entity, ct)
    activate Repo
    Repo -> DB : UPDATE InventoryTransaction
    activate DB
    DB --> Repo : ok
    deactivate DB
    Repo --> Svc : ok
    deactivate Repo

    note right of Svc : ApplyStockChangesAsync\n— update stock per transaction type

    loop Each InventoryTransactionItem
        alt TypeLvId == IN (Stock In)
            Svc -> Repo : UpdateStockAsync(ingredientId, +quantity, ct)
            activate Repo
            Repo -> DB : UPDATE CurrentStocks\nSET QuantityOnHand += quantity
            activate DB
            DB --> Repo : ok
            deactivate DB
            Repo --> Svc : ok
            deactivate Repo
        else TypeLvId == OUT (Stock Out)
            Svc -> Repo : UpdateStockAsync(ingredientId, -quantity, ct)
            activate Repo
            Repo -> DB : UPDATE CurrentStocks\nSET QuantityOnHand -= quantity
            activate DB
            DB --> Repo : ok
            deactivate DB
            Repo --> Svc : ok
            deactivate Repo
        else TypeLvId == ADJUST (Stock Check)
            Svc -> Repo : GetCurrentStockAsync(ingredientId, ct)
            activate Repo
            Repo -> DB : SELECT CurrentStocks
            activate DB
            DB --> Repo : CurrentStock
            deactivate DB
            Repo --> Svc : CurrentStock
            deactivate Repo
            Svc -> Svc : variance = ActualQuantity - currentQty
            Svc -> Repo : UpdateStockAsync(ingredientId, variance, ct)
            activate Repo
            Repo -> DB : UPDATE CurrentStocks
            activate DB
            DB --> Repo : ok
            deactivate DB
            Repo --> Svc : ok
            deactivate Repo
        end
    end

    Svc -> UoW : CommitAsync(ct)
    activate UoW
    UoW --> Svc : ok
    deactivate UoW

    note right of Svc : CheckLowStockAlertsAsync\n— check each item after stock update

    loop Each InventoryTransactionItem
        Svc -> Repo : GetCurrentStockAsync(ingredientId, ct)
        activate Repo
        Repo -> DB : SELECT CurrentStocks
        activate DB
        DB --> Repo : stock
        deactivate DB
        Repo --> Svc : stock
        deactivate Repo

        opt QuantityOnHand <= MinStockLevel
            Svc -> NS : PublishAsync(LOW_STOCK_ALERT\n→ targets: staff with ViewInventory permission)
            activate NS
            NS --> Svc : ok
            deactivate NS
        end
    end

    Svc -> NS : PublishAsync(INVENTORY_TX_APPROVED\n→ target: transaction creator)
    activate NS
    NS --> Svc : ok
    deactivate NS

else request.IsApproved == false (Reject)
    alt Rejection note is empty
        Svc --> Ctrl : throw InvalidOperationException
        Ctrl --> Client : 400 ApiResponse (Note required for rejection)
    end

    Svc -> Svc : Set StatusLvId = CANCELLED
    Svc -> Svc : Append rejection reason to Note

    Svc -> Repo : UpdateTransactionAsync(entity, ct)
    activate Repo
    Repo -> DB : UPDATE InventoryTransaction
    activate DB
    DB --> Repo : ok
    deactivate DB
    Repo --> Svc : ok
    deactivate Repo

    Svc -> NS : PublishAsync(INVENTORY_TX_REJECTED\n→ target: transaction creator)
    activate NS
    NS --> Svc : ok
    deactivate NS
end

note right of Svc : GetTransactionDetailAsync\n→ reload entity + MapToDetailDto

Svc -> Repo : GetTransactionByIdAsync(id, ct)
activate Repo
Repo -> DB : SELECT with all Includes
activate DB
DB --> Repo : entity
deactivate DB
Repo --> Svc : entity
deactivate Repo
Svc -> Svc : MapToDetailDto(entity)

Svc --> Ctrl : InventoryTransactionDetailDto
deactivate Svc
Ctrl --> Client : 200 ApiResponse<InventoryTransactionDetailDto>
deactivate Ctrl

@enduml
