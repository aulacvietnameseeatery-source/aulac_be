@startuml
autonumber
title 2.10.2.3 View Inventory Transaction Detail

actor User as U
participant "FE Layer" as C
note over U, C : User interacts through FE before backend calls
U -> C : uses web app UI
participant "InventoryController" as Ctrl
participant "InventoryService" as Svc
participant "InventoryRepository" as Repo
database "Database" as DB

== GET /api/inventory/transactions (list) ==

C -> Ctrl : GET /transactions (GetTransactionsFilterRequest)
activate Ctrl
Ctrl -> Svc : GetTransactionsAsync(filter, ct)
activate Svc
Svc -> Repo : GetTransactionsPagedAsync(filter, ct)
activate Repo

Repo -> DB : SELECT InventoryTransactions JOIN TypeLv, StatusLv,\nExportReasonLv, Supplier, CreatedBy, ApprovedBy, Items\nwith filters ORDER BY CreatedAt DESC
activate DB
DB --> Repo : Rows
deactivate DB
note right of Repo : Map to InventoryTransactionListDto with ItemCount and TotalValue
Repo --> Svc : PagedResultDTO of InventoryTransactionListDto
deactivate Repo
Svc --> Ctrl : PagedResultDTO of InventoryTransactionListDto
deactivate Svc
Ctrl --> C : 200 ApiResponse with PagedResultDTO of InventoryTransactionListDto
deactivate Ctrl

== GET /api/inventory/transactions/{id} ==

C -> Ctrl : GET /transactions/{id}
activate Ctrl
Ctrl -> Svc : GetTransactionDetailAsync(id, ct)
activate Svc
Svc -> Repo : GetTransactionByIdAsync(id, ct)
activate Repo

Repo -> DB : SELECT InventoryTransaction with Includes\n(TypeLv, StatusLv, ExportReasonLv, Supplier,\nCreatedBy, ApprovedBy, Items->Ingredient->Image,\nItems->Ingredient->CategoryLv, Items->UnitLv,\nItems->VarianceReasonLv, Media->MediaAsset)
activate DB
DB --> Repo : InventoryTransaction entity
deactivate DB

alt entity is null
    Repo --> Svc : null
    Svc --> C : KeyNotFoundException
end

Repo --> Svc : InventoryTransaction entity
deactivate Repo
Svc -> Svc : MapToDetailDto(entity)
Svc --> Ctrl : InventoryTransactionDetailDto
deactivate Svc
Ctrl --> C : 200 ApiResponse with InventoryTransactionDetailDto
deactivate Ctrl

@enduml
