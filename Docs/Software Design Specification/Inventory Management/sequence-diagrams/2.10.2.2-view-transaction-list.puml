@startuml
autonumber
title 2.10.2.2 View Transaction List
skinparam sequence {
	ParticipantBackgroundColor #ffffff
	ActorBackgroundColor #ffffff
}

actor ":User" as U
participant ":TransactionListPage" as Client
participant ":InventoryController" as Ctrl
participant ":InventoryService" as Svc
participant ":IInventoryRepository" as Repo
participant ":Database" as DB

activate U
U ->> Client : Open inventory transaction list page
activate Client
Client ->> Ctrl : GET /api/inventory/transactions\n(GetTransactionsFilterRequest)
activate Ctrl
Ctrl ->> Svc : GetTransactionsAsync(filter, ct)
activate Svc

Svc ->> Repo : GetTransactionsPagedAsync(filter, ct)
activate Repo
Repo ->> DB : Query inventory transactions with type, status, export reason, supplier, creator, approver, and items\napplying filters and sorting by latest created time
activate DB
DB -->> Repo : Return transaction rows
deactivate DB
Repo -->> Svc : PagedResultDTO<InventoryTransactionListDto>
deactivate Repo

Svc -->> Ctrl : PagedResultDTO<InventoryTransactionListDto>
deactivate Svc
Ctrl -->> Client : 200 ApiResponse<PagedResultDTO<InventoryTransactionListDto>>
deactivate Ctrl

Client -->> U : Display transaction list with pagination
deactivate Client
deactivate U
@enduml
