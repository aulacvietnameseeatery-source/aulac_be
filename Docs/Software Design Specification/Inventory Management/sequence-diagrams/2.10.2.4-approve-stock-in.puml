@startuml
autonumber
title 2.10.2.4 Approve Stock In

actor C as "Client"
participant "InventoryController" as Ctrl
participant "InventoryService" as Svc
participant "InventoryRepository" as Repo
participant "INotificationService" as NS
database "Database" as DB

== POST /api/inventory/transactions/{id}/approve (Approve or Reject) ==

C -> Ctrl : POST /transactions/{id}/approve (ApproveTransactionRequest)
activate Ctrl
Ctrl -> Ctrl : GetCurrentUserId()
Ctrl -> Svc : ApproveTransactionAsync(id, request, approvedByUserId, ct)
activate Svc

Svc -> Repo : GetTransactionByIdAsync(id, ct)
activate Repo
Repo -> DB : SELECT InventoryTransaction with all Includes
activate DB
DB --> Repo : entity
deactivate DB
Repo --> Svc : entity
deactivate Repo

alt entity is null
    Svc --> C : KeyNotFoundException
end

alt Status is not PENDING_APPROVAL
    Svc --> C : InvalidOperationException
end

Svc -> Svc : Set ApprovedBy, ApprovedAt

alt request.IsApproved == true (Approve)
    Svc -> Svc : Set StatusLvId = COMPLETED
    Svc -> Svc : Append approval note if provided

    Svc -> Svc : BeginTransaction via IUnitOfWork
    Svc -> Repo : UpdateTransactionAsync(entity, ct)
    activate Repo
    Repo -> DB : UPDATE InventoryTransactions
    activate DB
    DB --> Repo : ok
    deactivate DB
    Repo --> Svc : ok
    deactivate Repo

    note right of Svc : ApplyStockChangesAsync - update stock per type

    loop Each InventoryTransactionItem
        alt TypeLvId == IN (Stock In)
            Svc -> Repo : UpdateStockAsync(ingredientId, +quantity, ct)
            activate Repo
            Repo -> DB : UPDATE CurrentStocks SET QuantityOnHand += quantity
            activate DB
            DB --> Repo : ok
            deactivate DB
            Repo --> Svc : ok
            deactivate Repo
        else TypeLvId == OUT (Stock Out)
            Svc -> Repo : UpdateStockAsync(ingredientId, -quantity, ct)
            activate Repo
            Repo -> DB : UPDATE CurrentStocks SET QuantityOnHand -= quantity
            activate DB
            DB --> Repo : ok
            deactivate DB
            Repo --> Svc : ok
            deactivate Repo
        else TypeLvId == ADJUST (Stock Check)
            Svc -> Repo : GetCurrentStockAsync(ingredientId, ct)
            activate Repo
            Repo -> DB : SELECT CurrentStocks
            activate DB
            DB --> Repo : CurrentStock
            deactivate DB
            Repo --> Svc : CurrentStock
            deactivate Repo
            Svc -> Svc : Calculate variance = ActualQuantity - currentQty
            Svc -> Repo : UpdateStockAsync(ingredientId, variance, ct)
            activate Repo
            Repo -> DB : UPDATE CurrentStocks
            activate DB
            DB --> Repo : ok
            deactivate DB
            Repo --> Svc : ok
            deactivate Repo
        end
    end

    Svc -> Svc : CommitTransaction via IUnitOfWork

    note right of Svc : CheckLowStockAlertsAsync

    loop Each item
        Svc -> Repo : GetCurrentStockAsync(ingredientId, ct)
        activate Repo
        Repo -> DB : SELECT CurrentStocks
        activate DB
        DB --> Repo : CurrentStock
        deactivate DB
        Repo --> Svc : CurrentStock
        deactivate Repo

        opt QuantityOnHand <= MinStockLevel
            Svc -> NS : PublishAsync(LOW_STOCK_ALERT)
            activate NS
            NS --> Svc : ok
            deactivate NS
        end
    end

    Svc -> NS : PublishAsync(INVENTORY_TX_APPROVED to creator)
    activate NS
    NS --> Svc : ok
    deactivate NS

else request.IsApproved == false (Reject)
    alt Note is empty
        Svc --> C : InvalidOperationException (note required)
    end

    Svc -> Svc : Set StatusLvId = CANCELLED
    Svc -> Svc : Append rejection reason to Note

    Svc -> Repo : UpdateTransactionAsync(entity, ct)
    activate Repo
    Repo -> DB : UPDATE InventoryTransactions
    activate DB
    DB --> Repo : ok
    deactivate DB
    Repo --> Svc : ok
    deactivate Repo

    Svc -> NS : PublishAsync(INVENTORY_TX_REJECTED to creator)
    activate NS
    NS --> Svc : ok
    deactivate NS
end

Svc -> Repo : GetTransactionByIdAsync(id, ct)
activate Repo
Repo -> DB : SELECT
activate DB
DB --> Repo : entity
deactivate DB
Repo --> Svc : entity
deactivate Repo
Svc -> Svc : MapToDetailDto(entity)
Svc --> Ctrl : InventoryTransactionDetailDto
deactivate Svc
Ctrl --> C : 200 ApiResponse with InventoryTransactionDetailDto
deactivate Ctrl

@enduml
