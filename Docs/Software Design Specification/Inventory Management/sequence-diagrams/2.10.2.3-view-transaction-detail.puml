@startuml
autonumber
title 2.10.2.3 View Transaction Detail
skinparam sequence {
    ParticipantBackgroundColor #ffffff
    ActorBackgroundColor #ffffff
}

actor ":User" as U
participant ":TransactionDetailPage" as Client
participant ":InventoryController" as Ctrl
participant ":InventoryService" as Svc
participant ":IInventoryRepository" as Repo
participant ":Database" as DB

activate U
U ->> Client : Open transaction detail page
activate Client
Client ->> Ctrl : GET /api/inventory/transactions/{id}
activate Ctrl
Ctrl ->> Svc : GetTransactionDetailAsync(id, ct)
activate Svc

Svc ->> Repo : GetTransactionByIdAsync(id, ct)
activate Repo
Repo ->> DB : Query transaction detail with related type, status, export reason, supplier, creator, approver, items, ingredient metadata, and media
activate DB
DB -->> Repo : Return transaction entity
deactivate DB
Repo -->> Svc : entity
deactivate Repo

alt#White Transaction not found
    Svc -->> Ctrl : throw KeyNotFoundException
    Ctrl -->> Client : 404 ApiResponse (Transaction not found)
end

Svc ->> Svc : MapToDetailDto(entity)

Svc -->> Ctrl : InventoryTransactionDetailDto
deactivate Svc
Ctrl -->> Client : 200 ApiResponse<InventoryTransactionDetailDto>
deactivate Ctrl
Client -->> U : Display transaction detail
deactivate Client
deactivate U

@enduml
