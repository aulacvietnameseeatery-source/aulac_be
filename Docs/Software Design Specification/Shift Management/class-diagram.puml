@startuml
skinparam linetype ortho
title Shift Management Module - Specification Class Diagram
left to right direction

' ══════════════════════════════════════════════════════════════
'  PRESENTATION LAYER
' ══════════════════════════════════════════════════════════════

package "Presentation Layer" {

    class ShiftController {
        -_templateService: IShiftTemplateService
        -_assignmentService: IShiftAssignmentService
        -_attendanceService: IAttendanceService
        -GetStaffId(): long
        +GetTemplates(isActive: bool?): IActionResult
        +GetTemplate(id: long): IActionResult
        +CreateTemplate(request: CreateShiftTemplateRequest): IActionResult
        +UpdateTemplate(id: long, request: UpdateShiftTemplateRequest): IActionResult
        +DeactivateTemplate(id: long): IActionResult
        +GetAssignments(request: GetShiftAssignmentRequest): IActionResult
        +GetAssignment(id: long): IActionResult
        +CreateAssignment(request: CreateShiftAssignmentRequest): IActionResult
        +UpdateAssignment(id: long, request: UpdateShiftAssignmentRequest): IActionResult
        +CancelAssignment(id: long): IActionResult
        +BulkCreateAssignment(request: BulkCreateAssignmentRequest): IActionResult
        +PublishAssignments(request: PublishAssignmentsRequest): IActionResult
        +CopyWeek(request: CopyWeekRequest): IActionResult
        +ReassignAssignment(id: long, request: ReassignRequest): IActionResult
        +ConfirmAssignment(id: long): IActionResult
        +GetTeamSchedule(request: TeamScheduleRequest): IActionResult
        +GetMyShifts(request: GetShiftAssignmentRequest): IActionResult
        +GetLiveBoard(request: GetShiftAssignmentRequest): IActionResult
        +CheckIn(id: long): IActionResult
        +CheckOut(id: long): IActionResult
        +AdjustAttendance(id: long, request: AdjustAttendanceRequest): IActionResult
        +GetReportSnapshot(fromDate: DateOnly, toDate: DateOnly): IActionResult
        +GetAttendanceReport(request: AttendanceReportRequest): IActionResult
        +GetWorkedHoursReport(fromDate: DateOnly, toDate: DateOnly, staffId: long?): IActionResult
        +GetExceptionsReport(fromDate: DateOnly, toDate: DateOnly, staffId: long?): IActionResult
    }

    ' ── Template Request/Response DTOs ──

    class CreateShiftTemplateRequest <<DTO>> {
        +TemplateName: string
        +DefaultStartTime: TimeOnly
        +DefaultEndTime: TimeOnly
        +Description: string?
        +BufferBeforeMinutes: int?
        +BufferAfterMinutes: int?
    }

    class UpdateShiftTemplateRequest <<DTO>> {
        +TemplateName: string?
        +DefaultStartTime: TimeOnly?
        +DefaultEndTime: TimeOnly?
        +Description: string?
        +IsActive: bool?
        +BufferBeforeMinutes: int?
        +BufferAfterMinutes: int?
    }

    class GetShiftTemplateRequest <<DTO>> {
        +IsActive: bool?
        +PageIndex: int
        +PageSize: int
    }

    class ShiftTemplateListDto <<DTO>> {
        +ShiftTemplateId: long
        +TemplateName: string
        +DefaultStartTime: TimeOnly
        +DefaultEndTime: TimeOnly
        +Description: string?
        +BufferBeforeMinutes: int?
        +BufferAfterMinutes: int?
        +IsActive: bool
        +CreatedAt: DateTime
    }

    class ShiftTemplateDetailDto <<DTO>> {
        +CreatedByName: string
        +UpdatedByName: string?
        +UpdatedAt: DateTime
    }

    ' ── Assignment Request/Response DTOs ──

    class GetShiftAssignmentRequest <<DTO>> {
        +StaffId: long?
        +ShiftTemplateId: long?
        +FromDate: DateOnly?
        +ToDate: DateOnly?
        +IsActive: bool?
        +AssignmentStatusCode: string?
        +PageIndex: int
        +PageSize: int
    }

    class CreateShiftAssignmentRequest <<DTO>> {
        +ShiftTemplateId: long
        +StaffId: long
        +WorkDate: DateOnly
        +PlannedStartAt: DateTime?
        +PlannedEndAt: DateTime?
        +Notes: string?
        +Tags: string?
        +IsDraft: bool
    }

    class BulkCreateAssignmentRequest <<DTO>> {
        +ShiftTemplateId: long
        +StaffIds: List<long>
        +WorkDate: DateOnly
        +WorkDates: List<DateOnly>?
        +PlannedStartAt: DateTime?
        +PlannedEndAt: DateTime?
        +Notes: string?
        +Tags: string?
        +IsDraft: bool
        +GetEffectiveDates(): IReadOnlyList<DateOnly>
    }

    class PublishAssignmentsRequest <<DTO>> {
        +AssignmentIds: List<long>?
        +FromDate: DateOnly?
        +ToDate: DateOnly?
    }

    class CopyWeekRequest <<DTO>> {
        +SourceWeekStart: DateOnly
        +TargetWeekStart: DateOnly
        +AsDraft: bool
    }

    class ReassignRequest <<DTO>> {
        +NewStaffId: long
        +NewWorkDate: DateOnly?
        +Reason: string?
    }

    class UpdateShiftAssignmentRequest <<DTO>> {
        +PlannedStartAt: DateTime?
        +PlannedEndAt: DateTime?
        +Notes: string?
        +Tags: string?
    }

    class TeamScheduleRequest <<DTO>> {
        +WeekStart: DateOnly
        +WeekEnd: DateOnly?
        +ShiftTemplateId: long?
    }

    class ShiftAssignmentListDto <<DTO>> {
        +ShiftAssignmentId: long
        +ShiftTemplateId: long
        +TemplateName: string
        +StaffId: long
        +StaffName: string
        +WorkDate: DateOnly
        +PlannedStartAt: DateTime
        +PlannedEndAt: DateTime
        +AssignmentStatusCode: string
        +AssignmentStatusName: string
        +IsActive: bool
        +Tags: string?
        +Notes: string?
        +AssignedAt: DateTime
        +AssignedByName: string
    }

    class ShiftAssignmentDetailDto <<DTO>> {
        +Attendance: AttendanceRecordDto?
    }

    ' ── Attendance DTOs ──

    class AdjustAttendanceRequest <<DTO>> {
        +ActualCheckInAt: DateTime?
        +ActualCheckOutAt: DateTime?
        +AdjustmentReason: string
    }

    class AttendanceRecordDto <<DTO>> {
        +AttendanceId: long
        +ShiftAssignmentId: long
        +AttendanceStatusCode: string
        +AttendanceStatusName: string
        +ActualCheckInAt: DateTime?
        +ActualCheckOutAt: DateTime?
        +LateMinutes: int
        +EarlyLeaveMinutes: int
        +WorkedMinutes: int
        +IsManualAdjustment: bool
        +AdjustmentReason: string?
        +ReviewedByName: string?
        +ReviewedAt: DateTime?
        +TimeLogs: List<TimeLogDto>
    }

    class TimeLogDto <<DTO>> {
        +TimeLogId: long
        +PunchInTime: DateTime
        +PunchOutTime: DateTime?
        +ValidationStatus: string
        +PunchDurationMinutes: int
    }

    ' ── Live Board DTOs ──

    class ShiftLiveBoardItemDto <<DTO>> {
        +ShiftAssignmentId: long
        +StaffId: long
        +StaffName: string
        +LiveStatusCode: string
        +LiveStatusName: string
        +HasAlert: bool
        +OrdersHandledCount: int?
        +PaidBillsCount: int?
        +CurrentRevenue: decimal?
        +IssueCount: int
    }

    ' ── Report DTOs ──

    class AttendanceReportRequest <<DTO>> {
        +FromDate: DateOnly?
        +ToDate: DateOnly?
        +StaffId: long?
        +ShiftTemplateId: long?
        +AttendanceStatusCode: string?
        +PageIndex: int
        +PageSize: int
    }

    class AttendanceReportRowDto <<DTO>> {
        +ShiftAssignmentId: long
        +StaffId: long
        +StaffName: string
        +WorkDate: DateOnly
        +AttendanceStatusCode: string
        +LateMinutes: int
        +WorkedMinutes: int
    }

    class WorkedHoursReportRowDto <<DTO>> {
        +StaffId: long
        +StaffName: string
        +ScheduledMinutes: int
        +WorkedMinutes: int
        +VarianceMinutes: int
    }

    class AttendanceExceptionReportRowDto <<DTO>> {
        +StaffId: long
        +StaffName: string
        +ExceptionType: string
        +MinutesAffected: int
        +IsManualAdjustment: bool
    }

    class ShiftReportSnapshotDto <<DTO>> {
        +AttendanceCount: int
        +WorkedStaffCount: int
        +ExceptionCount: int
    }

    ShiftTemplateDetailDto --|> ShiftTemplateListDto
    ShiftAssignmentDetailDto --|> ShiftAssignmentListDto
}

' ══════════════════════════════════════════════════════════════
'  APPLICATION LAYER
' ══════════════════════════════════════════════════════════════

package "Application Layer" {

    interface IShiftTemplateService {
        +GetAllAsync(isActive: bool?): Task<List<ShiftTemplateListDto>>
        +GetByIdAsync(id: long): Task<ShiftTemplateDetailDto>
        +CreateAsync(request: CreateShiftTemplateRequest, staffId: long): Task<ShiftTemplateDetailDto>
        +UpdateAsync(id: long, request: UpdateShiftTemplateRequest, staffId: long): Task<ShiftTemplateDetailDto>
        +DeactivateAsync(id: long): Task
    }

    class ShiftTemplateService {
        -_templateRepo: IShiftTemplateRepository
        -_unitOfWork: IUnitOfWork
        +GetAllAsync(isActive: bool?): Task<List<ShiftTemplateListDto>>
        +GetByIdAsync(id: long): Task<ShiftTemplateDetailDto>
        +CreateAsync(request: CreateShiftTemplateRequest, staffId: long): Task<ShiftTemplateDetailDto>
        +UpdateAsync(id: long, request: UpdateShiftTemplateRequest, staffId: long): Task<ShiftTemplateDetailDto>
        +DeactivateAsync(id: long): Task
    }

    interface IShiftAssignmentService {
        +GetAssignmentsAsync(request: GetShiftAssignmentRequest): Task<(List<ShiftAssignmentListDto>, int)>
        +GetByIdAsync(id: long): Task<ShiftAssignmentDetailDto>
        +GetLiveBoardAsync(request: GetShiftAssignmentRequest): Task<List<ShiftLiveBoardItemDto>>
        +CreateAssignmentAsync(request: CreateShiftAssignmentRequest, staffId: long): Task<ShiftAssignmentDetailDto>
        +BulkCreateAssignmentsAsync(request: BulkCreateAssignmentRequest, staffId: long): Task<List<ShiftAssignmentDetailDto>>
        +UpdateAssignmentAsync(id: long, request: UpdateShiftAssignmentRequest, staffId: long): Task<ShiftAssignmentDetailDto>
        +CancelAssignmentAsync(id: long): Task
        +GetMyShiftsAsync(staffId: long, request: GetShiftAssignmentRequest): Task<(List<ShiftAssignmentDetailDto>, int)>
        +PublishAssignmentsAsync(request: PublishAssignmentsRequest, staffId: long): Task<List<ShiftAssignmentListDto>>
        +CopyWeekAsync(request: CopyWeekRequest, staffId: long): Task<List<ShiftAssignmentListDto>>
        +ReassignAsync(id: long, request: ReassignRequest, staffId: long): Task<ShiftAssignmentDetailDto>
        +ConfirmAssignmentAsync(id: long, staffId: long): Task<ShiftAssignmentDetailDto>
        +GetTeamScheduleAsync(request: TeamScheduleRequest): Task<List<ShiftAssignmentListDto>>
    }

    class ShiftAssignmentService {
        -_assignmentRepo: IShiftAssignmentRepository
        -_templateRepo: IShiftTemplateRepository
        -_accountRepo: IAccountRepository
        -_orderRepository: IOrderRepository
        -_unitOfWork: IUnitOfWork
        -_notificationService: INotificationService
        -_lookupResolver: ILookupResolver
        -_options: AttendanceOptions
        -_shiftLiveRealtimePublisher: IShiftLiveRealtimePublisher
        +GetAssignmentsAsync(request: GetShiftAssignmentRequest): Task<(List<ShiftAssignmentListDto>, int)>
        +GetByIdAsync(id: long): Task<ShiftAssignmentDetailDto>
        +GetLiveBoardAsync(request: GetShiftAssignmentRequest): Task<List<ShiftLiveBoardItemDto>>
        +CreateAssignmentAsync(request: CreateShiftAssignmentRequest, staffId: long): Task<ShiftAssignmentDetailDto>
        +BulkCreateAssignmentsAsync(request: BulkCreateAssignmentRequest, staffId: long): Task<List<ShiftAssignmentDetailDto>>
        +UpdateAssignmentAsync(id: long, request: UpdateShiftAssignmentRequest, staffId: long): Task<ShiftAssignmentDetailDto>
        +CancelAssignmentAsync(id: long): Task
        +PublishAssignmentsAsync(request: PublishAssignmentsRequest, staffId: long): Task<List<ShiftAssignmentListDto>>
        +CopyWeekAsync(request: CopyWeekRequest, staffId: long): Task<List<ShiftAssignmentListDto>>
        +ReassignAsync(id: long, request: ReassignRequest, staffId: long): Task<ShiftAssignmentDetailDto>
        +ConfirmAssignmentAsync(id: long, staffId: long): Task<ShiftAssignmentDetailDto>
        +GetTeamScheduleAsync(request: TeamScheduleRequest): Task<List<ShiftAssignmentListDto>>
    }

    interface IAttendanceService {
        +CheckInAsync(assignmentId: long, staffId: long): Task<AttendanceRecordDto>
        +CheckOutAsync(assignmentId: long, staffId: long): Task<AttendanceRecordDto>
        +AdjustAttendanceAsync(id: long, request: AdjustAttendanceRequest, reviewerId: long): Task<AttendanceRecordDto>
        +GetAttendanceReportAsync(request: AttendanceReportRequest): Task<(List<AttendanceReportRowDto>, int)>
        +GetExceptionsReportAsync(from: DateOnly, to: DateOnly, staffId: long?): Task<List<AttendanceExceptionReportRowDto>>
        +GetWorkedHoursReportAsync(from: DateOnly, to: DateOnly, staffId: long?): Task<List<WorkedHoursReportRowDto>>
        +GetReportSnapshotAsync(from: DateOnly, to: DateOnly): Task<ShiftReportSnapshotDto>
    }

    class AttendanceService {
        -_attendanceRepo: IAttendanceRepository
        -_assignmentRepo: IShiftAssignmentRepository
        -_unitOfWork: IUnitOfWork
        -_lookupResolver: ILookupResolver
        -_shiftSettings: IShiftSettingsProvider
        -_notificationService: INotificationService
        -_shiftLiveRealtimePublisher: IShiftLiveRealtimePublisher
        +CheckInAsync(assignmentId: long, staffId: long): Task<AttendanceRecordDto>
        +CheckOutAsync(assignmentId: long, staffId: long): Task<AttendanceRecordDto>
        +AdjustAttendanceAsync(id: long, request: AdjustAttendanceRequest, reviewerId: long): Task<AttendanceRecordDto>
        +GetAttendanceReportAsync(request: AttendanceReportRequest): Task<(List<AttendanceReportRowDto>, int)>
        +GetExceptionsReportAsync(from: DateOnly, to: DateOnly, staffId: long?): Task<List<AttendanceExceptionReportRowDto>>
        +GetWorkedHoursReportAsync(from: DateOnly, to: DateOnly, staffId: long?): Task<List<WorkedHoursReportRowDto>>
        +GetReportSnapshotAsync(from: DateOnly, to: DateOnly): Task<ShiftReportSnapshotDto>
    }

    interface IShiftSettingsProvider {
        +GetAllowedEarlyCheckInMinutesAsync(): Task<int>
        +GetLateGraceMinutesAsync(): Task<int>
        +GetAbsenceThresholdMinutesAsync(): Task<int>
        +GetEarlyLeaveBufferMinutesAsync(): Task<int>
        +GetNoShowThresholdMinutesAsync(): Task<int>
        +GetMaxWeeklyHoursAsync(): Task<double>
    }

    class ShiftSettingsProvider {
        -_systemSettingRepo: ISystemSettingRepository
        +GetAllowedEarlyCheckInMinutesAsync(): Task<int>
        +GetLateGraceMinutesAsync(): Task<int>
        +GetAbsenceThresholdMinutesAsync(): Task<int>
        +GetEarlyLeaveBufferMinutesAsync(): Task<int>
        +GetNoShowThresholdMinutesAsync(): Task<int>
        +GetMaxWeeklyHoursAsync(): Task<double>
    }

    interface IShiftLiveRealtimePublisher {
        +PublishBoardChangedAsync(payload: ShiftLiveRealtimeEventDto): Task
    }

    ShiftTemplateService ..|> IShiftTemplateService : implements
    ShiftAssignmentService ..|> IShiftAssignmentService : implements
    AttendanceService ..|> IAttendanceService : implements
    ShiftSettingsProvider ..|> IShiftSettingsProvider : implements
}

' ══════════════════════════════════════════════════════════════
'  PERSISTENCE LAYER
' ══════════════════════════════════════════════════════════════

package "Persistence Layer" {

    interface IShiftTemplateRepository {
        +Add(entity: ShiftTemplate): void
        +GetByIdAsync(id: long): Task<ShiftTemplate?>
        +GetAllActiveAsync(): Task<List<ShiftTemplate>>
        +GetAllAsync(): Task<List<ShiftTemplate>>
        +ExistsByNameAsync(name: string, excludeId: long?): Task<bool>
        +HasActiveAssignmentsAsync(templateId: long): Task<bool>
    }

    class ShiftTemplateRepository {
        -_context: AuLacDbContext
    }

    interface IShiftAssignmentRepository {
        +Add(entity: ShiftAssignment): void
        +AddRange(entities: IEnumerable<ShiftAssignment>): void
        +GetByIdAsync(id: long): Task<ShiftAssignment?>
        +GetByIdWithDetailsAsync(id: long): Task<ShiftAssignment?>
        +GetAssignmentsAsync(request: GetShiftAssignmentRequest): Task<(List<ShiftAssignment>, int)>
        +HasOverlappingAssignmentAsync(staffId: long, workDate: DateOnly, start: DateTime, end: DateTime, excludeId: long?): Task<bool>
        +GetAlreadyAssignedStaffIdsAsync(templateId: long, workDate: DateOnly, staffIds: IEnumerable<long>): Task<List<long>>
        +GetDraftAssignmentsAsync(from: DateOnly, to: DateOnly): Task<List<ShiftAssignment>>
        +GetByIdsWithDetailsAsync(ids: IEnumerable<long>): Task<List<ShiftAssignment>>
        +GetWeekAssignmentsAsync(weekStart: DateOnly): Task<List<ShiftAssignment>>
        +GetTeamScheduleAsync(weekStart: DateOnly, weekEnd: DateOnly, templateId: long?): Task<List<ShiftAssignment>>
        +GetNoShowCandidatesAsync(thresholdUtc: DateTime): Task<List<ShiftAssignment>>
        +GetWorkedHoursDataAsync(from: DateOnly, to: DateOnly, staffId: long?): Task<List<ShiftAssignment>>
        +GetExceptionDataAsync(from: DateOnly, to: DateOnly, staffId: long?): Task<List<ShiftAssignment>>
        +GetAttendanceReportAsync(request: AttendanceReportRequest): Task<(List<ShiftAssignment>, int)>
    }

    class ShiftAssignmentRepository {
        -_context: AuLacDbContext
    }

    interface IAttendanceRepository {
        +Add(entity: AttendanceRecord): void
        +GetByAssignmentIdAsync(assignmentId: long): Task<AttendanceRecord?>
        +GetByIdAsync(id: long): Task<AttendanceRecord?>
        +GetByIdWithDetailsAsync(id: long): Task<AttendanceRecord?>
    }

    class AttendanceRepository {
        -_context: AuLacDbContext
    }

    interface IUnitOfWork {
        +BeginTransactionAsync(): Task
        +CommitAsync(): Task
        +RollbackAsync(): Task
        +SaveChangesAsync(): Task
    }

    ShiftTemplateRepository ..|> IShiftTemplateRepository : implements
    ShiftAssignmentRepository ..|> IShiftAssignmentRepository : implements
    AttendanceRepository ..|> IAttendanceRepository : implements
}

' ══════════════════════════════════════════════════════════════
'  DOMAIN LAYER
' ══════════════════════════════════════════════════════════════

package "Domain Layer" {

    class ShiftTemplate <<Entity>> {
        +ShiftTemplateId: long
        +TemplateName: string
        +DefaultStartTime: TimeOnly
        +DefaultEndTime: TimeOnly
        +Description: string?
        +BufferBeforeMinutes: int?
        +BufferAfterMinutes: int?
        +IsActive: bool
        +CreatedBy: long
        +CreatedAt: DateTime
        +UpdatedBy: long?
        +UpdatedAt: DateTime
    }

    class ShiftAssignment <<Entity>> {
        +ShiftAssignmentId: long
        +ShiftTemplateId: long
        +StaffId: long
        +WorkDate: DateOnly
        +PlannedStartAt: DateTime
        +PlannedEndAt: DateTime
        +AssignmentStatusLvId: uint
        +IsActive: bool
        +Tags: string?
        +Notes: string?
        +AssignedBy: long
        +AssignedAt: DateTime
        +CreatedAt: DateTime
        +UpdatedAt: DateTime
    }

    class AttendanceRecord <<Entity>> {
        +AttendanceId: long
        +ShiftAssignmentId: long
        +AttendanceStatusLvId: uint
        +ActualCheckInAt: DateTime?
        +ActualCheckOutAt: DateTime?
        +LateMinutes: int
        +EarlyLeaveMinutes: int
        +WorkedMinutes: int
        +IsManualAdjustment: bool
        +AdjustmentReason: string?
        +ReviewedBy: long?
        +ReviewedAt: DateTime?
        +CreatedAt: DateTime
        +UpdatedAt: DateTime
    }

    class TimeLog <<Entity>> {
        +TimeLogId: long
        +AttendanceRecordId: long
        +PunchInTime: DateTime
        +PunchOutTime: DateTime?
        +GpsLocationIn: string?
        +GpsLocationOut: string?
        +DeviceIdIn: string?
        +DeviceIdOut: string?
        +ValidationStatus: string
        +PunchDurationMinutes: int
        +CreatedAt: DateTime
    }

    class StaffAccount <<Entity>> {
        +AccountId: long
        +FullName: string
        +RoleId: long
        +RegisteredDeviceId: string?
    }

    class LookupValue <<Entity>> {
        +ValueId: uint
        +TypeId: ushort
        +ValueCode: string
        +ValueName: string
    }

    ' ── Domain Relationships ──

    ShiftTemplate "1" *-- "0..*" ShiftAssignment : contains assignments
    ShiftAssignment "1" *-- "0..1" AttendanceRecord : tracks attendance
    AttendanceRecord "1" *-- "0..*" TimeLog : records punch cycles
    ShiftAssignment "0..*" --> "1" StaffAccount : assigned to
    ShiftAssignment "0..*" --> "1" LookupValue : assignment status
    AttendanceRecord "0..*" --> "1" LookupValue : attendance status
    ShiftTemplate "0..*" --> "1" StaffAccount : created by
}

' ══════════════════════════════════════════════════════════════
'  CROSS-LAYER RELATIONSHIPS
' ══════════════════════════════════════════════════════════════

' Presentation → Application
ShiftController --> IShiftTemplateService : uses for template operations
ShiftController --> IShiftAssignmentService : uses for assignment operations
ShiftController --> IAttendanceService : uses for attendance operations
ShiftController ..> CreateShiftTemplateRequest : receives
ShiftController ..> CreateShiftAssignmentRequest : receives
ShiftController ..> BulkCreateAssignmentRequest : receives
ShiftController ..> AdjustAttendanceRequest : receives
ShiftController ..> ShiftTemplateDetailDto : returns
ShiftController ..> ShiftAssignmentDetailDto : returns
ShiftController ..> AttendanceRecordDto : returns
ShiftController ..> ShiftLiveBoardItemDto : returns

' Application → Persistence
ShiftTemplateService --> IShiftTemplateRepository : uses for persistence
ShiftTemplateService --> IUnitOfWork : uses for transactions

ShiftAssignmentService --> IShiftAssignmentRepository : uses for persistence
ShiftAssignmentService --> IShiftTemplateRepository : validates templates
ShiftAssignmentService --> IUnitOfWork : uses for transactions
ShiftAssignmentService --> IShiftLiveRealtimePublisher : publishes live updates

AttendanceService --> IAttendanceRepository : uses for persistence
AttendanceService --> IShiftAssignmentRepository : validates assignments
AttendanceService --> IUnitOfWork : uses for transactions
AttendanceService --> IShiftSettingsProvider : reads attendance config
AttendanceService --> IShiftLiveRealtimePublisher : publishes live updates

' Persistence → Domain
ShiftTemplateRepository ..> ShiftTemplate : persists
ShiftAssignmentRepository ..> ShiftAssignment : persists
AttendanceRepository ..> AttendanceRecord : persists

@enduml
