@startuml
autonumber
title 2.16.2.6 Create Assignment
skinparam sequence {
    ParticipantBackgroundColor #ffffff
    ActorBackgroundColor #ffffff
}

actor ":User" as U
participant ":FE Layer" as Client
participant ":ShiftController" as Ctrl
participant ":ShiftAssignmentService" as Svc
participant ":IShiftTemplateRepository" as TRepo
participant ":IShiftAssignmentRepository" as ARepo
participant ":IAccountRepository" as AccRepo
participant ":ILookupResolver" as Lookup
participant ":INotificationService" as Notif
participant ":IShiftLiveRealtimePublisher" as RT
participant ":IUnitOfWork" as UoW
participant ":Database" as DB

activate U
U ->> Client : Submit create assignment form
activate Client
Client ->> Ctrl : POST /api/shifts/assignments\n(CreateShiftAssignmentRequest)
activate Ctrl
Ctrl ->> Svc : CreateAssignmentAsync(request, staffId, ct)
activate Svc

Svc ->> TRepo : GetByIdAsync(templateId)
activate TRepo
TRepo ->> DB : Fetch shift template by ID
activate DB
DB -->> TRepo : Return shift template or empty
deactivate DB
TRepo -->> Svc : ShiftTemplate?
deactivate TRepo
alt#White Template not found or inactive
    Svc -->> Ctrl : throw NotFoundException / ValidationException
    Ctrl -->> Client : 404 / 400
    Client -->> U : Display error
end

Svc ->> AccRepo : FindByIdWithRoleAsync(staffId)
activate AccRepo
AccRepo ->> DB : Fetch staff account by ID with role
activate DB
DB -->> AccRepo : Return staff account or empty
deactivate DB
AccRepo -->> Svc : StaffAccount?
deactivate AccRepo
alt#White Staff not found
    Svc -->> Ctrl : throw NotFoundException
    Ctrl -->> Client : 404
    Client -->> U : Display error
end

alt#White Planned start time is after or equal to planned end time
    Svc -->> Ctrl : throw ValidationException
    Ctrl -->> Client : 400
    Client -->> U : Display validation error
end

Svc ->> ARepo : GetAlreadyAssignedStaffIdsAsync(templateId, workDate, [staffId])
activate ARepo
ARepo -->> Svc : List<long>
deactivate ARepo
alt#White Staff already assigned to this template on this date
    Svc -->> Ctrl : throw ConflictException
    Ctrl -->> Client : 409 Conflict
    Client -->> U : Display conflict error
end

Svc ->> ARepo : HasOverlappingAssignmentAsync(staffId, workDate, start, end)
activate ARepo
ARepo -->> Svc : bool
deactivate ARepo
alt#White Overlapping shift found
    Svc -->> Ctrl : throw ConflictException
    Ctrl -->> Client : 409 Conflict
    Client -->> U : Display conflict error
end

Svc ->> Lookup : ToShiftAssignmentStatusIdAsync(DRAFT or ASSIGNED)
activate Lookup
Lookup -->> Svc : uint statusLvId
deactivate Lookup

Svc ->> ARepo : Add(ShiftAssignment)
Svc ->> UoW : SaveChangesAsync()
activate UoW
UoW ->> DB : Insert new shift assignment record
activate DB
DB -->> UoW : OK
deactivate DB
UoW -->> Svc : OK
deactivate UoW

opt#White Not a draft, published immediately
    Svc ->> Notif : PublishAsync(SHIFT_ASSIGNED notification)
    activate Notif
    Notif -->> Svc : OK
    deactivate Notif
end

Svc ->> ARepo : GetByIdWithDetailsAsync(newId)
activate ARepo
ARepo -->> Svc : ShiftAssignment
deactivate ARepo

Svc ->> RT : PublishBoardChangedAsync(assignment_created)
activate RT
RT -->> Svc : OK
deactivate RT

Svc -->> Ctrl : ShiftAssignmentDetailDto
deactivate Svc
Ctrl -->> Client : 201 Created ApiResponse<ShiftAssignmentDetailDto>
deactivate Ctrl
Client -->> U : Display created assignment
deactivate Client
deactivate U

@enduml
