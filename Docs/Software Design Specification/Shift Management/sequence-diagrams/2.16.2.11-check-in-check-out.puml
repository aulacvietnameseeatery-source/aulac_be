@startuml
autonumber
title 2.16.2.11 Check-in / Check-out
skinparam sequence {
    ParticipantBackgroundColor #ffffff
    ActorBackgroundColor #ffffff
}

actor ":User" as U
participant ":FE Layer" as Client
participant ":ShiftController" as Ctrl
participant ":AttendanceService" as Svc
participant ":IAttendanceRepository" as ARepo
participant ":IShiftAssignmentRepository" as SARepo
participant ":IShiftSettingsProvider" as Settings
participant ":ILookupResolver" as Lookup
participant ":INotificationService" as Notif
participant ":IShiftLiveRealtimePublisher" as RT
participant ":IUnitOfWork" as UoW
participant ":Database" as DB

== Staff Check-In ==

activate U
U ->> Client : Request check-in for shift
activate Client
Client ->> Ctrl : POST /api/shifts/assignments/{id}/check-in
activate Ctrl
Ctrl ->> Svc : CheckInAsync(assignmentId, staffId, ct)
activate Svc

Svc ->> SARepo : GetByIdWithDetailsAsync(assignmentId)
activate SARepo
SARepo ->> DB : Fetch shift assignment with\ntemplate, staff, status, and attendance
activate DB
DB -->> SARepo : Return shift assignment or empty
deactivate DB
SARepo -->> Svc : ShiftAssignment?
deactivate SARepo

alt#White Assignment not found
    Svc -->> Ctrl : throw NotFoundException
    Ctrl -->> Client : 404 Not Found
    Client -->> U : Display not found error
end
alt#White Not own shift (StaffId != caller)
    Svc -->> Ctrl : throw ForbiddenException
    Ctrl -->> Client : 403 Forbidden
    Client -->> U : Display forbidden error
end
alt#White Cancelled assignment (IsActive == false)
    Svc -->> Ctrl : throw ValidationException
    Ctrl -->> Client : 400 Bad Request
    Client -->> U : Display validation error
end

Svc ->> ARepo : GetByAssignmentIdAsync(assignmentId)
activate ARepo
ARepo ->> DB : Fetch attendance record by assignment ID
activate DB
DB -->> ARepo : Return attendance record or empty
deactivate DB
ARepo -->> Svc : AttendanceRecord?
deactivate ARepo

alt#White Already checked in (ActualCheckInAt != null)
    Svc -->> Ctrl : throw ConflictException
    Ctrl -->> Client : 409 Conflict
    Client -->> U : Display conflict error
end

Svc ->> Settings : GetAllowedEarlyCheckInMinutesAsync()
activate Settings
Settings -->> Svc : int allowedEarlyMinutes
deactivate Settings

alt#White Too early to check in
    Svc -->> Ctrl : throw ValidationException("Too early to check in")
    Ctrl -->> Client : 400 Bad Request
    Client -->> U : Display validation error
end
alt#White Shift already ended
    Svc -->> Ctrl : throw ValidationException("Shift has already ended")
    Ctrl -->> Client : 400 Bad Request
    Client -->> U : Display validation error
end

Svc ->> Settings : GetLateGraceMinutesAsync()
activate Settings
Settings -->> Svc : int lateGraceMinutes
deactivate Settings

Svc ->> Lookup : ToAttendanceStatusIdAsync(ACTIVE or LATE)
activate Lookup
Lookup -->> Svc : uint statusLvId
deactivate Lookup

alt#White Existing record (SCHEDULED status)
    Svc ->> ARepo : Update existing attendance record
else No existing record
    Svc ->> ARepo : Add(new AttendanceRecord)
end

Svc ->> UoW : SaveChangesAsync()
activate UoW
UoW ->> DB : Insert or update attendance record\nwith check-in data
activate DB
DB -->> UoW : OK
deactivate DB
UoW -->> Svc : OK
deactivate UoW

opt#White Staff is late (isLate == true)
    Svc ->> Notif : PublishAsync(ATTENDANCE_ALERT - Late Check-in)
    activate Notif
    Notif -->> Svc : OK
    deactivate Notif
end

Svc ->> RT : PublishBoardChangedAsync(attendance_checked_in)
activate RT
RT -->> Svc : OK
deactivate RT

Svc -->> Ctrl : AttendanceRecordDto
deactivate Svc
Ctrl -->> Client : 200 OK ApiResponse<AttendanceRecordDto>
deactivate Ctrl
Client -->> U : Display check-in confirmation
deactivate Client

== Staff Check-Out ==

U ->> Client : Request check-out for shift
activate Client
Client ->> Ctrl : POST /api/shifts/assignments/{id}/check-out
activate Ctrl
Ctrl ->> Svc : CheckOutAsync(assignmentId, staffId, ct)
activate Svc

Svc ->> ARepo : GetByAssignmentIdAsync(assignmentId)
activate ARepo
ARepo ->> DB : Fetch attendance record by assignment ID
activate DB
DB -->> ARepo : Return attendance record or empty
deactivate DB
ARepo -->> Svc : AttendanceRecord?
deactivate ARepo

alt#White No attendance record
    Svc -->> Ctrl : throw NotFoundException
    Ctrl -->> Client : 404 Not Found
    Client -->> U : Display not found error
end
alt#White Not checked in yet (ActualCheckInAt == null)
    Svc -->> Ctrl : throw ValidationException
    Ctrl -->> Client : 400 Bad Request
    Client -->> U : Display validation error
end
alt#White Already checked out (ActualCheckOutAt != null)
    Svc -->> Ctrl : throw ConflictException
    Ctrl -->> Client : 409 Conflict
    Client -->> U : Display conflict error
end

Svc ->> SARepo : GetByIdAsync(assignmentId)
activate SARepo
SARepo ->> DB : Fetch shift assignment by ID
activate DB
DB -->> SARepo : Return shift assignment
deactivate DB
SARepo -->> Svc : ShiftAssignment
deactivate SARepo

alt#White Not own shift (StaffId != caller)
    Svc -->> Ctrl : throw ForbiddenException
    Ctrl -->> Client : 403 Forbidden
    Client -->> U : Display forbidden error
end

Svc ->> Settings : GetEarlyLeaveBufferMinutesAsync()
activate Settings
Settings -->> Svc : int earlyLeaveBuffer
deactivate Settings

Svc ->> Lookup : ToAttendanceStatusIdAsync(COMPLETED or EARLY_LEAVE)
activate Lookup
Lookup -->> Svc : uint statusLvId
deactivate Lookup

Svc ->> UoW : SaveChangesAsync()
activate UoW
UoW ->> DB : Update attendance record with check-out data
activate DB
DB -->> UoW : OK
deactivate DB
UoW -->> Svc : OK
deactivate UoW

opt#White Early leave detected (isEarlyLeave == true)
    Svc ->> Notif : PublishAsync(ATTENDANCE_ALERT - Early Leave)
    activate Notif
    Notif -->> Svc : OK
    deactivate Notif
end

Svc ->> RT : PublishBoardChangedAsync(attendance_checked_out)
activate RT
RT -->> Svc : OK
deactivate RT

Svc -->> Ctrl : AttendanceRecordDto
deactivate Svc
Ctrl -->> Client : 200 OK ApiResponse<AttendanceRecordDto>
deactivate Ctrl
Client -->> U : Display check-out confirmation
deactivate Client
deactivate U

@enduml
