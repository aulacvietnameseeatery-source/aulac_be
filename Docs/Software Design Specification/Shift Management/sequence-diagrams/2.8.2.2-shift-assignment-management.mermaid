sequenceDiagram
    autonumber
    title 2.8.2.2 Shift Assignment Management

    actor Client
    participant Ctrl as ShiftController
    participant Svc as ShiftAssignmentService
    participant TRepo as IShiftTemplateRepository
    participant ARepo as IShiftAssignmentRepository
    participant AccRepo as IAccountRepository
    participant Lookup as ILookupResolver
    participant Notif as INotificationService
    participant RT as IShiftLiveRealtimePublisher
    participant UoW as IUnitOfWork
    participant DB as Database

    %% -- GET /api/shifts/assignments --
    rect rgba(0,0,0,0)
    note over Client,DB: List Assignments (paged)
    Client->>+Ctrl: GET /api/shifts/assignments?filters
    Ctrl->>+Svc: GetAssignmentsAsync(request)
    Svc->>+ARepo: GetAssignmentsAsync(request)
    ARepo->>+DB: SELECT ... with filters and paging
    DB-->>-ARepo: (List ShiftAssignment, int TotalCount)
    ARepo-->>-Svc: (Items, TotalCount)
    Svc-->>-Ctrl: (List ShiftAssignmentListDto, TotalCount)
    Ctrl-->>-Client: 200 OK PagedResult
    end

    %% -- GET /api/shifts/assignments/{id} --
    rect rgba(0,0,0,0)
    note over Client,DB: Get Assignment Detail
    Client->>+Ctrl: GET /api/shifts/assignments/{id}
    Ctrl->>+Svc: GetByIdAsync(id)
    Svc->>+ARepo: GetByIdWithDetailsAsync(id)
    ARepo->>+DB: SELECT ... with Includes
    DB-->>-ARepo: ShiftAssignment?
    ARepo-->>-Svc: ShiftAssignment?
    alt Not found
        Svc-->>Ctrl: throw NotFoundException
        Ctrl-->>Client: 404 Not Found
    else Found
        Svc-->>-Ctrl: ShiftAssignmentDetailDto
        Ctrl-->>-Client: 200 OK ApiResponse
    end
    end

    %% -- POST /api/shifts/assignments --
    rect rgba(0,0,0,0)
    note over Client,DB: Create Single Assignment
    Client->>+Ctrl: POST /api/shifts/assignments (CreateShiftAssignmentRequest)
    Ctrl->>+Svc: CreateAssignmentAsync(request, staffId)
    Svc->>+TRepo: GetByIdAsync(templateId)
    TRepo-->>-Svc: ShiftTemplate?
    alt Template not found or inactive
        Svc-->>Ctrl: throw NotFoundException / ValidationException
        Ctrl-->>Client: 404 / 400
    end
    Svc->>+AccRepo: FindByIdWithRoleAsync(staffId)
    AccRepo-->>-Svc: StaffAccount?
    alt Staff not found
        Svc-->>Ctrl: throw NotFoundException
        Ctrl-->>Client: 404
    end
    Svc->>+ARepo: GetAlreadyAssignedStaffIdsAsync(templateId, workDate, staffIds)
    ARepo-->>-Svc: List of long
    alt Already assigned
        Svc-->>Ctrl: throw ConflictException
        Ctrl-->>Client: 409 Conflict
    end
    Svc->>+ARepo: HasOverlappingAssignmentAsync(staffId, workDate, start, end)
    ARepo-->>-Svc: bool
    alt Overlap found
        Svc-->>Ctrl: throw ConflictException
        Ctrl-->>Client: 409 Conflict
    end
    Svc->>+Lookup: ToShiftAssignmentStatusIdAsync(DRAFT or ASSIGNED)
    Lookup-->>-Svc: uint statusLvId
    Svc->>ARepo: Add(ShiftAssignment)
    Svc->>+UoW: SaveChangesAsync()
    UoW->>+DB: INSERT INTO shift_assignment
    DB-->>-UoW: OK
    UoW-->>-Svc: OK
    opt Not Draft
        Svc->>+Notif: PublishAsync(SHIFT_ASSIGNED notification)
        Notif-->>-Svc: OK
    end
    Svc->>+RT: PublishBoardChangedAsync(assignment_created)
    RT-->>-Svc: OK
    Svc-->>-Ctrl: ShiftAssignmentDetailDto
    Ctrl-->>-Client: 201 Created ApiResponse
    end

    %% -- POST /api/shifts/assignments/bulk --
    rect rgba(0,0,0,0)
    note over Client,DB: Bulk Create Assignments
    Client->>+Ctrl: POST /api/shifts/assignments/bulk (BulkCreateAssignmentRequest)
    Ctrl->>+Svc: BulkCreateAssignmentsAsync(request, staffId)
    Svc->>+TRepo: GetByIdAsync(templateId)
    TRepo-->>-Svc: ShiftTemplate
    loop For each staffId in StaffIds
        Svc->>+AccRepo: FindByIdWithRoleAsync(staffId)
        AccRepo-->>-Svc: StaffAccount
    end
    loop For each workDate in effectiveDates
        Svc->>+ARepo: GetAlreadyAssignedStaffIdsAsync(...)
        ARepo-->>-Svc: alreadyAssigned
        loop For each valid staffId
            Svc->>+ARepo: HasOverlappingAssignmentAsync(...)
            ARepo-->>-Svc: bool (skip if true)
        end
    end
    Svc->>ARepo: AddRange(entities)
    Svc->>+UoW: SaveChangesAsync()
    UoW->>+DB: INSERT multiple rows
    DB-->>-UoW: OK
    UoW-->>-Svc: OK
    opt Not Draft
        loop For each entity
            Svc->>Notif: PublishAsync(SHIFT_ASSIGNED)
        end
    end
    Svc->>RT: PublishBoardChangedAsync(assignments_bulk_created)
    Svc-->>-Ctrl: List ShiftAssignmentDetailDto
    Ctrl-->>-Client: 201 Created ApiResponse
    end

    %% -- PUT /api/shifts/assignments/{id} --
    rect rgba(0,0,0,0)
    note over Client,DB: Update Assignment
    Client->>+Ctrl: PUT /api/shifts/assignments/{id} (UpdateShiftAssignmentRequest)
    Ctrl->>+Svc: UpdateAssignmentAsync(id, request, staffId)
    Svc->>+ARepo: GetByIdAsync(id)
    ARepo-->>-Svc: ShiftAssignment?
    alt Not found or cancelled or already checked in
        Svc-->>Ctrl: throw Exception
        Ctrl-->>Client: 404 / 400 / 409
    end
    opt Time changed
        Svc->>+ARepo: HasOverlappingAssignmentAsync(...)
        ARepo-->>-Svc: bool
        alt Overlap
            Svc-->>Ctrl: throw ConflictException
            Ctrl-->>Client: 409
        end
    end
    Svc->>+UoW: SaveChangesAsync()
    UoW->>+DB: UPDATE shift_assignment
    DB-->>-UoW: OK
    UoW-->>-Svc: OK
    Svc->>RT: PublishBoardChangedAsync(assignment_updated)
    Svc-->>-Ctrl: ShiftAssignmentDetailDto
    Ctrl-->>-Client: 200 OK ApiResponse
    end

    %% -- DELETE /api/shifts/assignments/{id} --
    rect rgba(0,0,0,0)
    note over Client,DB: Cancel Assignment
    Client->>+Ctrl: DELETE /api/shifts/assignments/{id}
    Ctrl->>+Svc: CancelAssignmentAsync(id)
    Svc->>+ARepo: GetByIdAsync(id)
    ARepo-->>-Svc: ShiftAssignment?
    alt Not found or already cancelled
        Svc-->>Ctrl: throw Exception
        Ctrl-->>Client: 404 / 400
    end
    alt Already checked in
        Svc-->>Ctrl: throw ConflictException
        Ctrl-->>Client: 409
    end
    Svc->>+Lookup: ToShiftAssignmentStatusIdAsync(CANCELLED)
    Lookup-->>-Svc: uint statusLvId
    Svc->>+UoW: SaveChangesAsync()
    UoW->>+DB: UPDATE ... SET IsActive=0, StatusLvId=CANCELLED
    DB-->>-UoW: OK
    UoW-->>-Svc: OK
    Svc->>RT: PublishBoardChangedAsync(assignment_cancelled)
    Svc-->>-Ctrl: void
    Ctrl-->>-Client: 204 No Content
    end

    %% -- POST /api/shifts/assignments/publish --
    rect rgba(0,0,0,0)
    note over Client,DB: Publish Draft Assignments
    Client->>+Ctrl: POST /api/shifts/assignments/publish (PublishAssignmentsRequest)
    Ctrl->>+Svc: PublishAssignmentsAsync(request, staffId)
    alt By IDs
        Svc->>+ARepo: GetByIdsWithDetailsAsync(ids)
        ARepo-->>-Svc: List ShiftAssignment (filter DRAFTs)
    else By date range
        Svc->>+ARepo: GetDraftAssignmentsAsync(from, to)
        ARepo-->>-Svc: List ShiftAssignment
    end
    Svc->>+Lookup: ToShiftAssignmentStatusIdAsync(ASSIGNED)
    Lookup-->>-Svc: uint
    loop For each draft
        Note right of Svc: Set status DRAFT to ASSIGNED
    end
    Svc->>+UoW: SaveChangesAsync()
    UoW->>+DB: UPDATE shift_assignment SET status=ASSIGNED
    DB-->>-UoW: OK
    UoW-->>-Svc: OK
    loop For each published
        Svc->>Notif: PublishAsync(SHIFT_ASSIGNED)
    end
    Svc->>RT: PublishBoardChangedAsync(assignments_published)
    Svc-->>-Ctrl: List ShiftAssignmentListDto
    Ctrl-->>-Client: 200 OK ApiResponse
    end

    %% -- POST /api/shifts/assignments/copy-week --
    rect rgba(0,0,0,0)
    note over Client,DB: Copy Week
    Client->>+Ctrl: POST /api/shifts/assignments/copy-week (CopyWeekRequest)
    Ctrl->>+Svc: CopyWeekAsync(request, staffId)
    Svc->>+ARepo: GetWeekAssignmentsAsync(sourceWeekStart)
    ARepo->>+DB: SELECT ... WHERE date in source week
    DB-->>-ARepo: List ShiftAssignment
    ARepo-->>-Svc: sourceAssignments
    loop For each source assignment
        Svc->>ARepo: GetAlreadyAssignedStaffIdsAsync(...)
        Svc->>ARepo: HasOverlappingAssignmentAsync(...)
        Note right of Svc: Clone with offset dates, skip conflicts
    end
    Svc->>ARepo: AddRange(newEntities)
    Svc->>+UoW: SaveChangesAsync()
    UoW->>+DB: INSERT copied assignments
    DB-->>-UoW: OK
    UoW-->>-Svc: OK
    Svc->>RT: PublishBoardChangedAsync(assignments_copied)
    Svc-->>-Ctrl: List ShiftAssignmentListDto
    Ctrl-->>-Client: 201 Created ApiResponse
    end

    %% -- PUT /api/shifts/assignments/{id}/reassign --
    rect rgba(0,0,0,0)
    note over Client,DB: Reassign Shift
    Client->>+Ctrl: PUT /api/shifts/assignments/{id}/reassign (ReassignRequest)
    Ctrl->>+Svc: ReassignAsync(id, request, staffId)
    Svc->>+ARepo: GetByIdWithDetailsAsync(id)
    ARepo-->>-Svc: ShiftAssignment?
    alt Not found / cancelled / checked in
        Svc-->>Ctrl: throw Exception
        Ctrl-->>Client: 404 / 400 / 409
    end
    Svc->>+AccRepo: FindByIdWithRoleAsync(newStaffId)
    AccRepo-->>-Svc: StaffAccount?
    Svc->>+ARepo: HasOverlappingAssignmentAsync(newStaffId, ...)
    ARepo-->>-Svc: bool
    alt Overlap
        Svc-->>Ctrl: throw ConflictException
        Ctrl-->>Client: 409
    end
    Note right of Svc: Update StaffId, WorkDate, Notes
    Svc->>+UoW: SaveChangesAsync()
    UoW->>+DB: UPDATE shift_assignment
    DB-->>-UoW: OK
    UoW-->>-Svc: OK
    Svc->>Notif: PublishAsync(SHIFT_ASSIGNED to new staff)
    Svc->>RT: PublishBoardChangedAsync(assignment_reassigned)
    Svc-->>-Ctrl: ShiftAssignmentDetailDto
    Ctrl-->>-Client: 200 OK ApiResponse
    end

    %% -- POST /api/shifts/assignments/{id}/confirm --
    rect rgba(0,0,0,0)
    note over Client,DB: Confirm Own Assignment
    Client->>+Ctrl: POST /api/shifts/assignments/{id}/confirm
    Ctrl->>+Svc: ConfirmAssignmentAsync(id, staffId)
    Svc->>+ARepo: GetByIdWithDetailsAsync(id)
    ARepo-->>-Svc: ShiftAssignment?
    alt Not own shift
        Svc-->>Ctrl: throw ForbiddenException
        Ctrl-->>Client: 403
    end
    alt Not in ASSIGNED status
        Svc-->>Ctrl: throw ValidationException
        Ctrl-->>Client: 400
    end
    Svc->>+Lookup: ToShiftAssignmentStatusIdAsync(CONFIRMED)
    Lookup-->>-Svc: uint
    Svc->>+UoW: SaveChangesAsync()
    UoW->>+DB: UPDATE ... SET status=CONFIRMED
    DB-->>-UoW: OK
    UoW-->>-Svc: OK
    Svc->>RT: PublishBoardChangedAsync(assignment_confirmed)
    Svc-->>-Ctrl: ShiftAssignmentDetailDto
    Ctrl-->>-Client: 200 OK ApiResponse
    end

    %% -- GET /api/shifts/team-schedule --
    rect rgba(0,0,0,0)
    note over Client,DB: Get Team Schedule
    Client->>+Ctrl: GET /api/shifts/team-schedule?weekStart&weekEnd
    Ctrl->>+Svc: GetTeamScheduleAsync(request)
    Svc->>+ARepo: GetTeamScheduleAsync(weekStart, weekEnd, templateId?)
    ARepo->>+DB: SELECT ... WHERE date BETWEEN weekStart AND weekEnd
    DB-->>-ARepo: List ShiftAssignment
    ARepo-->>-Svc: List ShiftAssignment
    Svc-->>-Ctrl: List ShiftAssignmentListDto
    Ctrl-->>-Client: 200 OK ApiResponse
    end

    %% -- GET /api/shifts/my-shifts --
    rect rgba(0,0,0,0)
    note over Client,DB: Get My Shifts (staff self-view)
    Client->>+Ctrl: GET /api/shifts/my-shifts?filters
    Ctrl->>+Svc: GetMyShiftsAsync(staffId, request)
    Note right of Svc: Forces StaffId filter = caller
    Svc->>+ARepo: GetAssignmentsAsync(request)
    ARepo->>+DB: SELECT ... WHERE StaffId = caller
    DB-->>-ARepo: (Items, TotalCount)
    ARepo-->>-Svc: (Items, TotalCount)
    Svc-->>-Ctrl: (List ShiftAssignmentDetailDto, TotalCount)
    Ctrl-->>-Client: 200 OK PagedResult
    end