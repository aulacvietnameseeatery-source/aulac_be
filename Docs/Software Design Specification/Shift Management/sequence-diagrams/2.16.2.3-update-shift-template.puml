@startuml
autonumber
title 2.16.2.3 Update Shift Template
skinparam sequence {
    ParticipantBackgroundColor #ffffff
    ActorBackgroundColor #ffffff
}

actor ":User" as U
participant ":FE Layer" as Client
participant ":ShiftController" as Ctrl
participant ":ShiftTemplateService" as Svc
participant ":IShiftTemplateRepository" as Repo
participant ":IUnitOfWork" as UoW
participant ":Database" as DB

activate U
U ->> Client : Submit update shift template form
activate Client
Client ->> Ctrl : PUT /api/shifts/templates/{id}\n(UpdateShiftTemplateRequest)
activate Ctrl
Ctrl ->> Svc : UpdateAsync(id, request, staffId, ct)
activate Svc

Svc ->> Repo : GetByIdAsync(id)
activate Repo
Repo ->> DB : Fetch shift template by ID
activate DB
DB -->> Repo : Return shift template or empty
deactivate DB
Repo -->> Svc : ShiftTemplate?
deactivate Repo

alt#White Not found
    Svc -->> Ctrl : throw NotFoundException
    Ctrl -->> Client : 404 Not Found
    Client -->> U : Display not found error
end

opt#White Template name is being changed
    Svc ->> Repo : ExistsByNameAsync(newName, excludeId: id)
    activate Repo
    Repo ->> DB : Check if another template with this name exists
    activate DB
    DB -->> Repo : Return existence result
    deactivate DB
    Repo -->> Svc : bool
    deactivate Repo
    alt#White Name already exists
        Svc -->> Ctrl : throw ConflictException
        Ctrl -->> Client : 409 Conflict
        Client -->> U : Display conflict error
    end
end

alt#White Effective start time is after or equal to end time
    Svc -->> Ctrl : throw ValidationException
    Ctrl -->> Client : 400 Bad Request
    Client -->> U : Display validation error
end

Svc ->> UoW : SaveChangesAsync()
activate UoW
UoW ->> DB : Update shift template record
activate DB
DB -->> UoW : OK
deactivate DB
UoW -->> Svc : OK
deactivate UoW

Svc ->> Repo : GetByIdAsync(id)
activate Repo
Repo ->> DB : Reload shift template with navigation properties
activate DB
DB -->> Repo : Return updated shift template
deactivate DB
Repo -->> Svc : ShiftTemplate
deactivate Repo

Svc -->> Ctrl : ShiftTemplateDetailDto
deactivate Svc
Ctrl -->> Client : 200 OK ApiResponse<ShiftTemplateDetailDto>
deactivate Ctrl
Client -->> U : Display updated shift template
deactivate Client
deactivate U

@enduml
