@startuml
autonumber
title 2.16.2.5 View Assignment List
skinparam sequence {
    ParticipantBackgroundColor #ffffff
    ActorBackgroundColor #ffffff
}

actor ":User" as U
participant ":ShiftAssignmentListPage" as Client
participant ":ShiftController" as Ctrl
participant ":ShiftAssignmentService" as Svc
participant ":IShiftAssignmentRepository" as ARepo
participant ":Database" as DB

activate U
U ->> Client : Open shift assignment list page
activate Client
Client ->> Ctrl : GET /api/shifts/assignments?filters
activate Ctrl
Ctrl ->> Svc : GetAssignmentsAsync(request, ct)
activate Svc

Svc ->> ARepo : GetAssignmentsAsync(request)
activate ARepo
ARepo ->> DB : Query shift assignments joined with\ntemplate, staff, status, and attendance\napplying filters and paging
activate DB
DB -->> ARepo : Return paginated assignment list with total count
deactivate DB
ARepo -->> Svc : (Items, TotalCount)
deactivate ARepo

Svc -->> Ctrl : (List<ShiftAssignmentListDto>, TotalCount)
deactivate Svc
Ctrl -->> Client : 200 OK PagedResult<ShiftAssignmentListDto>
deactivate Ctrl
Client -->> U : Display assignment list
deactivate Client
deactivate U

@enduml
