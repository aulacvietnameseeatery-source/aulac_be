@startuml
autonumber
title 2.8.2.4 Shift Live Board and Reports

actor User as U
participant "FE Layer" as Client
note over U, Client : User interacts through FE before backend calls
U -> Client : uses web app UI
participant "ShiftController" as Ctrl
participant "ShiftAssignmentService" as ASvc
participant "AttendanceService" as AtSvc
participant "IShiftAssignmentRepository" as ARepo
participant "IOrderRepository" as ORepo
participant "IShiftLiveRealtimePublisher" as RT
database "Database" as DB

== Get Live Board ==

Client -> Ctrl : GET /api/shifts/live-board?fromDate&toDate&filters
activate Ctrl
Ctrl -> ASvc : GetLiveBoardAsync(request)
activate ASvc

note right of ASvc : Build liveRequest with PageSize up to 200

ASvc -> ARepo : GetAssignmentsAsync(liveRequest)
activate ARepo
ARepo -> DB : SELECT shift_assignment with includes\n(Template, Staff, Status, Attendance)\nfiltered and paged
activate DB
DB --> ARepo : (List<ShiftAssignment>, TotalCount)
deactivate DB
ARepo --> ASvc : (Items, TotalCount)
deactivate ARepo

alt No assignments found
    ASvc --> Ctrl : empty List<ShiftLiveBoardItemDto>
    Ctrl --> Client : 200 OK []
end

note right of ASvc : Collect distinct staffIds\nand calculate date range window

ASvc -> ORepo : GetShiftLiveOrderSnapshotsAsync(queryStart, queryEnd, staffIds)
activate ORepo
ORepo -> DB : SELECT orders with revenue, items,\npaid bills within the shift window
activate DB
DB --> ORepo : List<ShiftLiveOrderSnapshotDto>
deactivate DB
ORepo --> ASvc : orderSnapshots
deactivate ORepo

ASvc -> ORepo : GetShiftLiveIssueSnapshotsAsync(queryStart, queryEnd, staffIds)
activate ORepo
ORepo -> DB : SELECT service_error events\nWHERE type = issue in window
activate DB
DB --> ORepo : List<ShiftLiveIssueSnapshotDto>
deactivate DB
ORepo --> ASvc : issueSnapshots
deactivate ORepo

note right of ASvc : Group orders and issues by StaffId

loop For each ShiftAssignment
    note right of ASvc : MapToLiveBoardDto:\n- Compute LiveStatusCode (ON_DUTY / WAITING / COMPLETED / NOT_CHECKED_IN)\n- Determine HasAlert (late, absent, early leave, issues)\n- Calculate KPIs: OrdersHandled, PaidBills, Revenue,\n  ItemsCompleted, PendingTickets, IssueCount
end

ASvc --> Ctrl : List<ShiftLiveBoardItemDto>
deactivate ASvc
Ctrl --> Client : 200 OK ApiResponse<List<ShiftLiveBoardItemDto>>
deactivate Ctrl

== Real-time Live Board Updates (SignalR) ==

note right of RT : Triggered on any assignment or attendance change:\nassignment_created, attendance_checked_in,\nattendance_checked_out, assignment_cancelled, etc.

RT -> Client : ShiftLiveRealtimeEventDto via SignalR Hub
note left of Client : FE invalidates live board query cache\nand re-fetches data

== Report KPI Snapshot ==

Client -> Ctrl : GET /api/shifts/reports/snapshot?fromDate&toDate
activate Ctrl
Ctrl -> AtSvc : GetReportSnapshotAsync(fromDate, toDate)
activate AtSvc

AtSvc -> ARepo : GetAttendanceReportAsync(request with PageSize=1)
activate ARepo
ARepo -> DB : COUNT total attendance rows\nin date range
activate DB
DB --> ARepo : (_, attendanceCount)
deactivate DB
ARepo --> AtSvc : (_, attendanceCount)
deactivate ARepo

AtSvc -> ARepo : GetWorkedHoursDataAsync(fromDate, toDate, staffId: null)
activate ARepo
ARepo -> DB : SELECT assignments with Attendance\nWHERE Attendance.WorkedMinutes > 0
activate DB
DB --> ARepo : List<ShiftAssignment>
deactivate DB
ARepo --> AtSvc : workedData
deactivate ARepo
note right of AtSvc : Count distinct StaffIds who worked

AtSvc -> ARepo : GetExceptionDataAsync(fromDate, toDate, staffId: null)
activate ARepo
ARepo -> DB : SELECT assignments WHERE status IN\n(LATE, ABSENT, EARLY_LEAVE)\nOR IsManualAdjustment = true
activate DB
DB --> ARepo : List<ShiftAssignment>
deactivate DB
ARepo --> AtSvc : exceptionData
deactivate ARepo
note right of AtSvc : Count total exceptions

AtSvc --> Ctrl : ShiftReportSnapshotDto
deactivate AtSvc
Ctrl --> Client : 200 OK ApiResponse<ShiftReportSnapshotDto>
deactivate Ctrl

== Attendance Report (paged) ==

Client -> Ctrl : GET /api/shifts/reports/attendance?filters
activate Ctrl
Ctrl -> AtSvc : GetAttendanceReportAsync(request)
activate AtSvc

AtSvc -> ARepo : GetAttendanceReportAsync(request)
activate ARepo
ARepo -> DB : SELECT shift_assignment\nJOIN attendance_record\nwith filters, paging, includes
activate DB
DB --> ARepo : (List<ShiftAssignment>, TotalCount)
deactivate DB
ARepo --> AtSvc : (Items, TotalCount)
deactivate ARepo

note right of AtSvc : Map to AttendanceReportRowDto:\nStaffName, WorkDate, TemplateName,\nPlanned times, Attendance status,\nActual times, LateMinutes, WorkedMinutes

AtSvc --> Ctrl : (List<AttendanceReportRowDto>, TotalCount)
deactivate AtSvc
Ctrl --> Client : 200 OK PagedResult<AttendanceReportRowDto>
deactivate Ctrl

== Worked Hours Report ==

Client -> Ctrl : GET /api/shifts/reports/worked-hours?fromDate&toDate&staffId
activate Ctrl
Ctrl -> AtSvc : GetWorkedHoursReportAsync(fromDate, toDate, staffId?)
activate AtSvc

AtSvc -> ARepo : GetWorkedHoursDataAsync(fromDate, toDate, staffId)
activate ARepo
ARepo -> DB : SELECT assignments with Attendance\nWHERE WorkDate BETWEEN @from AND @to
activate DB
DB --> ARepo : List<ShiftAssignment>
deactivate DB
ARepo --> AtSvc : data
deactivate ARepo

note right of AtSvc : Group by StaffId:\n- Sum ScheduledMinutes (PlannedEnd - PlannedStart)\n- Sum WorkedMinutes (from Attendance)\n- Calculate VarianceMinutes = Worked - Scheduled\n- Count IncompleteRecords (missing checkout)

AtSvc --> Ctrl : List<WorkedHoursReportRowDto>
deactivate AtSvc
Ctrl --> Client : 200 OK ApiResponse<List<WorkedHoursReportRowDto>>
deactivate Ctrl

== Exceptions Report ==

Client -> Ctrl : GET /api/shifts/reports/exceptions?fromDate&toDate&staffId
activate Ctrl
Ctrl -> AtSvc : GetExceptionsReportAsync(fromDate, toDate, staffId?)
activate AtSvc

AtSvc -> ARepo : GetExceptionDataAsync(fromDate, toDate, staffId)
activate ARepo
ARepo -> DB : SELECT assignments WHERE\nAttendance status IN (LATE, ABSENT, EARLY_LEAVE)\nOR IsManualAdjustment = true
activate DB
DB --> ARepo : List<ShiftAssignment>
deactivate DB
ARepo --> AtSvc : data
deactivate ARepo

note right of AtSvc : Map to AttendanceExceptionReportRowDto:\n- ExceptionType (LATE, ABSENT, EARLY_LEAVE, MANUAL_ADJUSTMENT)\n- MinutesAffected (LateMinutes / EarlyLeaveMinutes)\n- IsManualAdjustment\n- ReviewerName

AtSvc --> Ctrl : List<AttendanceExceptionReportRowDto>
deactivate AtSvc
Ctrl --> Client : 200 OK ApiResponse<List<AttendanceExceptionReportRowDto>>
deactivate Ctrl

@enduml
