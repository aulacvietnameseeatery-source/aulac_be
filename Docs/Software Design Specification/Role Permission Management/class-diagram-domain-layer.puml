@startuml
title Role & Permission Management - Domain Layer Class Diagram


package "Domain Layer" {

    class Role <<Entity>> {
        +RoleId: long
        +RoleCode: string
        +RoleName: string
        +RoleStatusLvId: uint
    }

    class Permission <<Entity>> {
        +PermissionId: long
        +ScreenCode: string
        +ActionCode: string
    }

    class StaffAccount <<Entity>> {
        +AccountId: long
        +FullName: string
        +RoleId: long
    }

    class LookupValue <<Entity>> {
        +ValueId: uint
        +TypeId: ushort
        +ValueCode: string
        +ValueName: string
    }

    enum RoleStatusCode <<Enum>> {
        ACTIVE
        INACTIVE
    }
}

' ── Domain Relationships ──

Role "0..*" -- "0..*" Permission : many-to-many\n(role_permissions join table)
Role "1" o-- "0..*" StaffAccount : assigned to
Role "0..*" --> "1" LookupValue : RoleStatusLv\n(ROLE_STATUS)
@enduml
