@startuml
title Role & Permission Management - Presentation Layer Class Diagram


package "Presentation Layer" {

    class RoleController <<Controller>> {
        -_roleService: IRoleService
        -_logger: ILogger<RoleController>
        +GetRoles(query: PagedQuery): IActionResult
        +GetRoleDetail(id: long): IActionResult
        +CreateRole(request: CreateRoleRequestDto): IActionResult
        +UpdateRole(id: long, request: UpdateRoleRequestDto): IActionResult
        +DeleteRole(id: long): IActionResult
    }

    ' ── Request DTOs ──

    class PagedQuery <<DTO>> {
        +PageIndex: int
        +PageSize: int
        +Search: string?
    }

    class CreateRoleRequestDto <<DTO>> {
        +RoleName: string
        +IsActive: bool
        +PermissionIds: List<long>
    }

    class UpdateRoleRequestDto <<DTO>> {
        +RoleName: string
        +IsActive: bool
        +PermissionIds: List<long>
    }

    ' ── Response DTOs ──

    class RoleListItemDto <<DTO>> {
        +RoleId: long
        +RoleCode: string
        +RoleName: string
        +StaffCount: int
    }

    class RoleDetailDto <<DTO>> {
        +RoleId: long
        +RoleCode: string
        +RoleName: string
        +RoleStatusLvId: uint
        +IsActive: bool
        +PermissionGroups: List<PermissionGroupDto>
    }

    class PermissionGroupDto <<DTO>> {
        +ScreenCode: string
        +DisplayName: string
        +Permissions: List<PermissionItemDto>
    }

    class PermissionItemDto <<DTO>> {
        +PermissionId: long
        +ScreenCode: string
        +ActionCode: string
        +DisplayName: string
        +IsAssigned: bool
    }

    class "PagedResult<T>" as PagedResult <<DTO>> {
        +PageData: List<T>
        +PageIndex: int
        +PageSize: int
        +TotalCount: int
        +TotalPage: int
    }

    class "ApiResponse<T>" as ApiResponse <<DTO>> {
        +Success: bool
        +Code: int
        +SubCode: int
        +UserMessage: string?
        +SystemMessage: string?
        +Data: T
        +ServerTime: DateTimeOffset
    }
}

' External type stubs
interface IRoleService <<interface>>

' ── Relationships ──

RoleController --> IRoleService : uses

RoleController ..> PagedQuery : receives
RoleController ..> CreateRoleRequestDto : receives
RoleController ..> UpdateRoleRequestDto : receives
RoleController ..> RoleListItemDto : returns
RoleController ..> RoleDetailDto : returns
RoleController ..> PagedResult : returns
RoleController ..> ApiResponse : wraps response

RoleDetailDto *-- "0..*" PermissionGroupDto : contains
PermissionGroupDto *-- "1..*" PermissionItemDto : contains
@enduml
