@startuml
title Role & Permission Management Module - Domain Layer Class Diagram

package "Domain Layer" {

    class Role <<Entity>> {
        +RoleId : long
        +RoleCode : string
        +RoleName : string
        +RoleStatusLvId : uint
        +StaffAccounts : ICollection<StaffAccount>
        +RoleStatusLv : LookupValue?
        +Permissions : ICollection<Permission>
    }

    class Permission <<Entity>> {
        +PermissionId : long
        +ScreenCode : string
        +ActionCode : string
        +Roles : ICollection<Role>
    }

    enum RoleStatusCode <<Enum>> {
        ACTIVE
        INACTIVE
    }
}

package "Cross-Module Entities" <<Rectangle>> {

    class StaffAccount <<Entity>> {
        +RoleId : long?
    }

    class LookupValue <<Entity>> {
        +ValueId : uint
        +ValueCode : string
    }
}

Role "1" *-- "0..*" Permission : contains permissions
Role "1" o-- "0..*" StaffAccount : has assigned staff
Role "1" --> "0..1" LookupValue : references status via RoleStatusLvId

@enduml
