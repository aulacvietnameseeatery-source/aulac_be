@startuml
title 2.1.2.2 - Forgot Password

skinparam maxMessageSize 250
skinparam sequence {
    ParticipantBackgroundColor #ffffff
    ActorBackgroundColor #ffffff
}

actor ":User" as U
participant ":ForgotPasswordPage" as Client
participant ":AuthController" as Ctrl
participant ":AuthService" as Svc
participant ":IAccountRepository" as AcctRepo
participant ":IPasswordResetTokenStore" as TokenStore
participant ":IEmailTemplateService" as EmailTplSvc
participant ":IEmailQueue" as EmailQ
participant ":Database" as DB

autonumber

activate U

U ->> Client : Enter email address
activate Client

Client ->> Ctrl : POST /api/auth/forgot-password\n(ForgotPasswordRequestDto)
activate Ctrl

Ctrl ->> Svc : RequestPasswordResetAsync(email, ipAddress, userAgent)
activate Svc

Svc ->> AcctRepo : FindByEmailAsync(emailNormalized)
activate AcctRepo
AcctRepo ->> DB : Query staff account by normalized email
activate DB
DB -->> AcctRepo : Return account or null
deactivate DB
deactivate AcctRepo

alt#White Account not found or locked
    Svc ->> Svc : Simulate processing delay (50-150ms) to prevent timing attacks
    Svc -->> Ctrl : Return silently (no error)
else Account found and active
    Svc ->> Svc : GenerateSecurePasswordResetToken(tokenLengthBytes)
    Svc ->> Svc : HashPasswordResetToken(token)

    Svc ->> TokenStore : InvalidateUserAsync(accountId)
    activate TokenStore
    TokenStore -->> Svc : Existing tokens invalidated
    deactivate TokenStore

    Svc ->> TokenStore : StoreAsync(PasswordResetTokenRecord, ttl)
    activate TokenStore
    TokenStore -->> Svc : Token record stored in cache
    deactivate TokenStore

    Svc ->> Svc : Build reset link: {baseUrl}/reset-password?token={token}

    Svc ->> EmailTplSvc : GetByCodeAsync("FORGOT_PASSWORD")
    activate EmailTplSvc
    EmailTplSvc -->> Svc : Return email template
    deactivate EmailTplSvc

    alt#White Template found
        Svc ->> Svc : Replace placeholders (username, resetLink, expiryMinutes)

        Svc ->> EmailQ : EnqueueAsync(QueuedEmail)
        activate EmailQ
        EmailQ -->> Svc : Email queued for background delivery
        deactivate EmailQ
    end
end

Svc -->> Ctrl : Return (always completes successfully)
deactivate Svc

Ctrl -->> Client : 200 OK ("If an account with that email exists, a password reset link has been sent.")
deactivate Ctrl

Client -->> U : Display success message (regardless of email existence)

deactivate Client
deactivate U

@enduml
