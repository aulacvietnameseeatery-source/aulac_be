@startuml
title 2.1.2.5 - Change Own Password

skinparam maxMessageSize 250
skinparam sequence {
    ParticipantBackgroundColor #ffffff
    ActorBackgroundColor #ffffff
}

actor ":User" as U
participant ":ChangePasswordPage" as Client
participant ":AccountController" as Ctrl
participant ":AccountService" as Svc
participant ":IAccountRepository" as AcctRepo
participant ":IPasswordHasher" as Hasher
participant ":Database" as DB

autonumber

activate U

U ->> Client : Enter current password, new password, and confirm password
activate Client

Client ->> Ctrl : POST /api/account/change-password\n(ChangePasswordRequest)\n(Authorization: Bearer {accessToken})
activate Ctrl

Ctrl ->> Ctrl : GetCurrentUserId() from JWT claims

alt#White User not authenticated
    Ctrl -->> Client : 401 Unauthorized
    Client -->> U : Redirect to Login page
else User authenticated
    Ctrl ->> Svc : ChangePasswordForSelfAsync(userId, currentPassword, newPassword)
    activate Svc

    Svc ->> AcctRepo : FindByIdAsync(accountId)
    activate AcctRepo
    AcctRepo ->> DB : Query staff account by ID
    activate DB
    DB -->> AcctRepo : Return account
    deactivate DB
    deactivate AcctRepo

    alt#White Account not found
        Svc -->> Ctrl : Throw NotFoundException
        Ctrl -->> Client : 404 Not Found
        Client -->> U : Display error message
    else Account found
        Svc ->> Svc : Check if account.IsLocked (first-time change)

        alt#White Normal password change (account is NOT locked)
            alt#White Current password not provided
                Svc -->> Ctrl : Throw ValidationException("Current password is required")
                Ctrl -->> Client : 400 Bad Request
                Client -->> U : Display "Current password is required"
            else Current password provided
                Svc ->> Hasher : VerifyPassword(currentPassword, account.PasswordHash)
                activate Hasher
                Hasher -->> Svc : Return verification result
                deactivate Hasher

                alt#White Current password incorrect
                    Svc -->> Ctrl : Throw ValidationException("Current password is incorrect")
                    Ctrl -->> Client : 400 Bad Request
                    Client -->> U : Display "Current password is incorrect"
                end
            end
        end

        Svc ->> Hasher : HashPassword(newPassword)
        activate Hasher
        Hasher -->> Svc : Return hashed password
        deactivate Hasher

        Svc ->> Svc : Update account.PasswordHash

        opt#White Account was locked (first-time password change)
            Svc ->> Svc : Set AccountStatusLvId to ACTIVE, IsLocked = false
        end

        Svc ->> AcctRepo : UpdateAccountAsync(account)
        activate AcctRepo
        AcctRepo ->> DB : Update account password and status
        activate DB
        DB -->> AcctRepo : Confirm update
        deactivate DB
        deactivate AcctRepo

        Svc -->> Ctrl : Return true
        deactivate Svc

        Ctrl -->> Client : 200 OK ("Password changed successfully. Please login with your new password.")
        deactivate Ctrl

        Client -->> U : Display success message
    end
end

deactivate Client
deactivate U

@enduml
