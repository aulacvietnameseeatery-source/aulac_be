@startuml
title 2.1.2.4 - Reset Password

skinparam maxMessageSize 250
skinparam sequence {
    ParticipantBackgroundColor #ffffff
    ActorBackgroundColor #ffffff
}

actor ":User" as U
participant ":ResetPasswordPage" as Client
participant ":AuthController" as Ctrl
participant ":AuthService" as Svc
participant ":IPasswordResetTokenStore" as TokenStore
participant ":IAccountRepository" as AcctRepo
participant ":IPasswordHasher" as Hasher
participant ":IAuthSessionRepository" as SessRepo
participant ":Database" as DB

autonumber

activate U

U ->> Client : Open reset password link from email
activate Client

== Verify Token ==

Client ->> Ctrl : POST /api/auth/reset-password/verify\n(VerifyResetTokenRequestDto)
activate Ctrl

Ctrl ->> Svc : VerifyPasswordResetTokenAsync(token)
activate Svc

Svc ->> Svc : HashPasswordResetToken(token)

Svc ->> TokenStore : GetByTokenHashAsync(tokenHash)
activate TokenStore
TokenStore -->> Svc : Return PasswordResetTokenRecord or null
deactivate TokenStore

alt#White Token not found
    Svc -->> Ctrl : Return false
    Ctrl -->> Client : 200 OK (VerifyResetTokenResponseDto { Valid = false })
    Client -->> U : Display "Token is invalid or expired"
else Token found but expired
    Svc ->> TokenStore : ConsumeAsync(tokenHash)
    activate TokenStore
    TokenStore -->> Svc : Token consumed
    deactivate TokenStore
    Svc -->> Ctrl : Return false
    Ctrl -->> Client : 200 OK (VerifyResetTokenResponseDto { Valid = false })
    Client -->> U : Display "Token has expired"
else Token valid
    Svc -->> Ctrl : Return true
    deactivate Svc
    Ctrl -->> Client : 200 OK (VerifyResetTokenResponseDto { Valid = true })
    deactivate Ctrl
    Client -->> U : Show password reset form
end

== Submit New Password ==

U ->> Client : Enter new password and confirm

Client ->> Ctrl : POST /api/auth/reset-password\n(ResetPasswordRequestDto)
activate Ctrl

Ctrl ->> Svc : ResetPasswordAsync(token, newPassword)
activate Svc

Svc ->> Svc : HashPasswordResetToken(token)

Svc ->> TokenStore : GetByTokenHashAsync(tokenHash)
activate TokenStore
TokenStore -->> Svc : Return PasswordResetTokenRecord or null
deactivate TokenStore

alt#White Token invalid or expired
    Svc -->> Ctrl : Throw InvalidOperationException
    Ctrl -->> Client : 400 Bad Request ("Invalid or expired reset token")
    Client -->> U : Display error message
else Token valid
    Svc ->> AcctRepo : FindByIdAsync(record.UserId)
    activate AcctRepo
    AcctRepo ->> DB : Query staff account by ID
    activate DB
    DB -->> AcctRepo : Return account
    deactivate DB
    deactivate AcctRepo

    alt#White Account not found or locked
        Svc ->> TokenStore : ConsumeAsync(tokenHash)
        activate TokenStore
        TokenStore -->> Svc : Token consumed
        deactivate TokenStore
        Svc -->> Ctrl : Throw InvalidOperationException
        Ctrl -->> Client : 400 Bad Request ("Account not found or locked")
        Client -->> U : Display error message
    else Account found
        Svc ->> Hasher : HashPassword(newPassword)
        activate Hasher
        Hasher -->> Svc : Return hashed password
        deactivate Hasher

        Svc ->> AcctRepo : UpdatePasswordAsync(accountId, newPasswordHash)
        activate AcctRepo
        AcctRepo ->> DB : Update password hash for account
        activate DB
        DB -->> AcctRepo : Confirm update
        deactivate DB
        deactivate AcctRepo

        Svc ->> TokenStore : ConsumeAsync(tokenHash)
        activate TokenStore
        TokenStore -->> Svc : Token consumed (one-time use)
        deactivate TokenStore

        Svc ->> SessRepo : RevokeAllUserSessionsAsync(userId)
        activate SessRepo
        SessRepo ->> DB : Revoke all active sessions for user
        activate DB
        DB -->> SessRepo : Confirm sessions revoked
        deactivate DB
        deactivate SessRepo

        Svc -->> Ctrl : Return (success)
        deactivate Svc

        Ctrl -->> Client : 200 OK ("Password reset successfully")
        deactivate Ctrl

        Client -->> U : Display success and redirect to Login page
    end
end

deactivate Client
deactivate U

@enduml
