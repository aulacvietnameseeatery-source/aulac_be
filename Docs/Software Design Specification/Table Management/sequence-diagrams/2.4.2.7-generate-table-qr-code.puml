@startuml
title 2.4.2.7 Generate Table QR Code

skinparam maxMessageSize 250
skinparam sequence {
    ParticipantBackgroundColor #ffffff
    ActorBackgroundColor #ffffff
}

autonumber

actor ":User" as U
participant ":TableDetailPage" as Client
participant ":TableController" as Ctrl
participant ":TableService" as Svc
participant ":TableRepository" as Repo
participant ":Database" as DB

activate U

U ->> Client : Click "Regenerate QR Code" button
activate Client

Client ->> Ctrl : POST /api/tables/{id}/qr-code
activate Ctrl

Ctrl ->> Svc : RegenerateQrCodeAsync(id, ct)
activate Svc

Svc ->> Repo : GetByIdWithDetailsAsync(id, ct)
activate Repo
Repo ->> DB : Query table with QR image navigation
activate DB
DB -->> Repo : Return table entity
deactivate DB
Repo -->> Svc : RestaurantTable or null
deactivate Repo

alt#White Table not found
    Svc -->> Ctrl : throw NotFoundException
    Ctrl -->> Client : 404 Not Found
    Client -->> U : Display error message
else Table found
    opt#White Old QR image exists
        Svc ->> Svc : Remove old MediaAsset via IMediaRepository, set TableQrImg = null
    end

    Svc ->> Svc : Generate new QrToken (GUID)
    Svc ->> Svc : Update table.QrToken and table.UpdatedAt

    Svc ->> Repo : SaveChangesAsync via IUnitOfWork
    activate Repo
    Repo ->> DB : Update table QrToken and clear old QR image
    activate DB
    DB -->> Repo : Confirm update
    deactivate DB
    Repo -->> Svc : Done
    deactivate Repo

    Svc ->> Svc : BuildQrCodeUrl(tableCode, newToken)
    Svc ->> Svc : Generate QR PNG via IQrCodeGenerator
    Svc ->> Svc : Save QR image to file storage, create MediaAsset, link to table via SetQrImageAsync

    Svc ->> Repo : GetByIdWithDetailsAsync(id, ct)
    activate Repo
    Repo ->> DB : Query updated table with new QR image
    activate DB
    DB -->> Repo : Return updated table
    deactivate DB
    Repo -->> Svc : RestaurantTable
    deactivate Repo

    Svc ->> Svc : Build QrCodeDto with QrCodeUrl and QrCodeImageUrl

    Svc -->> Ctrl : QrCodeDto
    deactivate Svc

    Ctrl -->> Client : 200 OK — ApiResponse<QrCodeDto>
    deactivate Ctrl

    Client -->> U : Display new QR code image and URL
end

deactivate Client
deactivate U

@enduml
