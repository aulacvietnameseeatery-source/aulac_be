@startuml
title 2.7.2.2 Process Payment

skinparam maxMessageSize 250
skinparam sequence {
    ParticipantBackgroundColor #ffffff
    ActorBackgroundColor #ffffff
}

autonumber

actor ":Staff" as U
participant ":PaymentPage" as Client
participant ":PaymentController" as Ctrl
participant ":PaymentService" as Svc
participant ":ILookupResolver" as Lookup
participant ":IPaymentRepository" as PayRepo
participant ":ISystemSettingService" as Settings
participant ":IUnitOfWork" as UoW
participant ":INotificationService" as Notif
participant ":IShiftLiveRealtimePublisher" as ShiftLive
participant ":IOrderRealtimeService" as Realtime
participant ":Database" as DB

activate U

U ->> Client : Enter payment details (method, received amount, optional coupons, tip)
activate Client

Client ->> Ctrl : POST /api/payments (CreatePaymentDTO)
activate Ctrl

Ctrl ->> Svc : ProcessPaymentAsync(CreatePaymentDTO, ct)
activate Svc

Svc ->> PayRepo : GetOrderForPaymentAsync(dto.OrderId, ct)
activate PayRepo
PayRepo ->> DB : Query order by ID with items, customer, table, payments, coupons, promotions
activate DB
DB -->> PayRepo : Return order with navigation properties
deactivate DB
PayRepo -->> Svc : Order
deactivate PayRepo

alt#White Order not found
    Svc -->> Ctrl : throw KeyNotFoundException
    Ctrl -->> Client : 404 Not Found
    Client -->> U : Display "Order not found" error
else Order found

    Svc ->> Lookup : Resolve status IDs (OrderStatus CANCELLED/COMPLETED, TableStatus AVAILABLE, OrderItemStatus REJECTED/CANCELLED, CouponStatus ACTIVE, PromotionStatus ACTIVE)
    activate Lookup
    Lookup -->> Svc : All status lookup IDs
    deactivate Lookup

    alt#White Order is cancelled
        Svc -->> Ctrl : throw InvalidOperationException
        Ctrl -->> Client : 400 Bad Request ("Cannot pay for a cancelled order")
        Client -->> U : Display cancelled order error
    else Order is not cancelled

        alt#White Order already has payments
            Svc -->> Ctrl : throw InvalidOperationException
            Ctrl -->> Client : 400 Bad Request ("Order already paid")
            Client -->> U : Display already paid error
        else Order not yet paid

            Svc ->> Lookup : Resolve PaymentMethod ID from dto.PaymentMethod
            activate Lookup
            Lookup -->> Svc : paymentMethodLvId
            deactivate Lookup

            Svc ->> Settings : ResolveLoyaltyPolicyAsync(ct)
            activate Settings
            Settings -->> Svc : (loyaltyEnabled, loyaltyPointBaseAmount)
            deactivate Settings

            Svc ->> UoW : BeginTransactionAsync(ct)
            activate UoW
            UoW -->> Svc : Transaction started
            deactivate UoW

            Svc ->> Svc : Calculate subTotal from active order items (excluding rejected/cancelled)

            opt#White CouponIds provided
                loop For each couponId in dto.CouponIds
                    Svc ->> PayRepo : GetCouponWithTypeAsync(couponId, ct)
                    activate PayRepo
                    PayRepo ->> DB : Query coupon by ID with discount type
                    activate DB
                    DB -->> PayRepo : Return coupon entity
                    deactivate DB
                    PayRepo -->> Svc : Coupon
                    deactivate PayRepo

                    Svc ->> Svc : Validate coupon (active, within valid period, usage limit, belongs to customer)
                    Svc ->> Svc : CalculateDiscountAmount and create OrderCoupon entity
                end
            end

            Svc ->> PayRepo : GetActivePromotionsAsync(activePromotionStatusId, now, ct)
            activate PayRepo
            PayRepo ->> DB : Query all active promotions with targets and rules
            activate DB
            DB -->> PayRepo : Return list of active promotions
            deactivate DB
            PayRepo -->> Svc : List<Promotion>
            deactivate PayRepo

            Svc ->> Svc : Apply dish-level promotions (matching item targets with rules)
            Svc ->> Svc : Apply general promotions (no targets, rule-based)
            Svc ->> Svc : Create OrderPromotion entities and accumulate discounts

            Svc ->> Svc : Calculate finalAmount = subTotal + tax + tip - totalDiscounts
            Svc ->> Svc : Validate receivedAmount >= finalAmount

            alt#White Received amount less than final amount
                Svc ->> UoW : RollbackAsync(ct)
                activate UoW
                UoW -->> Svc : Transaction rolled back
                deactivate UoW
                Svc -->> Ctrl : throw InvalidOperationException
                Ctrl -->> Client : 400 Bad Request
                Client -->> U : Display insufficient payment error
            else Payment amount valid

                Svc ->> PayRepo : AddPaymentAsync(Payment entity, ct)
                activate PayRepo
                PayRepo ->> DB : Insert payment record
                activate DB
                DB -->> PayRepo : Payment persisted
                deactivate DB
                PayRepo -->> Svc : done
                deactivate PayRepo

                Svc ->> Svc : Set order.OrderStatusLvId = completedStatusId, update amounts

                opt#White Order has a table (dine-in)
                    Svc ->> PayRepo : GetTableByIdAsync(tableId, ct)
                    activate PayRepo
                    PayRepo -->> Svc : RestaurantTable
                    deactivate PayRepo
                    Svc ->> Svc : Set table.TableStatusLvId = availableTableStatusId
                end

                opt#White Loyalty enabled and customer is not guest
                    Svc ->> Svc : CalculateLoyaltyPoints(finalAmount, pointBaseAmount)
                    Svc ->> Svc : Add earned points to customer.LoyaltyPoints
                end

                Svc ->> UoW : SaveChangesAsync(ct)
                activate UoW
                UoW ->> DB : Persist all changes (payment, order status, coupons, promotions, table, loyalty)
                activate DB
                DB -->> UoW : All changes saved
                deactivate DB
                UoW -->> Svc : done
                deactivate UoW

                Svc ->> UoW : CommitAsync(ct)
                activate UoW
                UoW -->> Svc : Transaction committed
                deactivate UoW

                Svc ->> Notif : PublishAsync(PAYMENT_COMPLETED notification)
                activate Notif
                Notif -->> Svc : done
                deactivate Notif

                Svc ->> ShiftLive : PublishBoardChangedAsync(payment_completed event)
                activate ShiftLive
                ShiftLive -->> Svc : done
                deactivate ShiftLive

                Svc ->> Realtime : OrderPaidAsync(orderId)
                activate Realtime
                Realtime -->> Svc : done
                deactivate Realtime

                Svc -->> Ctrl : (void - success)
                deactivate Svc

                Ctrl -->> Client : 200 OK ("Payment processed successfully")
                deactivate Ctrl

                Client -->> U : Display payment success confirmation
            end
        end
    end
end

deactivate Client
deactivate U

@enduml
